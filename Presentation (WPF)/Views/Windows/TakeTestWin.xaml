<Window x:Class="Presentation.Views.Windows.TakeTestWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Take Test" 
        Height="850" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="LockedInput" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="CaretBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TestIdBox" TargetType="Border">
            <Setter Property="Background" Value="#172554"/>
            <Setter Property="BorderBrush" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,16,0,20"/>
        </Style>

        <Style x:Key="OptionToggle" TargetType="ToggleButton">
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{StaticResource InputBackground}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1.5"
                                CornerRadius="8"
                                Padding="16,0">
                            <ContentPresenter x:Name="Content"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#1E40AF"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Content" Property="TextBlock.Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PassedToggle" TargetType="ToggleButton" BasedOn="{StaticResource OptionToggle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="ToggleBorder"
                                        Background="#065F46"
                                        BorderBrush="#10B981"
                                        BorderThickness="1.5"
                                        CornerRadius="8"
                                        Padding="16,0">
                                    <ContentPresenter x:Name="Content"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextBlock.Foreground="#FFFFFF"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#34D399"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FailedToggle" TargetType="ToggleButton" BasedOn="{StaticResource OptionToggle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="ToggleBorder"
                                        Background="#7F1D1D"
                                        BorderBrush="#EF4444"
                                        BorderThickness="1.5"
                                        CornerRadius="8"
                                        Padding="16,0">
                                    <ContentPresenter x:Name="Content"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextBlock.Foreground="#FFFFFF"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#F87171"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NotTakenToggle" TargetType="ToggleButton" BasedOn="{StaticResource OptionToggle}">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="ToggleBorder"
                                        Background="#78350F"
                                        BorderBrush="#F59E0B"
                                        BorderThickness="1.5"
                                        CornerRadius="8"
                                        Padding="16,0">
                                    <ContentPresenter x:Name="Content"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      TextBlock.Foreground="#FFFFFF"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#FBBF24"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource CardStyle}" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" Padding="24" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource CardBackground}" 
                            BorderBrush="{StaticResource BorderColor}" 
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,20"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Vision Test" 
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextColor}"/>
                            <TextBlock Text="Scheduled Test" 
                                       FontSize="13" FontWeight="Normal"
                                       Foreground="{StaticResource SecondaryTextColor}" 
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="D.L. App ID" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Schedule.LocalDrivingLicenseApplicationID}" Style="{StaticResource LockedInput}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="D. Class" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Schedule.LicenseClassName}" Style="{StaticResource LockedInput}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Name" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Schedule.FullName}" Style="{StaticResource LockedInput}"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Trial" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Schedule.Trial}" Style="{StaticResource LockedInput}"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Date" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Schedule.Date, StringFormat='yyyy-MM-dd'}" Style="{StaticResource LockedInput}"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Fees" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding Schedule.Fees}" Style="{StaticResource LockedInput}"/>
                    </Grid>

                    <Border Style="{StaticResource TestIdBox}">
                        <Grid>
                            <TextBlock Text="Test ID" FontSize="12" FontWeight="SemiBold" Foreground="#93C5FD"/>
                            <TextBlock Text="{Binding Schedule.TestID, TargetNullValue='Not Taken Yet'}" FontSize="13" FontWeight="Bold" Foreground="#60A5FA" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="Result" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                    <UniformGrid Columns="3" Margin="0,0,0,24">
                        <ToggleButton Content="Passed" 
                                      Style="{StaticResource PassedToggle}" 
                                      Margin="0,0,8,0"
                                      IsChecked="{Binding IsPassed}"/>
                        <ToggleButton Content="Failed" 
                                      Style="{StaticResource FailedToggle}" 
                                      Margin="4,0"
                                      IsChecked="{Binding IsFailed}"/>
                        
                    </UniformGrid>

                    <TextBlock Text="Notes" Style="{StaticResource LabelStyle}" Margin="0,0,0,8"/>
                    <Grid Height="90" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource InputBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,1,0,1" CornerRadius="6,0,0,6">
                            <TextBlock Text="📁" FontSize="18" Foreground="{StaticResource SecondaryTextColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBox Grid.Column="1" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Height="90" VerticalContentAlignment="Top" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="{StaticResource InputBackground}" Foreground="{StaticResource TextColor}" FontSize="14"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="1" Background="Transparent" Padding="24,16" CornerRadius="0,0,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="Save" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Grid.Column="3" Content="Close" Command="{Binding CloseCommand}" Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
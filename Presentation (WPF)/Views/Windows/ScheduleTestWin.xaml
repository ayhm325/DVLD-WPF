<Window x:Class="Presentation.Views.Windows.ScheduleTestWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation.Views.Windows"        
        mc:Ignorable="d"
        Title="Schedule Test" 
        Height="700" Width="500" 
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Retake Section Style (Dark Mode Adapted) -->
        <Style x:Key="RetakeSectionStyle" TargetType="Border">
            <Setter Property="Background" Value="#451A03"/>
            <Setter Property="BorderBrush" Value="#B45309"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="24,0,24,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.15" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ReadOnly Input Override (Dark Mode) -->
        <Style x:Key="ReadOnlyInput" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="#020617"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#1E293B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Warning Text Style -->
        <Style x:Key="WarningText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FCD34D"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <!-- Main Container using Global CardStyle -->
    <Border Style="{StaticResource CardStyle}" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. MAIN CONTENT (ScrollViewer) -->
            <ScrollViewer Grid.Row="0" Padding="24,20" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- TITLE CARD -->
                    <Border Background="{StaticResource CardBackground}" 
                            BorderBrush="{StaticResource BorderColor}" 
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16,20"
                            Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Header Icon -->
                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21" Background="#FFFFFF" Opacity="0.15" VerticalAlignment="Center"/>

                            <!-- Header Titles -->
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Schedule Test" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextColor}"/>
                                <TextBlock Text="Vision Test" FontSize="13" Foreground="{StaticResource SecondaryTextColor}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- INPUTS GRID -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: D.L.App.ID & Trial -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="D.L.App.ID" Style="{StaticResource LabelStyle}"/>
                            <TextBox Style="{StaticResource ReadOnlyInput}" Text="{Binding Schedule.LocalDrivingLicenseApplicationID}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Trial" Style="{StaticResource LabelStyle}"/>
                            <!-- ليبل (قراءة فقط) -->
                            <TextBox Text="{Binding Schedule.Trial}" Style="{StaticResource ReadOnlyInput}"/>
                        </StackPanel>

                        <!-- Row 2: D. Class (Full Width) -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="D. Class" Style="{StaticResource LabelStyle}"/>
                            <!-- تحويل الـ ComboBox إلى TextBox ليبدو كباقي الليبلز -->
                            <TextBox Text="{Binding Schedule.LicenseClassName}" Style="{StaticResource ReadOnlyInput}"/>
                        </StackPanel>

                        <!-- Row 4: Name (Full Width) -->
                        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Name" Style="{StaticResource LabelStyle}"/>
                            <!-- ليبل (قراءة فقط) -->
                            <TextBox Text="{Binding Schedule.FullName}" Style="{StaticResource ReadOnlyInput}"/>
                        </StackPanel>

                        <!-- Row 6: Date & Fees -->
                        <StackPanel Grid.Row="6" Grid.Column="0">
                            <TextBlock Text="Date" Style="{StaticResource LabelStyle}"/>
                            <!-- التاريخ فقط هو المسموح بتعديله -->
                            <DatePicker SelectedDate="{Binding Schedule.Date}" DisplayDateStart="{Binding MinDate, Mode=OneWay}" Background="{StaticResource InputBackground}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="2">
                            <TextBlock Text="Fees" Style="{StaticResource LabelStyle}"/>
                            <!-- ليبل (قراءة فقط) -->
                            <TextBox Text="{Binding Schedule.Fees}" Style="{StaticResource ReadOnlyInput}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- 2. RETAKE SECTION (Conditional) -->
            <Border Grid.Row="1" Style="{StaticResource RetakeSectionStyle}" 
                    Visibility="{Binding IsRetake,Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header Warning -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="Retake Test Info" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Style="{StaticResource WarningText}"/>
                    </StackPanel>

                    <!-- Retake Fields -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- R.App.Fees -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="R.App.Fees" FontSize="11" FontWeight="SemiBold" Foreground="#D97706" Margin="0,0,0,4"/>
                            <!-- جعله للقراءة فقط مع الحفاظ على ستايل التحذير -->
                            <TextBox Height="32" FontSize="13" Background="#0F172A" 
                                     BorderBrush="#B45309" Padding="8,4" Text="{Binding Schedule.RetakerFees}" IsReadOnly="True"
                                     BorderThickness="1" Foreground="White"/>
                        </StackPanel>

                        <!-- Total Fees -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Total Fees" FontSize="11" FontWeight="SemiBold" Foreground="#D97706" Margin="0,0,0,4"/>
                            <TextBox Height="32" FontSize="13" Background="#1E293B" 
                                     BorderBrush="#B45309" FontWeight="Bold" Padding="8,4" Text="{Binding TotalFees, Mode=OneWay}" 
                                     IsReadOnly="True" BorderThickness="1" Foreground="#FCD34D"/>
                        </StackPanel>

                        <!-- R.Test.App.ID -->
                        <StackPanel Grid.Column="4">
                            <TextBlock Text="R.Test.App.ID" FontSize="11" FontWeight="SemiBold" Foreground="#D97706" Margin="0,0,0,4"/>
                            <TextBox Height="32" FontSize="13" Background="#0F172A" 
                                     BorderBrush="#B45309" Padding="8,4" Text="{Binding Schedule.TestID}"
                                     IsReadOnly="True" BorderThickness="1" Foreground="#94A3B8"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- 3. FOOTER -->
            <Border Grid.Row="2" Background="{StaticResource CardBackground}" CornerRadius="0,0,12,12" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status Text -->

                    <!-- Buttons using Commands -->
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}" Content="Save"/>
                    <Button Grid.Column="3" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding CloseCommand}" Content="Close"/>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
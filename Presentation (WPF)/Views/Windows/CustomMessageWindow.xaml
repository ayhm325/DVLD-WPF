<Window x:Class="Presentation.Views.Windows.CustomMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        SizeToContent="WidthAndHeight"
        Background="SeaGreen">

    <Border CornerRadius="12"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            Padding="20">

        <StackPanel Width="320">

            <TextBlock x:Name="TxtTitle"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <TextBlock x:Name="TxtMessage"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <Button Content="OK"
                    Width="90"
                    Height="35"
                    HorizontalAlignment="Right"
                    Click="BtnOk_Click"/>
        </StackPanel>

    </Border>
</Window>
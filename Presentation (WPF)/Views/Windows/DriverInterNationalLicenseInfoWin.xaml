<Window x:Class="Presentation.Views.Windows.DriverInterNationalLicenseInfoWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="International Driver License Information"
        Height="580"
        Width="820"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- تدرج الهيدر الموحد -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- ألوان دلالية مطابقة للستايل العام -->
        <SolidColorBrush x:Key="ActiveGreenText" Color="#34D399"/>
        <SolidColorBrush x:Key="InactiveRedText" Color="#F87171"/>

        <!-- نمط حدود المجموعات الفرعية -->
        <Style x:Key="SubGroupBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- نمط لقيم الحقول -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
        </Style>

        <!-- تسمية القسم الفرعي -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>
    </Window.Resources>

    <!-- الحاوية الرئيسية -->
    <Border Background="{StaticResource BackgroundColor}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="16"
            Margin="15">

        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ================= الهيدر الموحد ================= -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}"
                    CornerRadius="16,16,0,0"
                    Padding="25,18,25,18">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10"
                                Background="{StaticResource PrimaryColor}"
                                Opacity="0.15"
                                Margin="0,0,14,0"
                                Padding="8"
                                VerticalAlignment="Center">
                            <Path Data="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                  Stroke="{StaticResource PrimaryColor}" StrokeThickness="1.6"
                                  Fill="Transparent" Stretch="Uniform" Height="20" Width="20"/>
                        </Border>
                        <TextBlock Text="Driver International License Info"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- شارة الـ ID -->
                    <Border Background="#042F2E"
                            BorderBrush="{StaticResource PrimaryColor}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource PrimaryColor}"
                                   FontWeight="Bold" FontSize="12" x:Name="txtIntLicenseId">
                            <Run Text="ID: "/>
                            <Run Text="{Binding LicenseData.InternationalLicenseID}"/>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- ================= المحتوى الرئيسي ================= -->
            <Grid Grid.Row="1" Margin="20,15,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- العمود الأيسر: البيانات -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- ====== قسم المعلومات الشخصية (5 حقول) ====== -->
                        <TextBlock Text="Personal Information" Style="{StaticResource SectionTitleStyle}"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="155"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 1. Full Name -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LicenseData.FullName}" Style="{StaticResource ValueTextStyle}" FontWeight="SemiBold" x:Name="txtFullName"/>

                                <!-- 2. Date Of Birth -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Date Of Birth" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LicenseData.DateOfBirth, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtDateOfBirth"/>

                                <!-- 3. Gender -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Gender" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicenseData.Gender}" Style="{StaticResource ValueTextStyle}" x:Name="txtGender"/>

                                <!-- 4. National No. -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="National No." Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LicenseData.NationalNo}" Style="{StaticResource ValueTextStyle}" x:Name="txtNationalNo"/>

                                <!-- 5. Driver ID -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Driver ID" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <Border Grid.Row="4" Grid.Column="1"
                                        MinWidth="40" Height="24" CornerRadius="6"
                                        Background="#042F2E"
                                        BorderBrush="{StaticResource PrimaryColor}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Left" Margin="0,4,0,10" Padding="8,0">
                                    <TextBlock Text="{Binding LicenseData.DriverID}"
                                               Foreground="{StaticResource PrimaryColor}"
                                               FontWeight="Bold" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               x:Name="txtDriverIdBadge"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ====== قسم تفاصيل الرخصة الدولية (5 حقول) ====== -->
                        <TextBlock Text="License Details" Style="{StaticResource SectionTitleStyle}"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="155"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 6. International License ID -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Int. License ID" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <Border Grid.Row="0" Grid.Column="1"
                                        MinWidth="40" Height="24" CornerRadius="6"
                                        Background="#042F2E"
                                        BorderBrush="{StaticResource PrimaryColor}"
                                        BorderThickness="1"
                                        HorizontalAlignment="Left" Margin="0,4,0,10" Padding="8,0">
                                    <TextBlock Text="{Binding LicenseData.InternationalLicenseID}"
                                               Foreground="{StaticResource PrimaryColor}"
                                               FontWeight="Bold" FontSize="12"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               x:Name="txtLicenseIdBadge"/>
                                </Border>

                                <!-- 7. License ID -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="License ID" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LicenseData.IssuedUsingLocalLicenseID}" Style="{StaticResource ValueTextStyle}" x:Name="txtLicenseId"/>

                                <!-- 8. Application ID -->
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Application ID" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicenseData.ApplicationID}"
                                           Style="{StaticResource ValueTextStyle}"
                                           Foreground="{StaticResource SecondaryTextColor}"
                                           FontStyle="Italic" x:Name="txtApplicationId"/>

                                <!-- 9. Issue Date -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Issue Date" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LicenseData.IssueDate, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtIssueDate"/>

                                <!-- 10. Expiration Date -->
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Expiration Date" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LicenseData.ExpirationDate, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtExpirationDate"/>
                            </Grid>
                        </Border>

                        <!-- ====== قسم الحالة (1 حقل) ====== -->
                        <TextBlock Text="Status" Style="{StaticResource SectionTitleStyle}"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}" Margin="0,0,0,0">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="155"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 11. IsActive -->
                                <TextBlock Grid.Column="0" Text="Active Status" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,0,0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,8">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource SecondaryTextColor}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LicenseData.IsActive}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource ActiveGreenText}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding LicenseData.IsActive}" FontWeight="Bold" Foreground="{StaticResource TextColor}" x:Name="txtIsActive"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ================= العمود الأيمن: الصورة (12) ================= -->
                <Border Grid.Column="2"
                        Width="180"
                        Height="240"
                        CornerRadius="12"
                        Background="{StaticResource InputBackground}"
                        BorderBrush="{StaticResource PrimaryColor}"
                        BorderThickness="2"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center">

                    <Grid>
                        <TextBlock Text="NO PHOTO"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource SecondaryTextColor}"
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Image Source="{Binding LicenseData.ImagePath}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               x:Name="imgPerson">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                </Border>
            </Grid>

            <!-- ================= شريط الأزرار السفلي ================= -->
            <Border Grid.Row="2" Background="{StaticResource BackgroundColor}"
                    Padding="20,15,25,20"
                    CornerRadius="0,0,16,16"
                    Margin="-1,0,-1,-1">
                <Button Content="Close"
                        Width="120"
                        HorizontalAlignment="Right"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CloseCommand}"/>
            </Border>

        </Grid>
    </Border>
</Window>
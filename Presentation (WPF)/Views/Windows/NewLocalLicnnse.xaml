<Window x:Class="Presentation.Views.Windows.NewLocalLicnnse"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Presentation.Views.Controls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="New Local Driving License Application"
        Height="650" 
        Width="850"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">

    <Window.Resources>
        <!-- لون الأيقونات (Emerald Green) -->
        <SolidColorBrush x:Key="InfoIconColor" Color="#10B981"/>

        <!-- تعريف ValueTextStyle محلياً لضمان تنسيق القيم -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- العنوان: استخدام الستايل العام -->
        <TextBlock Text="New Local Driving License Application"
                   Style="{StaticResource HeaderStyle}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- نمط التبويب -->
        <TabControl x:Name="MainTabControl" 
                    Grid.Row="1"
                    Background="Transparent" 
                    BorderThickness="0">

            <!-- التبويب الأول: معلومات شخصية -->
            <TabItem Header="Personal Info" Style="{StaticResource TabItemStyle}" FontSize="14">
                <DockPanel Margin="0,0,0,15" LastChildFill="True">

                    <!-- فلتر البحث -->
                    <controls:Filter DockPanel.Dock="Top" Margin="0,0,0,10" />

                    <!-- زر Next -->
                    <Button DockPanel.Dock="Bottom"
                            Content="Next"
                            HorizontalAlignment="Right"
                            Margin="0,15,0,0"
                            Click="NextButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <controls:InformationPerson Person="{Binding Person}" />
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- التبويب الثاني: معلومات الطلب -->
            <TabItem Header="Application Info" Style="{StaticResource TabItemStyle}" FontSize="14">
                <StackPanel Margin="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 1: ID -->
                        <materialDesign:PackIcon Kind="Identifier" Foreground="{StaticResource InfoIconColor}" 
                                                Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="D.L. Application ID:" 
                                   Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ApplicationId}" 
                                   Style="{StaticResource ValueTextStyle}" VerticalAlignment="Center"/>

                        <!-- Row 2: Date -->
                        <materialDesign:PackIcon Kind="Calendar" Foreground="{StaticResource InfoIconColor}" 
                                                Grid.Row="1" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Application Date:" 
                                   Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ApplicationDate, StringFormat='{}{0:dd/MM/yyyy}'}" 
                                   Style="{StaticResource ValueTextStyle}" VerticalAlignment="Center"/>

                        <!-- Row 3: License Class -->
                        <materialDesign:PackIcon Kind="Car" Foreground="{StaticResource InfoIconColor}" 
                                                Grid.Row="2" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="License Class:" 
                                   Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>

                        <!-- ComboBox: ستأخذ الستايل العام (الارتفاع 38) مع العرض المطلوب -->
                        <ComboBox Grid.Row="2" Grid.Column="2" 
                                  ItemsSource="{Binding LicenseClasses}" 
                                  SelectedItem="{Binding SelectedLicenseClass}" 
                                  DisplayMemberPath="LicenseClassName" 
                                  Width="250" 
                                  VerticalAlignment="Center"/>

                        <!-- Row 4: Fees -->
                        <materialDesign:PackIcon Kind="Cash" Foreground="{StaticResource InfoIconColor}" 
                                                Grid.Row="3" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Application Fees:" 
                                   Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ApplicationTypeFees, StringFormat='{}{0:F2}'}" 
                                   Style="{StaticResource ValueTextStyle}" VerticalAlignment="Center"/>

                        <!-- Row 5: Created By -->
                        <materialDesign:PackIcon Kind="Account" Foreground="{StaticResource InfoIconColor}" 
                                                Grid.Row="4" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Created By:" 
                                   Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding CreatedBy}" 
                                   Style="{StaticResource ValueTextStyle}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- الأزرار السفلية -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <!-- زر الحفظ -->
            <Button Content="Save" 
                    Command="{Binding SaveCommand}" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100" 
                    Margin="0,0,10,0"/>

            <!-- زر الإغلاق (بدون Height ليتوافق مع الستايل) -->
            <Button Content="Close" 
                    Click="CloseButton_Click" 
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Width="100"/>
        </StackPanel>
    </Grid>
</Window>
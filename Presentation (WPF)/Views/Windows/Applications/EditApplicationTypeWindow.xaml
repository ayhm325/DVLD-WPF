<Window x:Class="Presentation.Views.Windows.Applications.EditApplicationTypeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Update Application Type"
        Height="450"
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <!-- تدرج الهيدر الموحد -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- تسمية الحقل -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- ستايل زر الإغلاق -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="{StaticResource ErrorColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- تجاوز ارتفاع الـ TextBox للنصوص الطويلة -->
        <Style x:Key="MultiLineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="MinHeight" Value="80"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>
    </Window.Resources>

    <!-- الحاوية الرئيسية -->
    <Border Style="{StaticResource CardStyle}" Padding="30" Margin="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ================= الهيدر الموحد ================= -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                    CornerRadius="12" Padding="18,14,18,14" Margin="-30,-30,-30,20">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="10" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.15"
                                Margin="0,0,14,0"
                                Padding="7"
                                VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="ApplicationEdit" 
                                                    Foreground="{StaticResource PrimaryColor}" 
                                                    Width="20" Height="20" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Update Application Type" 
                                   FontSize="18" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Content="✕" 
                            Style="{StaticResource CloseButtonStyle}" 
                            HorizontalAlignment="Right" 
                            Click="Close_Click"/>
                </Grid>
            </Border>

            <!-- ================= الحقول ================= -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= ID ================= -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Border Width="34" Height="34" CornerRadius="9" 
                            Background="#042F2E" 
                            Margin="0,0,12,0" 
                            VerticalAlignment="Center"
                            Padding="7">
                        <materialDesign:PackIcon Kind="Identifier"
                                                 Foreground="{StaticResource PrimaryColor}"
                                                 Width="18" Height="18"
                                                 VerticalAlignment="Center" 
                                                 HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ID" Style="{StaticResource FormLabelStyle}"/>
                        <TextBlock Text="{Binding CurrentApplicationType.ApplicationTypeId}"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource SecondaryTextColor}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- ================= TITLE ================= -->
                <StackPanel Grid.Row="2">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="34" Height="34" CornerRadius="9" 
                                Background="#042F2E" 
                                Margin="0,0,12,0" 
                                VerticalAlignment="Center"
                                Padding="7">
                            <materialDesign:PackIcon Kind="TextBoxEditOutline"
                                                     Foreground="{StaticResource PrimaryColor}"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" 
                                                     HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Title" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding CurrentApplicationType.ApplicationTypeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MultiLineTextBoxStyle}"/>
                </StackPanel>

                <!-- ================= FEES ================= -->
                <StackPanel Grid.Row="4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="34" Height="34" CornerRadius="9" 
                                Background="#042F2E" 
                                Margin="0,0,12,0" 
                                VerticalAlignment="Center"
                                Padding="7">
                            <materialDesign:PackIcon Kind="Cash100"
                                                     Foreground="{StaticResource PrimaryColor}"
                                                     Width="18" Height="18"
                                                     VerticalAlignment="Center" 
                                                     HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Fees" Style="{StaticResource FormLabelStyle}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBox Text="{Binding CurrentApplicationType.ApplicationTypeFees,
                                            UpdateSourceTrigger=PropertyChanged,
                                            StringFormat={}{0:F2}}"/>
                </StackPanel>
            </Grid>

            <!-- ================= الأزرار ================= -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,25,0,0">

                <Button Command="{Binding SaveCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Width="120"
                        Margin="0,0,10,0"
                        Style="{StaticResource PrimaryButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave"
                                                 Width="18" Height="18"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding CloseCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Width="120"
                        Style="{StaticResource SecondaryButtonStyle}">

                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close"
                                                 Width="18" Height="18"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Close" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>

        </Grid>
    </Border>
</Window>
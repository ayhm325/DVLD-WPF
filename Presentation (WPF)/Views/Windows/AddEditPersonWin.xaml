<Window x:Class="Presentation.Views.Windows.AddEditPersonWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:Presentation.Views.Controls"
        mc:Ignorable="d"
        Title="Add/Edit Person"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}"
        ResizeMode="CanResize">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title Section -->
        <TextBlock Text="{Binding PageTitle}"
                   Style="{StaticResource HeaderStyle}"
                   Margin="0,0,0,20"/>

        <!-- Content Section (Inside a Card) -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,20">

            <Border Style="{StaticResource CardStyle}" Padding="25">
                <controls:PersonInfoCard />
            </Border>

        </ScrollViewer>

        <!-- Buttons Section -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Close" 
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Click="CloseButton_Click" 
                    Width="100"
                    Margin="0,0,15,0"/>

            <Button Content="Save"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="100"
                    Command="{Binding SavePersonCommand}"/>

        </StackPanel>

    </Grid>
</Window>
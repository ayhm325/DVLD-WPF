<Window x:Class="Presentation.Views.Windows.PersonDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Person Information Details" 
        Height="450" 
        Width="900"
        Background="#F0F2F5" 
        ResizeMode="NoResize" 
        WindowStyle="ThreeDBorderWindow"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto">

    <Window.Resources>
        <!-- Resources -->
        <DropShadowEffect x:Key="CardShadow" Color="#000000" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.08"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0078D7"/>
        <SolidColorBrush x:Key="PrimaryBlueLight" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextGray" Color="#7F8C8D"/>

        <!-- Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                                <Setter Property="Foreground" Value="#2C3E50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">

        <!-- Main Card -->
        <Border Background="White" CornerRadius="12" Padding="30" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource PrimaryBlueLight}" 
                                VerticalAlignment="Center" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="Account" Foreground="{StaticResource PrimaryBlue}" 
                                                    Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Detailed Person Profile" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Decorative Line -->
                    <Border Height="3" Width="40" Margin="48,32,0,0" Background="{StaticResource PrimaryBlue}" CornerRadius="2" HorizontalAlignment="Left"/>
                </Grid>

                <!-- Content Area: 3 Columns -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- Col 1: Data -->
                        <ColumnDefinition Width="40"/>
                        <!-- Spacing -->
                        <ColumnDefinition Width="*"/>
                        <!-- Col 2: Data -->
                        <ColumnDefinition Width="40"/>
                        <!-- Spacing -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Col 3: Image -->
                    </Grid.ColumnDefinitions>

                    <!-- Left Column Data -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top">
                        <!-- Person ID -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Person ID" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblPersonId" FontSize="14" FontWeight="Bold" Foreground="{StaticResource PrimaryBlue}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- National No -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="National No" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblNationalNo" FontSize="14" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Full Name -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Full Name" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblFullName" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextDark}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Gender -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Gender" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblGender" FontSize="14" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Phone -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Phone" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblPhone" FontSize="14" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- Right Column Data -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <!-- Date Of Birth -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Date Of Birth" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblDateOfBirth" FontSize="14" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Email -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Email" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblEmail" FontSize="14" Foreground="{StaticResource TextDark}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>

                        <!-- Country -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Country" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LblCountry" FontSize="14" Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Address -->
                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Address" Foreground="{StaticResource TextGray}" FontSize="12" VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1" x:Name="LblAddress" FontSize="14" Foreground="{StaticResource TextDark}" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>

                    <!-- Image Column (3rd) -->
                    <Border Grid.Column="4" Width="160" Height="160" CornerRadius="100" BorderThickness="3" BorderBrush="White" Effect="{StaticResource CardShadow}" VerticalAlignment="Top">
                        <Border.Clip>
                            <EllipseGeometry Center="80,80" RadiusX="80" RadiusY="80"/>
                        </Border.Clip>
                        <Image x:Name="ImgPerson" Stretch="UniformToFill" />
                    </Border>
                </Grid>

                <!-- Footer / Close Button -->
                <Grid Grid.Row="2" Margin="0,25,0,0">
                    <Button Content="Close" 
                            HorizontalAlignment="Right" 
                            Width="100" 
                            Height="35" 
                            Style="{StaticResource CloseButtonStyle}"
                            Click="Close_Click"/>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
<Window x:Class="Presentation.Views.Windows.PersonDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Person Information Details"
        Height="450"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">

    <Window.Resources>
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">

        <Border Style="{StaticResource CardStyle}" Padding="30">

            <!-- MAIN GRID -->
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= HEADER ================= -->
                <StackPanel Grid.Row="0" Margin="0,0,0,25">

                    <StackPanel Orientation="Horizontal">

                        <Border Width="36" Height="36"
                                CornerRadius="18"
                                Background="{StaticResource InputBackground}"
                                Margin="0,0,12,0">

                            <materialDesign:PackIcon Kind="Account"
                                                      Foreground="{StaticResource PrimaryColor}"
                                                      Width="20"
                                                      Height="20"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Detailed Person Profile"
                                   Style="{StaticResource HeaderStyle}"
                                   VerticalAlignment="Center"/>

                    </StackPanel>

                    <Border Height="3"
                            Width="40"
                            Margin="0,10,0,0"
                            Background="{StaticResource PrimaryColor}"
                            CornerRadius="2"/>
                </StackPanel>

                <!-- ================= CONTENT ================= -->
                <Grid Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ===== LEFT COLUMN ===== -->
                    <StackPanel Grid.Column="0">

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Person ID"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblPersonId"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="National No"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblNationalNo"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Full Name"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblFullName"
                                       Style="{StaticResource ValueTextStyle}"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Gender"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblGender"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Phone"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblPhone"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </Grid>

                    </StackPanel>

                    <!-- ===== RIGHT COLUMN ===== -->
                    <StackPanel Grid.Column="2">

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Date Of Birth"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblDateOfBirth"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Email"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblEmail"
                                       Style="{StaticResource ValueTextStyle}"
                                       TextWrapping="Wrap"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Country"
                                       Style="{StaticResource LabelStyle}"/>
                            <TextBlock Grid.Column="1"
                                       x:Name="LblCountry"
                                       Style="{StaticResource ValueTextStyle}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Address"
                                       Style="{StaticResource LabelStyle}"
                                       VerticalAlignment="Top"/>

                            <TextBlock Grid.Column="1"
                                       x:Name="LblAddress"
                                       Style="{StaticResource ValueTextStyle}"
                                       TextWrapping="Wrap"/>
                        </Grid>

                    </StackPanel>

                    <!-- ===== IMAGE ===== -->
                    <Border Grid.Column="4"
                            Width="160"
                            Height="160"
                            CornerRadius="80"
                            Background="{StaticResource InputBackground}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="2"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">

                        <Border.Clip>
                            <EllipseGeometry Center="80,80"
                                             RadiusX="80"
                                             RadiusY="80"/>
                        </Border.Clip>

                        <Image x:Name="ImgPerson"
                               Stretch="UniformToFill"/>
                    </Border>

                </Grid>

                <!-- ================= FOOTER ================= -->
                <Grid Grid.Row="2" Margin="0,25,0,0">

                    <Button Content="Close"
                            Width="100"
                            HorizontalAlignment="Right"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="Close_Click"/>
                </Grid>

            </Grid>

        </Border>

    </Grid>

</Window>
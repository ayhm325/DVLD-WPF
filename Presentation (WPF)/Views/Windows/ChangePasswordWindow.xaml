<Window x:Class="Presentation.Views.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Presentation.Helpers"
        Title="Change Password" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/GlobalStyles.xaml"/>
                <ResourceDictionary Source="/Resources/PrimaryButtonStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- CardStyle يعالج الخلفية البيضاء والظل والزوايا -->
    <Border Style="{StaticResource CardStyle}" Margin="20" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Change Password" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="User: " FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" Margin="0,0,15,0" Foreground="{StaticResource TextColor}"/>
                    <TextBlock Text="ID: " FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                    <TextBlock Text="{Binding UserId}" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,10">

                <!-- 1. Current Password Field -->
                <TextBlock Text="Current Password:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                <!-- Grid Height matches the input style height (38) -->
                <Grid Height="38" Margin="0,0,0,15">
                    <!-- PasswordBox: يستخدم الستايل العام مع Padding مخصص للعين -->
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding CurrentPassword, Mode=TwoWay}"
                                 Padding="10,0,35,0"
                                 VerticalContentAlignment="Center">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <!-- TextBox: يستخدم الستايل العام مع Padding مخصص للعين -->
                    <TextBox Text="{Binding CurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,0,35,0" 
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Eye Button -->
                    <Button HorizontalAlignment="Right" Width="35" Height="38" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleCurrentPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- 2. New Password Field -->
                <TextBlock Text="New Password:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                <Grid Height="38" Margin="0,0,0,15">
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding NewPassword, Mode=TwoWay}"
                                 Padding="10,0,35,0"
                                 VerticalContentAlignment="Center">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <TextBox Text="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,0,35,0" 
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button HorizontalAlignment="Right" Width="35" Height="38" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleNewPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- 3. Confirm New Password Field -->
                <TextBlock Text="Confirm New Password:" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                <Grid Height="38" Margin="0,0,0,15">
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding ConfirmNewPassword, Mode=TwoWay}"
                                 Padding="10,0,35,0"
                                 VerticalContentAlignment="Center">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConfirmNewPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <TextBox Text="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,0,35,0" 
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConfirmNewPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button HorizontalAlignment="Right" Width="35" Height="38" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleConfirmPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <!-- تم إزالة Height ليتحكم فيه الستايل (يصبح 40) -->
                <Button Content="Save" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ChangePasswordCommand}" 
                        Width="100" Margin="0,0,10,0"/>

                <Button Content="Close" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Click="CloseButton_Click" 
                        Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
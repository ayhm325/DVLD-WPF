<Window x:Class="Presentation.Views.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Presentation.Helpers"
        Title="Change Password" 
        Height="520" 
        Width="450"
        WindowStartupLocation="CenterScreen"       
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- تدرج الهيدر الموحد -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- ستايل زر الإغلاق -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="{StaticResource ErrorColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ستايل زر إظهار/إخفاء كلمة المرور -->
        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0,8,8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A1A1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- الحاوية الرئيسية -->
    <Border Background="{StaticResource BackgroundColor}" 
            BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="15">

        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- User Info -->
                <RowDefinition Height="*"/>
                <!-- Fields -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- ================= الهيدر الموحد ================= -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                    CornerRadius="16,16,0,0" 
                    Padding="25,18,25,18">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.15"
                                Margin="0,0,14,0"
                                Padding="8"
                                VerticalAlignment="Center">
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14M21,12V14H19V12H21M21,16V18H19V16H21M21,8V10H19V8H21M21,4V6H19V4H21Z" 
                                  Stroke="{StaticResource PrimaryColor}" StrokeThickness="1.6" 
                                  Fill="Transparent" Stretch="Uniform" Height="20" Width="20"/>
                        </Border>
                        <TextBlock Text="Change Password" 
                                   FontSize="18" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    
                </Grid>
            </Border>

            <!-- ================= معلومات المستخدم ================= -->
            <Border Grid.Row="1" Background="#0E0E10" 
                    Padding="25,12,25,12" 
                    Margin="-1,0,-1,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="User: " FontWeight="SemiBold" 
                               Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" 
                               Margin="0,0,20,0" Foreground="{StaticResource TextColor}" VerticalAlignment="Center"/>
                    <TextBlock Text="ID: " FontWeight="SemiBold" 
                               Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UserId}" FontWeight="SemiBold" 
                               Margin="0,0,0,0" Foreground="{StaticResource TextColor}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ================= الحقول ================= -->
            <StackPanel Grid.Row="2" Margin="25,20,25,0">

                <!-- 1. Current Password -->
                <TextBlock Text="Current Password" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,15">
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding CurrentPassword, Mode=TwoWay}"
                                 Padding="10,0,40,0">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <TextBox Text="{Binding CurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,0,40,0">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Style="{StaticResource EyeButtonStyle}"
                            HorizontalAlignment="Right"
                            Command="{Binding ToggleCurrentPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" 
                                   Foreground="{StaticResource PrimaryColor}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- 2. New Password -->
                <TextBlock Text="New Password" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,15">
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding NewPassword, Mode=TwoWay}"
                                 Padding="10,0,40,0">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <TextBox Text="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,0,40,0">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Style="{StaticResource EyeButtonStyle}"
                            HorizontalAlignment="Right"
                            Command="{Binding ToggleNewPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" 
                                   Foreground="{StaticResource PrimaryColor}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- 3. Confirm New Password -->
                <TextBlock Text="Confirm New Password" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,0">
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding ConfirmNewPassword, Mode=TwoWay}"
                                 Padding="10,0,40,0">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConfirmNewPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <TextBox Text="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,0,40,0">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConfirmNewPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Style="{StaticResource EyeButtonStyle}"
                            HorizontalAlignment="Right"
                            Command="{Binding ToggleConfirmPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" 
                                   Foreground="{StaticResource PrimaryColor}" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

            </StackPanel>

            <!-- ================= شريط الأزرار السفلي ================= -->
            <Border Grid.Row="3" Background="{StaticResource BackgroundColor}" 
                    Padding="25,15,25,20" 
                    CornerRadius="0,0,16,16"
                    Margin="-1,0,-1,-1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="Save" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding ChangePasswordCommand}" 
                            Width="120" 
                            Margin="0,0,15,0"/>

                    <Button Content="Close" 
                            Style="{StaticResource SecondaryButtonStyle}" 
                            Click="CloseButton_Click" 
                            Width="120"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
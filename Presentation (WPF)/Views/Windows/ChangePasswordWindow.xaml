<Window x:Class="Presentation.Views.Windows.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Presentation.Helpers"
        Title="Change Password" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F8FAFC">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/GlobalStyles.xaml"/>
                <ResourceDictionary Source="/Resources/PrimaryButtonStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Style="{StaticResource CardStyle}" Margin="20" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Change Password" Style="{StaticResource HeaderStyle}" Margin="0,0,0,20"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="User: " FontWeight="Bold" Foreground="#64748B"/>
                    <TextBlock Text="{Binding UserName}" FontWeight="Bold" Margin="0,0,15,0"/>
                    <TextBlock Text="ID: " FontWeight="Bold" Foreground="#64748B"/>
                    <TextBlock Text="{Binding UserId}" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,10">

                <!-- 1. Current Password Field -->
                <TextBlock Text="Current Password:" Style="{StaticResource LabelStyle}"/>
                <Grid Height="35" Margin="0,5,0,15">
                    <!-- PasswordBox -->
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding CurrentPassword, Mode=TwoWay}"
                                 Padding="5,0,35,0"
                                 VerticalContentAlignment="Center">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    <!-- TextBox -->
                    <TextBox Text="{Binding CurrentPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,0,35,0" 
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <!-- Eye Button -->
                    <Button HorizontalAlignment="Right" Width="35" Height="35" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleCurrentPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- 2. New Password Field -->
                <TextBlock Text="New Password:" Style="{StaticResource LabelStyle}"/>
                <Grid Height="35" Margin="0,5,0,15">
                    <!-- PasswordBox -->
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding NewPassword, Mode=TwoWay}"
                                 Padding="5,0,35,0"
                                 VerticalContentAlignment="Center">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    <!-- TextBox -->
                    <TextBox Text="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,0,35,0" 
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <!-- Eye Button -->
                    <Button HorizontalAlignment="Right" Width="35" Height="35" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleNewPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <!-- 3. Confirm New Password Field -->
                <TextBlock Text="Confirm New Password:" Style="{StaticResource LabelStyle}"/>
                <Grid Height="35" Margin="0,5,0,15">
                    <!-- PasswordBox -->
                    <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                 helpers:PasswordBoxHelper.Password="{Binding ConfirmNewPassword, Mode=TwoWay}"
                                 Padding="5,0,35,0"
                                 VerticalContentAlignment="Center">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConfirmNewPasswordVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                    <!-- TextBox -->
                    <TextBox Text="{Binding ConfirmNewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,0,35,0" 
                             VerticalContentAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConfirmNewPasswordVisible}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <!-- Eye Button -->
                    <Button HorizontalAlignment="Right" Width="35" Height="35" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding ToggleConfirmPasswordCommand}">
                        <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Save" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ChangePasswordCommand}" 
                        Width="100" Height="35" Margin="0,0,10,0"/>

                <Button Content="Close" 
                        Style="{StaticResource SecondaryButtonStyle}" 
                        Click="CloseButton_Click" 
                        Width="100" Height="35"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
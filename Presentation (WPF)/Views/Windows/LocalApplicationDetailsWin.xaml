<Window x:Class="Presentation.Views.Windows.LocalApplicationDetailsWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"      
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Presentation.Views.Controls"
        Title="Local Driving License Application Details"
        Height="797" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ثابت -->
        <TextBlock Grid.Row="0"
               Text="Local Driving License Application Details"
               FontSize="26"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"
               Margin="0,0,0,20"/>

        <!-- Scroll لكل المحتوى تحت العنوان -->
        <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

            <StackPanel>

                <controls:DrivingLicenseApplicationInfo
                DrivingLicenseApplicationId="{Binding LdlAppInfo.LocalDrivingLicenseApplicationID}"
                PassedTests="{Binding LdlAppInfo.PassedTest}"
                TotalTests="3"
                LicenseClassName="{Binding LdlAppInfo.LicenseClassName}"/>

                <controls:ApplicationBasicInfo 
                    x:Name="ApplicationBasicInfoControl"
                    Application="{Binding ApplicationInfo}" />
                
                
            </StackPanel>

        </ScrollViewer>

    </Grid>
</Window>
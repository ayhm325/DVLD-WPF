<Window x:Class="Presentation.Views.Windows.DriverLicenseInfoWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Driver License Information"
        Height="650" 
        Width="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundColor}">

    <Window.Resources>
        <!-- ألوان دلالية للحالة والملاحظات -->
        <SolidColorBrush x:Key="DangerColor" Color="#F87171"/>
        <SolidColorBrush x:Key="SuccessColorBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="InactiveColorBrush" Color="#6B7280"/>

        <!-- خلفية للأقسام الفرعية (أفتح قليلاً من الخلفية الرئيسية) -->
        <SolidColorBrush x:Key="SubCardBackground" Color="#1E293B"/>

        <!-- نمط حدود المجموعات الفرعية -->
        <Style x:Key="SubGroupBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- نمط لقيم الحقول -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
        </Style>
    </Window.Resources>

    <!-- الحاوية الرئيسية -->
    <Border Style="{StaticResource CardStyle}" 
            Padding="30"
            Margin="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. الترويسة -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Driver License Details" 
                           Style="{StaticResource HeaderStyle}"
                           Margin="0,0,0,0"/>

                <!-- شارة الـ ID المصممة حديثاً -->
                <Border Grid.Column="1" 
                        Background="{StaticResource CardBackground}" 
                        BorderBrush="{StaticResource PrimaryColor}" 
                        BorderThickness="1" 
                        CornerRadius="20" 
                        Padding="12,6"
                        Margin="10,0,0,0">
                    <TextBlock Foreground="{StaticResource PrimaryColor}" 
                               FontWeight="Bold" 
                               FontSize="13"
                               x:Name="txtLicenseId">
                        <Run Text="ID: "/>
                        <Run Text="{Binding LicenseData.LicenseId}"/>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- 2. المحتوى الرئيسي -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- العمود الأيسر: البيانات -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- قسم المعلومات الشخصية -->
                        <TextBlock Text="Personal Information" 
                                   Foreground="{StaticResource PrimaryColor}" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" 
                                   Margin="0,0,0,8"
                                   Padding="5,0"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LicenseData.FullName}" Style="{StaticResource ValueTextStyle}" FontWeight="SemiBold" x:Name="txtFullName"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="National No:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LicenseData.NationalNo}" Style="{StaticResource ValueTextStyle}" x:Name="txtNationalNo"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Date Of Birth:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicenseData.DateOfBirth, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtDateOfBirth"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Gender:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LicenseData.Gender}" Style="{StaticResource ValueTextStyle}" x:Name="txtGender"/>
                            </Grid>
                        </Border>

                        <!-- قسم تفاصيل الرخصة -->
                        <TextBlock Text="License Details" 
                                   Foreground="{StaticResource PrimaryColor}" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" 
                                   Margin="0,0,0,8"
                                   Padding="5,0"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="License Class:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>

                                <!-- تم التعديل هنا: MinWidth بدلاً من Width و Padding للمسافة -->
                                <Border Grid.Row="0" Grid.Column="1" MinWidth="40" Height="24" CornerRadius="4" Background="#334155" HorizontalAlignment="Left" Margin="0,4,0,10" Padding="8,0">
                                    <TextBlock Text="{Binding LicenseData.LicenseClass}" 
                                               Foreground="White" 
                                               FontWeight="Bold" 
                                               FontSize="12" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"
                                               x:Name="txtLicenseClass"/>
                                </Border>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Issue Date:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LicenseData.IssueDate, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtIssueDate"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Issue Reason:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicenseData.IssueReason}" Style="{StaticResource ValueTextStyle}" x:Name="txtIssueReason"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Expiration Date:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LicenseData.ExpirationDate, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtExpirationDate"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Driver ID:" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LicenseData.DriverId}" Style="{StaticResource ValueTextStyle}" Foreground="{StaticResource SecondaryTextColor}" FontStyle="Italic" x:Name="txtDriverId"/>
                            </Grid>
                        </Border>

                        <!-- قسم الحالة -->
                        <TextBlock Text="Status" 
                                   Foreground="{StaticResource PrimaryColor}" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" 
                                   Margin="0,0,0,8"
                                   Padding="5,0"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <StackPanel>
                                <!-- Active Status -->
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Active Status:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,0,0"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,8">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource InactiveColorBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LicenseData.IsActive}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource SuccessColorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding LicenseData.IsActive}" FontWeight="Bold" Foreground="{StaticResource TextColor}" x:Name="txtIsActive"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Detained Status -->
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Detained Status:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,0,0"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,8">
                                        <TextBlock Text="{Binding LicenseData.IsDetained}" FontWeight="Bold" Foreground="{StaticResource DangerColor}" x:Name="txtIsDetained"/>
                                        <TextBlock Text=" ✕" FontSize="16" Foreground="{StaticResource DangerColor}" Margin="5,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LicenseData.IsDetained}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- قسم الملاحظات -->
                        <TextBlock Text="Notes" 
                                   Foreground="{StaticResource PrimaryColor}" 
                                   FontWeight="SemiBold" 
                                   FontSize="14" 
                                   Margin="0,0,0,8"
                                   Padding="5,0"/>

                        <!-- استخدام نمط Amble المخصص (محافظاً عليه لأنه مناسب للملاحظات) -->
                        <Border Background="#451A03" 
                                BorderBrush="#92400E" 
                                BorderThickness="1" 
                                CornerRadius="6" 
                                Padding="12">
                            <TextBlock Text="{Binding LicenseData.Notes}" 
                                       Foreground="#FCD34D" 
                                       FontSize="13" 
                                       TextWrapping="Wrap" 
                                       FontStyle="Italic"
                                       x:Name="txtNotes"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- العمود الأيمن: الصورة -->
                <Border Grid.Column="2" 
                        Width="180" 
                        Height="240" 
                        CornerRadius="10" 
                        Background="{StaticResource CardBackground}" 
                        BorderBrush="{StaticResource BorderColor}" 
                        BorderThickness="1" 
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center">

                    <Grid>
                        <!-- NO PHOTO Text: يظهر فقط إذا كان المسار Null -->
                        <TextBlock Text="NO PHOTO" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Foreground="{StaticResource SecondaryTextColor}" 
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- الصورة: تختفي إذا كان المسار Null -->
                        <Image Source="{Binding LicenseData.ImagePath}" 
                               Stretch="UniformToFill" 
                               RenderOptions.BitmapScalingMode="HighQuality"
                               x:Name="imgPerson">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                </Border>
            </Grid>

            <!-- 3. زر الإغلاق -->
            <Button Grid.Row="2" 
                    Content="Close" 
                    Width="100" 
                    Margin="0,20,0,0" 
                    HorizontalAlignment="Right" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CloseCommand}"/>

        </Grid>
    </Border>
</Window>
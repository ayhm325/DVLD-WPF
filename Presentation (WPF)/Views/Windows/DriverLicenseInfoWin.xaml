<Window x:Class="Presentation.Views.Windows.DriverLicenseInfoWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Driver License Information"
        Height="700" 
        Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- تدرج الهيدر الموحد -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- ألوان دلالية مطابقة للستايل العام -->
        <SolidColorBrush x:Key="ActiveGreenText" Color="#34D399"/>
        <SolidColorBrush x:Key="InactiveRedText" Color="#F87171"/>
        <SolidColorBrush x:Key="DetainedRedText" Color="#DC2626"/>

        <!-- نمط حدود المجموعات الفرعية -->
        <Style x:Key="SubGroupBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource InputBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- نمط لقيم الحقول -->
        <Style x:Key="ValueTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,10"/>
        </Style>

        <!-- تسمية القسم الفرعي -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="5,0"/>
        </Style>

        <!-- ستايل زر الإغلاق -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="{StaticResource ErrorColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- الحاوية الرئيسية -->
    <Border Background="{StaticResource BackgroundColor}" 
            BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="15">

        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ================= الهيدر الموحد ================= -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                    CornerRadius="16,16,0,0" 
                    Padding="25,18,25,18">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.15"
                                Margin="0,0,14,0"
                                Padding="8"
                                VerticalAlignment="Center">
                            <Path Data="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" 
                                  Stroke="{StaticResource PrimaryColor}" StrokeThickness="1.6" 
                                  Fill="Transparent" Stretch="Uniform" Height="20" Width="20"/>
                        </Border>
                        <TextBlock Text="Driver License Details" 
                                   FontSize="18" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- شارة الـ ID -->
                    <Border Background="#042F2E" 
                            BorderBrush="{StaticResource PrimaryColor}" 
                            BorderThickness="1" 
                            CornerRadius="6" 
                            Padding="12,6"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource PrimaryColor}" 
                                   FontWeight="Bold" FontSize="12" x:Name="txtLicenseId">
                            <Run Text="ID: "/>
                            <Run Text="{Binding LicenseData.LicenseId}"/>
                        </TextBlock>
                    </Border>

                    
                </Grid>
            </Border>

            <!-- ================= المحتوى الرئيسي ================= -->
            <Grid Grid.Row="1" Margin="20,15,20,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- العمود الأيسر: البيانات -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- قسم المعلومات الشخصية -->
                        <TextBlock Text="Personal Information" Style="{StaticResource SectionTitleStyle}"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LicenseData.FullName}" Style="{StaticResource ValueTextStyle}" FontWeight="SemiBold" x:Name="txtFullName"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="National No" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LicenseData.NationalNo}" Style="{StaticResource ValueTextStyle}" x:Name="txtNationalNo"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Date Of Birth" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicenseData.DateOfBirth, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtDateOfBirth"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Gender" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LicenseData.Gender}" Style="{StaticResource ValueTextStyle}" x:Name="txtGender"/>
                            </Grid>
                        </Border>

                        <!-- قسم تفاصيل الرخصة -->
                        <TextBlock Text="License Details" Style="{StaticResource SectionTitleStyle}"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="License Class" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>

                                <!-- شارة فئة الرخصة بأسلوب Teal -->
                                <Border Grid.Row="0" Grid.Column="1" 
                                        MinWidth="40" Height="24" CornerRadius="6" 
                                        Background="#042F2E" 
                                        BorderBrush="{StaticResource PrimaryColor}" 
                                        BorderThickness="1"
                                        HorizontalAlignment="Left" Margin="0,4,0,10" Padding="8,0">
                                    <TextBlock Text="{Binding LicenseData.LicenseClass}" 
                                               Foreground="{StaticResource PrimaryColor}" 
                                               FontWeight="Bold" FontSize="12" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               x:Name="txtLicenseClass"/>
                                </Border>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Issue Date" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LicenseData.IssueDate, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtIssueDate"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Issue Reason" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LicenseData.IssueReason}" Style="{StaticResource ValueTextStyle}" x:Name="txtIssueReason"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Expiration Date" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LicenseData.ExpirationDate, StringFormat='{}{0:dd/MMM/yyyy}'}" Style="{StaticResource ValueTextStyle}" x:Name="txtExpirationDate"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Driver ID" Style="{StaticResource LabelStyle}" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LicenseData.DriverId}" 
                                           Style="{StaticResource ValueTextStyle}" 
                                           Foreground="{StaticResource SecondaryTextColor}" 
                                           FontStyle="Italic" x:Name="txtDriverId"/>
                            </Grid>
                        </Border>

                        <!-- قسم الحالة -->
                        <TextBlock Text="Status" Style="{StaticResource SectionTitleStyle}"/>

                        <Border Style="{StaticResource SubGroupBorderStyle}">
                            <StackPanel>
                                <!-- Active Status -->
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Active Status" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,0,0"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,8">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource SecondaryTextColor}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LicenseData.IsActive}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource ActiveGreenText}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding LicenseData.IsActive}" FontWeight="Bold" Foreground="{StaticResource TextColor}" x:Name="txtIsActive"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Detained Status -->
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Detained Status" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,0,0"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,8">
                                        <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{StaticResource ActiveGreenText}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LicenseData.IsDetained}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource DetainedRedText}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding LicenseData.IsDetained}" FontWeight="Bold" x:Name="txtIsDetained">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource ActiveGreenText}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LicenseData.IsDetained}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource DetainedRedText}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- قسم الملاحظات -->
                        <TextBlock Text="Notes" Style="{StaticResource SectionTitleStyle}"/>

                        <!-- خلفية Teal داكنة للملاحظات (بدلاً من البرتقالي) -->
                        <Border Background="#042F2E" 
                                BorderBrush="{StaticResource PrimaryColor}" 
                                BorderThickness="1" 
                                CornerRadius="10" 
                                Padding="12">
                            <TextBlock Text="{Binding LicenseData.Notes}" 
                                       Foreground="{StaticResource TextColor}" 
                                       FontSize="13" 
                                       TextWrapping="Wrap" 
                                       FontStyle="Italic"
                                       x:Name="txtNotes"/>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ================= العمود الأيمن: الصورة ================= -->
                <Border Grid.Column="2" 
                        Width="180" 
                        Height="240" 
                        CornerRadius="12" 
                        Background="{StaticResource InputBackground}" 
                        BorderBrush="{StaticResource PrimaryColor}" 
                        BorderThickness="2" 
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center">

                    <Grid>
                        <TextBlock Text="NO PHOTO" 
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" 
                                   Foreground="{StaticResource SecondaryTextColor}" 
                                   FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Image Source="{Binding LicenseData.ImagePath}" 
                               Stretch="UniformToFill" 
                               RenderOptions.BitmapScalingMode="HighQuality"
                               x:Name="imgPerson">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding LicenseData.ImagePath}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Grid>
                </Border>
            </Grid>

            <!-- ================= شريط الأزرار السفلي ================= -->
            <Border Grid.Row="2" Background="{StaticResource BackgroundColor}" 
                    Padding="20,15,25,20" 
                    CornerRadius="0,0,16,16"
                    Margin="-1,0,-1,-1">
                <Button Content="Close" 
                        Width="120" 
                        HorizontalAlignment="Right" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CloseCommand}"/>
            </Border>

        </Grid>
    </Border>
</Window>
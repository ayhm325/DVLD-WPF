<Window x:Class="Presentation.Views.Windows.LicenseHistoryWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Presentation.Views.Controls"
        mc:Ignorable="d"
        Title="License History" 
        Height="600" Width="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- تدرج الهيدر الموحد -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- ستايل زر الإغلاق -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="{StaticResource ErrorColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== DataGrid ===== -->
        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#111114"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ===== Column Header ===== -->
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0E0E10"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <!-- ===== Cell ===== -->
        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#042F2E"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== Row (Hover) ===== -->
        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#1A1A1E"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- ===== نصوص الأعمدة ===== -->
        <Style x:Key="ColumnTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style x:Key="ColumnTextBoldStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style x:Key="ColumnTextLeftStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <!-- ===== قالب عمود "هل نشط" (مطابق لألوان الحالة العامة) ===== -->
        <DataTemplate x:Key="IsActiveTemplate">
            <Border x:Name="PillBorder"
                    Background="#064E3B"
                    CornerRadius="6"
                    Padding="10,4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot" 
                             Width="7" Height="7"
                             Fill="#34D399"
                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText" 
                               Text="Active" 
                               FontSize="11" 
                               FontWeight="SemiBold"
                               Foreground="#34D399"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="False">
                    <Setter TargetName="PillBorder" Property="Background" Value="#7F1D1D"/>
                    <Setter TargetName="Dot" Property="Fill" Value="#F87171"/>
                    <Setter TargetName="StatusText" Property="Text" Value="Inactive"/>
                    <Setter TargetName="StatusText" Property="Foreground" Value="#F87171"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

    </Window.Resources>

    <!-- الحاوية الرئيسية -->
    <Border Background="{StaticResource BackgroundColor}" 
            BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="15">

        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Scrollable Content -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- ================= الهيدر الموحد ================= -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                    CornerRadius="16,16,0,0" 
                    Padding="25,18,25,18">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.15"
                                Margin="0,0,14,0"
                                Padding="8"
                                VerticalAlignment="Center">
                            <Path Data="M13,3A9,9 0 0,0 22,12A9,9 0 0,0 13,3M13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19M12,8V12L15.28,13.94L16.05,12.66L13,10.8V8H12Z" 
                                  Stroke="{StaticResource PrimaryColor}" StrokeThickness="1.6" 
                                  Fill="Transparent" Stretch="Uniform" Height="20" Width="20"/>
                        </Border>
                        <TextBlock Text="License History" 
                                   FontSize="18" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                   
                </Grid>
            </Border>

            <!-- ================= المحتوى ================= -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="20,15,20,20">

                <StackPanel>

                    <!-- اليوزر كنترول (بدون بطاقة خارجية لتفادي تكرار البطاقات) -->
                    <controls:InformationPerson x:Name="ucPersonInfo" Margin="0,0,0,15"/>

                    <!-- التابات + الداتا قريد -->
                    <Border Style="{StaticResource CardStyle}"
                            Padding="0"
                            ClipToBounds="True"
                            MinHeight="280">

                        <TabControl Background="Transparent"
                                    BorderThickness="0">

                            <!-- ===== تاب الرخص المحلية ===== -->
                            <TabItem Header="Local Licenses History" 
                                     Style="{StaticResource TabItemStyle}">

                                <DataGrid x:Name="dgLocalLicenses"
                                          Style="{StaticResource DataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                                          CellStyle="{StaticResource CellStyle}"
                                          RowStyle="{StaticResource RowStyle}"
                                          ItemsSource="{Binding LocalLicenses}"
                                          Margin="8,8,8,12">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Lic.ID"
                                                            Binding="{Binding LicenseID}"
                                                            Width="70"
                                                            ElementStyle="{StaticResource ColumnTextBoldStyle}"/>

                                        <DataGridTextColumn Header="App.ID"
                                                            Binding="{Binding ApplicationID}"
                                                            Width="70"
                                                            ElementStyle="{StaticResource ColumnTextStyle}"/>

                                        <DataGridTextColumn Header="Class Name"
                                                            Binding="{Binding LicenseClassName}"
                                                            Width="*"
                                                            ElementStyle="{StaticResource ColumnTextLeftStyle}"/>

                                        <DataGridTextColumn Header="Issue Date"
                                                            Binding="{Binding IssueDate, StringFormat='yyyy/M/d'}"
                                                            Width="115"
                                                            ElementStyle="{StaticResource ColumnTextStyle}"/>

                                        <DataGridTextColumn Header="Expiration Date"
                                                            Binding="{Binding ExpirationDate, StringFormat='yyyy/M/d'}"
                                                            Width="115"
                                                            ElementStyle="{StaticResource ColumnTextStyle}"/>

                                        <DataGridTemplateColumn Header="Status"
                                                                Width="95"
                                                                CellTemplate="{StaticResource IsActiveTemplate}"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                            </TabItem>

                            <!-- ===== تاب الرخص الدولية ===== -->
                            <TabItem Header="International Licenses History" 
                                     Style="{StaticResource TabItemStyle}">

                                <DataGrid x:Name="dgInternationalLicenses"
                                          Style="{StaticResource DataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                                          CellStyle="{StaticResource CellStyle}"
                                          RowStyle="{StaticResource RowStyle}"
                                          ItemsSource="{Binding InternationalLicenses}"
                                          Margin="8,8,8,12">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Int.Lic.ID"
                                                            Binding="{Binding InternationalLicenseID}"
                                                            Width="90"
                                                            ElementStyle="{StaticResource ColumnTextBoldStyle}"/>

                                        <DataGridTextColumn Header="App.ID"
                                                            Binding="{Binding ApplicationID}"
                                                            Width="80"
                                                            ElementStyle="{StaticResource ColumnTextStyle}"/>

                                        <DataGridTextColumn Header="L.Lic.ID"
                                                            Binding="{Binding LicenseID}"
                                                            Width="80"
                                                            ElementStyle="{StaticResource ColumnTextStyle}"/>

                                        <DataGridTextColumn Header="Issue Date"
                                                            Binding="{Binding IssueDate, StringFormat='yyyy/M/d'}"
                                                            Width="115"
                                                            ElementStyle="{StaticResource ColumnTextStyle}"/>

                                        <DataGridTextColumn Header="Expiration Date"
                                                            Binding="{Binding ExpirationDate, StringFormat='yyyy/M/d'}"
                                                            Width="115"
                                                            ElementStyle="{StaticResource ColumnTextStyle}"/>

                                        <DataGridTemplateColumn Header="Status"
                                                                Width="95"
                                                                CellTemplate="{StaticResource IsActiveTemplate}"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                            </TabItem>

                        </TabControl>

                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- ================= شريط الأزرار السفلي ================= -->
            <Border Grid.Row="2" Background="{StaticResource BackgroundColor}" 
                    Padding="20,15,25,20" 
                    CornerRadius="0,0,16,16"
                    Margin="-1,0,-1,-1">
                <Button x:Name="btnClose"
                        Content="Close" 
                        Width="120" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Right"
                        Click="btnClose_Click"/>
            </Border>

        </Grid>
    </Border>
</Window>
<Window x:Class="Presentation.Views.Windows.AddEditUserWin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Presentation.Views.Controls"
      xmlns:helpers="clr-namespace:Presentation.Helpers"
      mc:Ignorable="d"
      Title="Add/Edit User"
      WindowStartupLocation="CenterScreen"     
      Background="Transparent"
      ResizeMode="NoResize"
      Height="750"
      Width="950">

    <Window.Resources>
        <!-- تدرج الهيدر الموحد -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- لون أخضر زمردي للزر (Accent) مع متغيرات -->
        <SolidColorBrush x:Key="AccentColor" Color="#10B981"/>
        <SolidColorBrush x:Key="AccentHoverColor" Color="#34D399"/>

        <!-- ستايل زر الإغلاق -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter Property="Foreground" Value="{StaticResource ErrorColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ستايل زر الحفظ (Accent Emerald) بقالب مستقل -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="0.5" CenterY="0.5"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ستايل زر إظهار/إخفاء كلمة المرور -->
        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="0,8,8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A1A1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- عدّل ستايل NextButtonStyle -->
        <Style x:Key="NextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        CornerRadius="10" 
                        Padding="18,0"
                        Opacity="{TemplateBinding Opacity}">
                            <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center">
                                <!-- أضف Foreground="{TemplateBinding Foreground}" هنا -->
                                <TextBlock Text="Next" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock Text="&#x276F;" FontSize="16" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="Opacity" Value="0.6"/>
                                <Setter Property="Cursor" Value="No"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- الحاوية الرئيسية -->
    <Border Background="{StaticResource BackgroundColor}" 
            BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="1" 
            CornerRadius="16" 
            Margin="15">

        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="30" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Tabs Content -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- ================= الهيدر الموحد ================= -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                    CornerRadius="16,16,0,0" 
                    Padding="25,18,25,18">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.15"
                                Margin="0,0,14,0"
                                Padding="8"
                                VerticalAlignment="Center">
                            <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                                  Stroke="{StaticResource PrimaryColor}" StrokeThickness="1.6" 
                                  Fill="Transparent" Stretch="Uniform" Height="20" Width="20"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="User Information Details"
                                       FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextColor}"/>
                            <TextBlock Text="Review or update the user profile details below"
                                       FontSize="12" Foreground="{StaticResource SecondaryTextColor}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>


                </Grid>
            </Border>

            <!-- ================= المحتوى (تبويبات) ================= -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="20,15,20,20">

                <TabControl x:Name="MainTabControl" Background="Transparent" 
                            BorderThickness="0"
                            SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

                    <!-- Tab 1: Personal & Filter -->
                    <TabItem Header="Personal &amp; Filter" 
                             Style="{StaticResource TabItemStyle}" 
                             FontSize="14">

                        <StackPanel>
                            <controls:Filter Margin="0,0,0,15"/>
                            <controls:InformationPerson Person="{Binding Person}" />

                            <!-- زر Next -->
                            <Grid Margin="0,20,0,0">
                                <Button Style="{StaticResource NextButtonStyle}"
                                        HorizontalAlignment="Right"
                                        Command="{Binding GoToNextTabCommand}"/>
                            </Grid>
                        </StackPanel>

                    </TabItem>

                    <!-- Tab 2: Login Information -->
                    <TabItem Header="Login Information" 
                             Style="{StaticResource TabItemStyle}" 
                             FontSize="14" IsEnabled="{Binding CanGoToNextTab}">

                        <Border Style="{StaticResource CardStyle}" Padding="25">
                            <StackPanel>

                                <TextBlock Text="Login Information"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource PrimaryColor}"
                                           Margin="0,0,0,20"/>

                                <Grid>
                                    <Grid.Resources>
                                        <!-- تنسيق التسميات -->
                                        <Style TargetType="Label">
                                            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </Grid.Resources>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- User ID -->
                                    <Label Content="User ID:" Grid.Row="0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding UserIdDisplay, TargetNullValue='???'}"
                                               VerticalAlignment="Center"
                                               Margin="10,0"
                                               Foreground="{StaticResource SecondaryTextColor}"/>

                                    <!-- User Name -->
                                    <Label Grid.Row="1" Content="User Name:"/>
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Width="300" Margin="0,5"
                                             HorizontalAlignment="Left"
                                             Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <!-- Validation Message -->
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{Binding UserNameValidationMessage}"
                                               Foreground="{Binding UserNameValidationColor}"
                                               FontSize="11"
                                               Margin="10,0,0,5"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top"
                                               TextWrapping="Wrap"/>

                                    <!-- Password -->
                                    <Label Grid.Row="3" Content="Password:"
                                           Visibility="{Binding PasswordVisibility}" />

                                    <Grid Grid.Row="3" Grid.Column="1"
                                          Width="300" Margin="0,5"
                                          HorizontalAlignment="Left"
                                          Visibility="{Binding PasswordVisibility}">

                                        <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                                     helpers:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay}"
                                                     Padding="10,0,30,0">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>

                                        <TextBox Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,0,30,0" VerticalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPasswordVisible}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <Button Style="{StaticResource EyeButtonStyle}"
                                                HorizontalAlignment="Right"
                                                Command="{Binding TogglePasswordVisibilityCommand}">
                                            <TextBlock Text="👁️" FontSize="14" 
                                                       Foreground="{StaticResource PrimaryColor}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>

                                    </Grid>

                                    <!-- Confirm Password -->
                                    <Label Grid.Row="4" Content="Confirm Password:"
                                           Visibility="{Binding ConfirmPasswordVisibility}" />

                                    <Grid Grid.Row="4" Grid.Column="1"
                                          Width="300" Margin="0,5"
                                          HorizontalAlignment="Left"
                                          Visibility="{Binding ConfirmPasswordVisibility}">

                                        <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                                     helpers:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay}"
                                                     Padding="10,0,30,0">
                                            <PasswordBox.Style>
                                                <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConfirmPasswordVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </PasswordBox.Style>
                                        </PasswordBox>

                                        <TextBox Text="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="10,0,30,0" VerticalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsConfirmPasswordVisible}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <Button Style="{StaticResource EyeButtonStyle}"
                                                HorizontalAlignment="Right"
                                                Command="{Binding ToggleConfirmPasswordVisibilityCommand}">
                                            <TextBlock Text="👁️" FontSize="14" 
                                                       Foreground="{StaticResource PrimaryColor}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Button>

                                    </Grid>

                                    <!-- Active -->
                                    <CheckBox Grid.Row="5" Grid.Column="1"
                                              Content="Is Active"
                                              IsChecked="{Binding IsActive}"
                                              Margin="0,10,0,0"/>

                                </Grid>

                            </StackPanel>
                        </Border>

                    </TabItem>
                </TabControl>

            </ScrollViewer>

            <!-- ================= شريط الأزرار السفلي ================= -->
            <Border Grid.Row="2" Background="{StaticResource BackgroundColor}" 
                    Padding="20,15,25,20" 
                    CornerRadius="0,0,16,16"
                    Margin="-1,0,-1,-1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Button Content="Close" 
                            Style="{StaticResource SecondaryButtonStyle}" 
                            Click="CloseButton_Click" 
                            Width="120"
                            Margin="0,0,15,0"/>

                    <Button Content="Save"
                            Style="{StaticResource AccentButtonStyle}"
                            Width="120"
                            Command="{Binding SaveUserCommand}" />

                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
<UserControl x:Class="Presentation.Views.Controls.PersonInfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>

        <!-- تظبيط الأنماط لترث من القاموس العام ولكن مع إضافة منطق الأخطاء -->

        <!-- Label Style: استخدام SecondaryColor من النظام -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ErrorMessage Style -->
        <Style TargetType="TextBlock" x:Key="ErrorMessageStyle">
            <Setter Property="Foreground" Value="#E53E3E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="2,4,0,0"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
                <Trigger Property="Text" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style: يرث النمط العام ويضيف تأثيرات التحقق -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#E53E3E"/>
                    <Setter Property="Background" Value="#FFF5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox Style: يرث النمط العام ويضيف تأثيرات التحقق -->
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="#E53E3E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DatePicker Style: تنسيق بسيط ليتماشى مع النظام -->
        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Danger Button Style للحذف (محلي) -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Foreground" Value="#E53E3E"/>
            <Setter Property="BorderBrush" Value="#E53E3E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FEF2F2"/>
                    <Setter Property="BorderBrush" Value="#C53030"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <!-- تطبيق CardStyle على الحاوية الرئيسية -->
    <Border Style="{StaticResource CardStyle}" Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- العنوان: استخدام HeaderStyle -->
            <TextBlock Text="Person Details" 
                       Style="{StaticResource HeaderStyle}" 
                       Foreground="{StaticResource PrimaryColor}" 
                       Margin="0,0,0,20"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- First Name -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="First Name *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtFirstName" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TxtFirstName}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Second Name -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Second Name *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtSecondName" Text="{Binding SecondName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TxtSecondName}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Third Name -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="Third Name (Optional)" Style="{StaticResource LabelStyle}"/>
                    <TextBox Text="{Binding ThirdName, UpdateSourceTrigger=PropertyChanged,TargetNullValue=''}" />
                </StackPanel>

                <!-- Last Name -->
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Last Name *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtLastName" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TxtLastName}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- National No -->
                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="National Number *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtNationalNo" Text="{Binding NationalNo, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TxtNationalNo}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Phone -->
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Phone Number *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtPhone" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TxtPhone}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="Email Address (Optional)" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtEmail" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TxtEmail}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Address -->
                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Physical Address *" Style="{StaticResource LabelStyle}"/>
                    <TextBox x:Name="TxtAddress" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=TxtAddress}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Date Of Birth -->
                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="Date Of Birth *" Style="{StaticResource LabelStyle}"/>
                    <DatePicker x:Name="DtpDateOfBirth" 
                                SelectedDate="{Binding DateOfBirth, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" 
                                DisplayDateEnd="{Binding MaxBirthDate, Mode=OneWay}" />
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=DtpDateOfBirth}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Gender -->
                <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Gender *" Style="{StaticResource LabelStyle}"/>
                    <StackPanel Orientation="Horizontal" Height="38" VerticalAlignment="Center">
                        <RadioButton Content="Male" 
                                     GroupName="GenderGroup"
                                     IsChecked="{Binding IsMale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,25,0" 
                                     FontSize="14" 
                                     Foreground="{StaticResource TextColor}"
                                     VerticalContentAlignment="Center" 
                                     Cursor="Hand"/>

                        <RadioButton Content="Female" 
                                     GroupName="GenderGroup"
                                     IsChecked="{Binding IsFemale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                     FontSize="14" 
                                     Foreground="{StaticResource TextColor}"
                                     VerticalContentAlignment="Center" 
                                     Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>

                <!-- Country -->
                <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="Country *" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="CboCountry" 
                              ItemsSource="{Binding Countries}" 
                              SelectedItem="{Binding SelectedCountry, ValidatesOnNotifyDataErrors=True, NotifyOnValidationError=True}" 
                              DisplayMemberPath="CountryName"/>
                    <TextBlock Text="{Binding (Validation.Errors)/ErrorContent, ElementName=CboCountry}" Style="{StaticResource ErrorMessageStyle}"/>
                </StackPanel>

                <!-- Profile Photo -->
                <StackPanel Grid.Row="5" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Profile Photo (Optional)" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- صورة العرض باستخدام ألوان النظام -->
                        <Border Width="120" Height="120" 
                                CornerRadius="8" 
                                BorderBrush="{StaticResource BorderColor}" 
                                BorderThickness="1" 
                                Background="{StaticResource BackgroundColor}" 
                                Grid.Column="0">
                            <Image Source="{Binding ImageDisplayPath}" Stretch="UniformToFill" Margin="2" ToolTip="User Image"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                            <!-- زر اختيار الصورة باستخدام PrimaryButtonStyle -->
                            <Button Content="Choose Image" 
                                    Height="38" Width="130" 
                                    HorizontalAlignment="Left" 
                                    Command="{Binding ChooseImageCommand}" 
                                    Style="{StaticResource PrimaryButtonStyle}"/>

                            <!-- زر الحذف باستخدام DangerButtonStyle -->
                            <Button Content="Remove" 
                                    Height="38" Width="130" 
                                    HorizontalAlignment="Left" 
                                    Command="{Binding RemoveImageCommand}" 
                                    Margin="0,10,0,0" 
                                    Style="{StaticResource DangerButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
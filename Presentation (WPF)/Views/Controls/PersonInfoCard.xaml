<UserControl x:Class="Presentation.Views.Controls.PersonInfoCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            CornerRadius="12"
            Padding="20"
            BorderBrush="#E0E0E0"
            BorderThickness="1">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <TextBlock Text="Person Information"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <!-- CONTENT -->
            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- FIRST NAME -->
                <StackPanel Grid.Row="0" Margin="5">
                    <TextBlock Text="First Name"/>
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- SECOND NAME -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="5">
                    <TextBlock Text="Second Name"/>
                    <TextBox Text="{Binding SecondName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- THIRD NAME -->
                <StackPanel Grid.Row="1" Margin="5">
                    <TextBlock Text="Third Name"/>
                    <TextBox Text="{Binding ThirdName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- LAST NAME -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="5">
                    <TextBlock Text="Last Name"/>
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- NATIONAL NO -->
                <StackPanel Grid.Row="2" Margin="5">
                    <TextBlock Text="National Number"/>
                    <TextBox Text="{Binding NationalNo, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- PHONE -->
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="5">
                    <TextBlock Text="Phone"/>
                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- EMAIL -->
                <StackPanel Grid.Row="3" Margin="5">
                    <TextBlock Text="Email"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- ADDRESS -->
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="5">
                    <TextBlock Text="Address"/>
                    <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- DATE OF BIRTH -->
                <StackPanel Grid.Row="4" Margin="5">
                    <TextBlock Text="Birth Date"/>
                    <DatePicker SelectedDate="{Binding DateOfBirth, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- GENDER -->
                <StackPanel Grid.Row="4" Grid.Column="1" Margin="5">
                    <TextBlock Text="Gender"/>
                    <TextBox Text="{Binding Gender, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- COUNTRY -->
                <StackPanel Grid.Row="5" Margin="5">
                    <TextBlock Text="Country"/>
                    <ComboBox ItemsSource="{Binding Countries}"
                              SelectedItem="{Binding SelectedCountry}"
                              DisplayMemberPath="CountryName"
                              Height="30"/>
                </StackPanel>

                <!-- IMAGE -->
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="5">
                    <TextBlock Text="Photo"/>

                    <Image Source="{Binding ImagePath}"
                           Height="80"
                           Margin="0,5"/>

                    <Button Content="Choose Image"
                            Height="30"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
<UserControl x:Class="Presentation.Views.Controls.Filter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignWidth="800">

    <!-- تم تطبيق CardStyle. تم إزالة CornerRadius لأنه موجود داخل الستايل -->
    <Border Style="{StaticResource CardStyle}" Padding="15">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- استخدام TextColor بدلاً من اللون الافتراضي -->
            <TextBlock Grid.Column="0" Text="Filter:" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource TextColor}"
                       VerticalAlignment="Center" Margin="0,0,15,0"/>

            <TextBlock Grid.Column="1" Text="Find By:" 
                       Foreground="{StaticResource TextColor}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>

            <!-- ComboBox: الستايل المضمن يهتم بالخلفية والحدود -->
            <ComboBox Grid.Column="2" 
                      SelectedIndex="{Binding SelectedFilterIndex}" 
                      Width="140" 
                      Margin="0,0,10,0"
                      VerticalAlignment="Center">
                <ComboBoxItem Content="Person ID"/>
                <ComboBoxItem Content="National No"/>
            </ComboBox>

            <!-- TextBox: الستايل المضمن يهتم بالخلفية والحدود والارتفاع -->
            <TextBox Grid.Column="3" 
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,10,0" 
                     VerticalAlignment="Center"/>

            <!-- PrimaryButtonStyle يحدد الارتفاع تلقائياً (40) -->
            <Button Grid.Column="4" 
                    Content="Search" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Width="90" 
                    Margin="0,0,5,0" 
                    Command="{Binding SearchCommand}"
                    VerticalAlignment="Center"/>

            <!-- الزر هنا يستخدم PrimaryButtonStyle مع تغيير اللون محلياً إلى OliveDrab -->
            <Button Grid.Column="5" 
                    Content="+ Add Person" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Width="110" 
                    Background="OliveDrab" 
                    Command="{Binding AddPersonCommand}"
                    VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
<UserControl x:Class="Presentation.Views.Controls.Filter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="800">

    <Border Style="{StaticResource CardStyle}" Padding="15" CornerRadius="12">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

            <TextBlock Text="Filter:" FontSize="16" FontWeight="Bold" 
                       Foreground="{StaticResource TextColor}" 
                       VerticalAlignment="Center" Margin="0,0,15,0"/>

            <TextBlock Text="Find By:" VerticalAlignment="Center" Margin="0,0,10,0"/>

            <Border CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" 
                    Background="White" Margin="0,0,10,0" Height="38" Width="160">
                <ComboBox SelectedIndex="{Binding SelectedFilterIndex}" 
                          Background="Transparent" BorderThickness="0" 
                          VerticalContentAlignment="Center" Padding="10,0" FontSize="14">
                    <ComboBoxItem Content="Person ID"/>
                    <ComboBoxItem Content="National No"/>
                </ComboBox>
            </Border>

            <Border CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" 
                    Background="White" Margin="0,0,10,0" Height="38" Width="250">
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                         Background="Transparent" BorderThickness="0" 
                         VerticalContentAlignment="Center" Padding="10,0" FontSize="14"/>
            </Border>

            <Button Content="Search" Style="{StaticResource PrimaryButtonStyle}" 
                    Width="100" Height="38" Margin="0,0,5,0" 
                    Command="{Binding SearchCommand}"/>

            <Button Content="+ Add Person" Style="{StaticResource PrimaryButtonStyle}" 
                    Width="130" Height="38" Background="OliveDrab" 
                    Command="{Binding AddPersonCommand}" ToolTip="Add New Person"
                    FontSize="14" FontWeight="Bold" Padding="10,0"/>

        </StackPanel>
    </Border>
</UserControl>
<UserControl x:Class="Presentation.Views.Controls.Filter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- تعريف لون إضافي محلي لزر الإضافة (Accent Color) -->
        <SolidColorBrush x:Key="AccentGreen" Color="#10B981"/>
    </UserControl.Resources>

    <!-- استخدام CardStyle مع زيادة بسيطة في Padding -->
    <Border Style="{StaticResource CardStyle}" Padding="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- العنوان الرئيسي -->
            <TextBlock Grid.Column="0" Text="Filter:" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource TextColor}"
                       VerticalAlignment="Center" Margin="0,0,20,0"/>

            <!-- تسمية الحقل (استخدمنا اللون الثانوي للتمييز) -->
            <TextBlock Grid.Column="1" Text="Find By:" 
                       Foreground="{StaticResource SecondaryTextColor}"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>

            <!-- ComboBox: تم زيادة العرض قليلاً لضمان ظهور النصوص -->
            <ComboBox Grid.Column="2" 
                      SelectedIndex="{Binding SelectedFilterIndex}" 
                      Width="150" 
                      Margin="0,0,15,0"
                      VerticalAlignment="Center">
                <ComboBoxItem Content="Person ID"/>
                <ComboBoxItem Content="National No"/>
            </ComboBox>

            <!-- TextBox: سيأخذ الستايل العام تلقائياً -->
            <TextBox Grid.Column="3" 
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,0,15,0" 
                     VerticalAlignment="Center"/>

            <!-- زر البحث (Primary Style) -->
            <Button Grid.Column="4" 
                    Content="Search" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Width="100" 
                    Margin="0,0,10,0" 
                    Command="{Binding SearchCommand}"
                    VerticalAlignment="Center"/>

            <!-- زر الإضافة (باستخدام PrimaryButtonStyle مع تغيير اللون للأخضر الزمردي) -->
            <Button Grid.Column="5" 
                    Content="+ Add Person" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Width="130" 
                    Background="{StaticResource AccentGreen}" 
                    Command="{Binding AddPersonCommand}"
                    VerticalAlignment="Center"/>
        </Grid>
    </Border>
</UserControl>
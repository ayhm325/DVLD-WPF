<UserControl x:Class="Presentation.Views.Controls.ApplicationBasicInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Name="Root"
             HorizontalContentAlignment="Stretch">

    <UserControl.Resources>
        <!-- تدرج خفيف للهيدر يطابق النمط العام -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- نمط تسمية الحقل – يرث من الستايل العام مع تعديل الحجم -->
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- نمط قيمة الحقل -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <!-- استخدام ستايل البطاقة العام (CardStyle) -->
    <Border Style="{StaticResource CardStyle}" Padding="25" Margin="20,10,20,20" HorizontalAlignment="Stretch">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════ HEADER ═══════════════ -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                    CornerRadius="12" Padding="18,14,18,14" Margin="-25,-25,-25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- أيقونة بنمط المربّع المستدير الموحد (مصمتة وواضحة) -->
                        <Border Width="38" Height="38" CornerRadius="10" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.25"
                                VerticalAlignment="Center" Margin="0,0,14,0"
                                Padding="8">
                            <materialDesign:PackIcon Kind="Information" 
                                                    Foreground="White" 
                                                    Width="22" Height="22" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Application Basic Info" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- استخدام الزر الأساسي من الستايل العام -->
                    <Button Grid.Column="1" 
                            VerticalAlignment="Center"
                            Content="Person Info" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="PersonInfoButton_Click"
                            Tag="{Binding Application, ElementName=Root}"/>
                </Grid>
            </Border>

            <!-- فاصل بلون الحدود العام -->
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="0,0,0,20" Background="{StaticResource BorderColor}"/>

            <!-- ═══════════════ DATA GRID ═══════════════ -->
            <Grid Grid.Row="1" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ═══ Row 0: ID | Date | StatusDate | Fees ═══ -->
                <StackPanel Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="ID" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Application.ApplicationID, ElementName=Root}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,0,15">
                    <TextBlock Text="DATE" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Application.ApplicationDate, ElementName=Root, StringFormat='{}{0:dd/MM/yyyy}'}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="STATUS DATE" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Application.LastStatusDate, ElementName=Root, StringFormat='{}{0:dd/MM/yyyy}'}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,0,15">
                    <TextBlock Text="FEES" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Application.PaidFees, ElementName=Root}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

                <!-- ═══ Row 1: Type | Status ═══ -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,5,0,15">
                    <TextBlock Text="TYPE" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Application.ApplicationTypeName, ElementName=Root}" 
                               Style="{StaticResource FieldValue}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Grid.Row="1" Margin="0,5,0,15" HorizontalAlignment="Left">
                    <TextBlock Text="STATUS" Style="{StaticResource FieldLabel}"/>
                    <Border Background="#042F2E" CornerRadius="6" Padding="10,4" Margin="0,4,0,0" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Application.StatusText, ElementName=Root}" 
                                   FontWeight="SemiBold" FontSize="13" 
                                   Foreground="{StaticResource PrimaryColor}"/>
                    </Border>
                </StackPanel>

                <!-- ═══ Row 2: Applicant | Created By ═══ -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Margin="0,5,0,0">
                    <TextBlock Text="APPLICANT" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Application.ApplicantFullName, ElementName=Root}" 
                               Style="{StaticResource FieldValue}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Grid.Row="2" Margin="0,5,0,0" HorizontalAlignment="Left">
                    <TextBlock Text="CREATED BY" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Application.CreatedByUserName, ElementName=Root}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
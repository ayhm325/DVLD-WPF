<UserControl x:Class="Presentation.Views.Controls.ApplicationBasicInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             x:Name="Root"
             HorizontalContentAlignment="Stretch"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="Auto">

    <!-- تمت إزالة Resources المحلية للاعتماد على الستايل العام في App.xaml -->

    <!-- استخدام ستايل البطاقة العام (CardStyle) -->
    <Border Style="{StaticResource CardStyle}" Padding="25" Margin="20,10,20,20" HorizontalAlignment="Stretch">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Row -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- أيقونة مع خلفية داكنة -->
                    <Border Width="40" Height="40" CornerRadius="20" 
                            Background="{StaticResource InputBackground}" 
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <materialDesign:PackIcon Kind="InformationOutline" 
                                                Foreground="{StaticResource PrimaryColor}" 
                                                Width="22" Height="22" 
                                                VerticalAlignment="Center" 
                                                HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Application Basic Info" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                        <!-- خط ملون تحت العنوان -->
                        <Border Height="3" Width="40" Margin="0,6,0,0" 
                                Background="{StaticResource PrimaryColor}" 
                                CornerRadius="2" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>

                <!-- استخدام الزر الأساسي من الستايل العام -->
                <Button Grid.Column="1" 
                        VerticalAlignment="Center"
                        Content="Person Info" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="PersonInfoButton_Click"
                        Tag="{Binding Application, ElementName=Root}"/>
            </Grid>

            <!-- فاصل بلون الحدود العام -->
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="0,0,0,20" Background="{StaticResource BorderColor}"/>

            <!-- Data Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: ID | Date | StatusDate | Fees -->
                <StackPanel Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="ID" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.ApplicationID, ElementName=Root}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextColor}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,0,15">
                    <TextBlock Text="DATE" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.ApplicationDate, ElementName=Root, StringFormat='{}{0:dd/MM/yyyy}'}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextColor}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="STATUS DATE" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.LastStatusDate, ElementName=Root, StringFormat='{}{0:dd/MM/yyyy}'}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextColor}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,0,15">
                    <TextBlock Text="FEES" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.PaidFees, ElementName=Root}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextColor}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Row 1: Type | Status -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,5,0,15">
                    <TextBlock Text="TYPE" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.ApplicationTypeName, ElementName=Root}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextColor}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Grid.Row="1" Margin="0,5,0,15" HorizontalAlignment="Left">
                    <TextBlock Text="STATUS" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.StatusText, ElementName=Root}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource PrimaryColor}" Margin="0,4,0,0"/>
                    <!-- لون الحالة باللون الأساسي -->
                </StackPanel>

                <!-- Row 2: Applicant | Created By -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2" Margin="0,5,0,0">
                    <TextBlock Text="APPLICANT" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.ApplicantFullName, ElementName=Root}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextColor}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Grid.Row="2" Margin="0,5,0,0" HorizontalAlignment="Left">
                    <TextBlock Text="CREATED BY" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Application.CreatedByUserName, ElementName=Root}" 
                               FontWeight="SemiBold" FontSize="15" 
                               Foreground="{StaticResource TextColor}" Margin="0,4,0,0"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
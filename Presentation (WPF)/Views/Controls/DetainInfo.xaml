<UserControl x:Class="Presentation.Views.Controls.DetainInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Presentation.Views.Controls"
             mc:Ignorable="d" 
             x:Name="Root"
             HorizontalContentAlignment="Stretch"
             d:DesignHeight="200" d:DesignWidth="800">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="FineFeesTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MaxLength" Value="10"/>
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}" Padding="25" Margin="20,10,20,20" HorizontalAlignment="Stretch">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════ HEADER ═══════════════ -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                    CornerRadius="12" Padding="18,14,18,14" Margin="-25,-25,-25,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38" CornerRadius="10" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.15"
                                VerticalAlignment="Center" Margin="0,0,14,0"
                                Padding="8">
                            <materialDesign:PackIcon Kind="LockOutline" 
                                                    Foreground="{StaticResource PrimaryColor}" 
                                                    Width="22" Height="22" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Detain Info" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- فاصل -->
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="0,0,0,20" Background="{StaticResource BorderColor}"/>

            <!-- ═══════════════ DATA GRID ═══════════════ -->
            <Grid Grid.Row="1" Margin="0,4,0,0" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Detain ID -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="DETAIN ID" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Detain.DetainID, ElementName=Root}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

                <!-- Detain Date -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="DETAIN DATE" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Detain.DetainDate, ElementName=Root, StringFormat='{}{0:dd/MMM/yyyy}'}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

                <!-- Created By -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="CREATED BY" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding Detain.CreatedByUserName, ElementName=Root}" 
                               Style="{StaticResource FieldValue}"/>
                </StackPanel>

                <!-- Fine Fees (إدخال) -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Left">
                    <TextBlock Text="FINE FEES" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding FineFees, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FineFeesTextBoxStyle}"
                             materialDesign:HintAssist.Hint="0.00"/>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</UserControl>
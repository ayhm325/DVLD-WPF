<UserControl x:Class="Presentation.Views.Controls.DrivingLicenseApplicationInfo"
             x:Name="control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="350"
             d:DesignWidth="800">

    <UserControl.Resources>
        <!-- تدرج خفيف للهيدر -->
        <LinearGradientBrush x:Key="HeaderBgGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#042F2E" Offset="0"/>
            <GradientStop Color="#0A0A0B" Offset="1"/>
        </LinearGradientBrush>

        <!-- نمط تسمية الحقل -->
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- نمط قيمة الحقل -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- أيقونة المعلومة (مربع مستدير صغير) -->
        <Style x:Key="InfoIconBox" TargetType="Border">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Background" Value="#042F2E"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- أيقونة الحالة (مربع مستدير صغير) -->
        <Style x:Key="StatusIconBox" TargetType="Border">
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0,0,0,29">

        <!-- البطاقة الرئيسية باستخدام CardStyle العام -->
        <Border Style="{StaticResource CardStyle}" 
                Padding="25" 
                Margin="20,15,20,10">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 1: ID & Tests -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 2: License Class -->
                </Grid.RowDefinitions>

                <!-- ═══════════════ 1. HEADER ═══════════════ -->
                <Border Grid.Row="0" Background="{StaticResource HeaderBgGradient}" 
                        CornerRadius="12" Padding="18,14,18,14" Margin="-25,-25,-25,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- أيقونة بنمط المربّع المستدير الموحد -->
                            <Border Width="38" Height="38" CornerRadius="10" 
                                    Background="{StaticResource PrimaryColor}" 
                                    Opacity="0.15"
                                    VerticalAlignment="Center" Margin="0,0,14,0"
                                    Padding="8">
                                <materialDesign:PackIcon Kind="CardAccountDetailsStar" 
                                                        Foreground="{StaticResource PrimaryColor}" 
                                                        Width="22" Height="22" 
                                                        VerticalAlignment="Center" 
                                                        HorizontalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Driving License Application Info" 
                                       FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextColor}" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- الزر باستخدام الستايل العام -->
                        <Button Grid.Column="1" VerticalAlignment="Center"
                                Content="License Info" 
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="LicenseInfoButton_Click"
                                Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <!-- الفاصل بلون الحدود العام -->
                <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="0,0,0,20" Background="{StaticResource BorderColor}"/>

                <!-- ═══════════════ 2. ROW 1: ID & TESTS ═══════════════ -->
                <Grid Grid.Row="1" Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- D.L.App ID -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Style="{StaticResource InfoIconBox}" Margin="0,0,15,0">
                            <materialDesign:PackIcon Kind="Numeric" 
                                                    Foreground="{StaticResource PrimaryColor}" 
                                                    Width="24" Height="24" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="D.L.App ID" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Text="{Binding DrivingLicenseApplicationId, ElementName=control}" 
                                       Style="{StaticResource FieldValue}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Passed Tests (أخضر داكن – نمط حالة التفعيل) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Style="{StaticResource StatusIconBox}" 
                                Background="#064E3B" Margin="0,0,15,0">
                            <materialDesign:PackIcon Kind="CheckCircle" 
                                                    Foreground="#34D399" 
                                                    Width="24" Height="24" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Passed Tests" Style="{StaticResource FieldLabel}"/>
                            <TextBlock Style="{StaticResource FieldValue}">
                                <Run Text="{Binding PassedTests, ElementName=control}" Foreground="#34D399"/>
                                <Run Text="/" Foreground="{StaticResource BorderColor}"/>
                                <Run Text="{Binding TotalTests, ElementName=control}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- ═══════════════ 3. ROW 2: APPLIED FOR LICENSE ═══════════════ -->
                <Border Grid.Row="2" 
                        Background="#042F2E" 
                        CornerRadius="10" 
                        Padding="16" 
                        BorderBrush="{StaticResource PrimaryColor}" 
                        BorderThickness="1"
                        Opacity="0.9">
                    <Border.Effect>
                        <DropShadowEffect Color="#14B8A6" Direction="270" ShadowDepth="0" BlurRadius="12" Opacity="0.08"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" 
                                Background="{StaticResource PrimaryColor}" 
                                Opacity="0.2" 
                                CornerRadius="10" 
                                Margin="0,0,15,0" 
                                VerticalAlignment="Center"
                                Padding="8">
                            <materialDesign:PackIcon Kind="Car" 
                                                    Foreground="{StaticResource PrimaryColor}" 
                                                    Width="22" Height="22" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Applied For License" 
                                       Foreground="{StaticResource PrimaryColor}" 
                                       FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding LicenseClassName, ElementName=control}" 
                                       FontWeight="SemiBold" FontSize="17" 
                                       Foreground="{StaticResource TextColor}" 
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
<UserControl x:Class="Presentation.Views.Controls.DrivingLicenseApplicationInfo"
             x:Name="control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="350"
             d:DesignWidth="800">

    <UserControl.Resources>

        <DropShadowEffect x:Key="CardShadow"
                          Color="#CCCCCC"
                          Direction="270"
                          ShadowDepth="2"
                          BlurRadius="10"
                          Opacity="0.3"/>

        <SolidColorBrush x:Key="AppBackground" Color="#F0F2F5"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0078D7"/>

    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackground}"
          Margin="0,0,0,29">

        <Border Background="White"
                CornerRadius="8"
                Padding="40"
                Margin="15,15,15,10"
                Effect="{StaticResource CardShadow}">

            <StackPanel>

                <!-- Header -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,25">

                    <Path Width="28"
                          Height="28"
                          Fill="{StaticResource PrimaryBlue}"
                          Stretch="Uniform"
                          Margin="0,0,15,0"
                          Data="M20,4H4C2.89,4 2,4.89 2,6V18C2,19.11 2.89,20 4,20H20C21.11,20 22,19.11 22,18V6C22,4.89 21.11,4 20,4M20,18H4V6H20V18M13,15H18V13H13V15M13,11H18V9H13V11M6,15H11V13H6V15M6,11H11V9H6V11Z"/>

                    <TextBlock Text="Driving License Application Info"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#333333"
                               VerticalAlignment="Center"/>

                </StackPanel>

                <Border Height="3"
                        Width="60"
                        Background="{StaticResource PrimaryBlue}"
                        HorizontalAlignment="Left"
                        Margin="0,0,0,30"/>

                <StackPanel>

                    <!-- First Row -->
                    <Grid Margin="0,0,0,30">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- D.L.App ID -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <Border Width="45"
                                    Height="45"
                                    Background="#E6F2FF"
                                    CornerRadius="22"
                                    Margin="0,0,15,0">

                                <Path Width="22"
                                      Height="22"
                                      Fill="{StaticResource PrimaryBlue}"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Data="M20,4H4C2.89,4 2,4.89 2,6V18C2,19.11 2.89,20 4,20H20C21.11,20 22,19.11 22,18V6C22,4.89 21.11,4 20,4M20,18H4V6H20V18M12,12C13.66,12 15,10.66 15,9C15,7.34 13.66,6 12,6C10.34,6 9,7.34 9,9C9,10.66 10.34,12 12,12M6,16H18V14C18,12.67 15.33,12 12,12C8.67,12 6,12.67 6,14V16Z"/>

                            </Border>

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock Text="D.L.App ID"
                                           FontSize="13"
                                           Foreground="#757575"/>

                                <TextBlock Text="{Binding DrivingLicenseApplicationId, ElementName=control}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,2,0,0"/>

                            </StackPanel>

                        </StackPanel>

                        <!-- Passed Tests -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <Border Width="45"
                                    Height="45"
                                    Background="#E6F2FF"
                                    CornerRadius="22"
                                    Margin="0,0,15,0">

                                <Path Width="22"
                                      Height="22"
                                      Fill="{StaticResource PrimaryBlue}"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Data="M19,3H5C3.89,3 3,3.9 3,5V19C3,20.1 3.89,21 5,21H19C20.1,21 21,20.1 21,19V5C21,3.9 20.1,3 19,3M19,19H5V5H19V19M10,17L5,12L6.41,10.59L10,14.17L17.59,6.58L19,8L10,17Z"/>

                            </Border>

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock Text="Passed Tests"
                                           FontSize="13"
                                           Foreground="#757575"/>

                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,2,0,0">

                                    <Run Text="{Binding PassedTests, ElementName=control}"/>
                                    <Run Text="/"/>
                                    <Run Text="{Binding TotalTests, ElementName=control}"/>

                                </TextBlock>

                            </StackPanel>

                        </StackPanel>

                    </Grid>

                    <!-- Second Row -->
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- License Class -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <Border Width="40"
                                    Height="40"
                                    Background="#E6F2FF"
                                    CornerRadius="20"
                                    Margin="0,0,15,0">

                                <Path Width="20"
                                      Height="20"
                                      Fill="{StaticResource PrimaryBlue}"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Data="M18.92,6.01C18.72,5.42 18.16,5 17.5,5H6.5C5.84,5 5.28,5.42 5.08,6.01L3,12V20C3,20.55 3.45,21 4,21H5C5.55,21 6,20.55 6,20V19H18V20C18,20.55 18.45,21 19,21H20C20.55,21 21,20.55 21,20V12L18.92,6.01M6.5,6.5H17.5L18.5,9.5H5.5L6.5,6.5M19,17H5V12H19V17M7.5,13C6.67,13 6,13.67 6,14.5C6,15.33 6.67,16 7.5,16C8.33,16 9,15.33 9,14.5C9,13.67 8.33,13 7.5,13M16.5,13C15.67,13 15,13.67 15,14.5C15,15.33 15.67,16 16.5,16C17.33,16 18,15.33 18,14.5C18,13.67 17.33,13 16.5,13Z"/>

                            </Border>

                            <StackPanel VerticalAlignment="Center">

                                <TextBlock Text="Applied For"
                                           FontSize="14"
                                           Foreground="#757575"/>

                                <TextBlock Text="{Binding LicenseClassName, ElementName=control}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#333333"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"/>

                            </StackPanel>

                        </StackPanel>

                        <!-- Button -->
                        <Button Grid.Column="1"
                                Content="Show License Info"
                                Command="{Binding ShowLicenseInfoCommand, ElementName=control}"
                                Background="{StaticResource PrimaryBlue}"
                                Foreground="White"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Padding="20,10"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="15,0,0,0">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                    </Grid>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>
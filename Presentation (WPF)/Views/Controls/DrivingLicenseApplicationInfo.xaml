<UserControl x:Class="Presentation.Views.Controls.DrivingLicenseApplicationInfo"
             x:Name="control"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="350"
             d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="Auto">

    <!-- تمت إزالة UserControl.Resources للاعتماد على الستايل العام -->

    <!-- الخلفية الشفافة لترك الخلفية للنافذة الأم -->
    <Grid Margin="0,0,0,29">

        <!-- البطاقة الرئيسية باستخدام CardStyle العام -->
        <Border Style="{StaticResource CardStyle}" 
                Padding="25" 
                Margin="20,15,20,10">

            <!-- شبكة خارجية رئيسية -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 1: ID & Tests -->
                    <RowDefinition Height="Auto"/>
                    <!-- Row 2: License Class -->
                </Grid.RowDefinitions>

                <!-- 1. Header Row -->
                <Grid Grid.Row="0" Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- دائرة الأيقونة (خلفية داكنة + حدود) -->
                        <Border Width="40" Height="40" CornerRadius="20" 
                                Background="{StaticResource InputBackground}" 
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="CardAccountDetailsStar" 
                                                    Foreground="{StaticResource PrimaryColor}" 
                                                    Width="22" Height="22" 
                                                    VerticalAlignment="Center" 
                                                    HorizontalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Driving License Application Info" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextColor}" VerticalAlignment="Center"/>
                            <!-- الخط الملون -->
                            <Border Height="3" Width="40" Margin="0,6,0,0" 
                                    Background="{StaticResource PrimaryColor}" 
                                    CornerRadius="2" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- الزر باستخدام الستايل العام -->
                    <Button Grid.Column="1" VerticalAlignment="Center"
                            Content="License Info" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="LicenseInfoButton_Click"
                            Margin="10,0,0,0"/>
                </Grid>

                <!-- الفاصل بلون الحدود العام -->
                <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Margin="0,0,0,20" Background="{StaticResource BorderColor}"/>

                <!-- 2. First Info Row: ID and Tests -->
                <Grid Grid.Row="1" Margin="0,5,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- D.L.App ID -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Border Width="45" Height="45" Background="{StaticResource InputBackground}" 
                                CornerRadius="22" Margin="0,0,15,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Numeric" Foreground="{StaticResource PrimaryColor}" 
                                                    Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="D.L.App ID" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding DrivingLicenseApplicationId, ElementName=control}" 
                                       FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextColor}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Passed Tests (تخصيص لون أخضر داكن للوضع الليلي) -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- خلفية خضراء داكنة جداً -->
                        <Border Width="45" Height="45" Background="#064E3B" CornerRadius="22" Margin="0,0,15,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="#34D399" 
                                                    Width="24" Height="24" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Passed Tests" Foreground="{StaticResource SecondaryTextColor}" FontSize="11" FontWeight="Bold"/>
                            <TextBlock FontWeight="SemiBold" FontSize="16" Foreground="{StaticResource TextColor}" Margin="0,4,0,0">
                                <Run Text="{Binding PassedTests, ElementName=control}" Foreground="#34D399"/>
                                <Run Text="/" Foreground="{StaticResource BorderColor}"/>
                                <Run Text="{Binding TotalTests, ElementName=control}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- 3. Second Info Row: Applied For License (تخصيص لون برتقالي داكن للوضع الليلي) -->
                <Border Grid.Row="2" 
                        Background="#451A03" 
                        CornerRadius="8" 
                        Padding="15" 
                        BorderBrush="#D97706" 
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" Background="#78350F" CornerRadius="20" Margin="0,0,15,0" VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="Car" Foreground="#FBBF24" 
                                                    Width="22" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Applied For License" Foreground="#FBBF24" FontSize="11" FontWeight="Bold"/>
                            <TextBlock Text="{Binding LicenseClassName, ElementName=control}" 
                                       FontWeight="SemiBold" FontSize="17" Foreground="#FCD34D" 
                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>
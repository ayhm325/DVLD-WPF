<UserControl x:Class="Presentation.Views.Controls.DriverLicenseInfo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="920">

    <UserControl.Resources>

        <!-- ═══════════════ Local Brushes ═══════════════ -->
        <SolidColorBrush x:Key="IconBgBrush" Color="#1E1B4B"/>

        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0.6">
            <GradientStop Color="#0B1220" Offset="0"/>
            <GradientStop Color="#162032" Offset="0.5"/>
            <GradientStop Color="#0F1D32" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SearchBtnGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6366F1" Offset="0"/>
            <GradientStop Color="#4F46E5" Offset="1"/>
        </LinearGradientBrush>

        <!-- ألوان حالة التفعيل -->
        <SolidColorBrush x:Key="ActiveGreenBg" Color="#064E3B"/>
        <SolidColorBrush x:Key="ActiveGreenText" Color="#34D399"/>
        <SolidColorBrush x:Key="InactiveRedBg" Color="#7F1D1D"/>
        <SolidColorBrush x:Key="InactiveRedText" Color="#F87171"/>

        <!-- ألوان حالة الاحتجاز -->
        <SolidColorBrush x:Key="DetainedRedBg" Color="#450A0A"/>
        <SolidColorBrush x:Key="DetainedRedText" Color="#DC2626"/>
        <SolidColorBrush x:Key="FreeGreenBg" Color="#064E3B"/>
        <SolidColorBrush x:Key="FreeGreenText" Color="#34D399"/>

        <!-- ═══════════════ Local Styles ═══════════════ -->

        <Style x:Key="FieldItemContainer" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,12,14,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                    <!-- تم تصحيح اللون ليطابق لوحة الألوان العامة بدلاً من #111827 -->
                    <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Margin" Value="10,2,0,0"/>
        </Style>

        <Style x:Key="IconCircle" TargetType="Border">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="{StaticResource IconBgBrush}"/>
        </Style>

        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,4,10,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="10,3,0,0"/>
        </Style>

        <!-- نص خانة البحث – يرث كل الألوان من الستايل العام -->
        <Style x:Key="SearchTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Padding" Value="10,8,10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryColor}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderSearchBtn" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SearchBtnGradient}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,9,14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </UserControl.Resources>

    <!-- ═══════════════ MAIN CARD ═══════════════ -->
    <Border Background="{DynamicResource CardBackground}"
            CornerRadius="16"
            Margin="6"
            ClipToBounds="False"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">

        <!-- تم إصلاح مشكلة مشاركة الـ Effect لمنع التجميد -->
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="0" BlurRadius="20" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════════ HEADER ═══════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderGradient}"
                    CornerRadius="16,16,0,0"
                    Padding="28,18,28,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{DynamicResource PrimaryColor}" Opacity="0.15"
                                CornerRadius="10" Padding="10" Margin="0,0,16,0">
                            <Path Data="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
                                  Stroke="White" StrokeThickness="1.6" Fill="Transparent" Stretch="Uniform" Height="22" Width="22"/>
                        </Border>
                        <TextBlock Text="Driver License Info" FontSize="21" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="License ID :" Foreground="{DynamicResource SecondaryTextColor}"
                                   FontSize="14.5" FontWeight="Medium" VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <Grid Width="220" Height="38">
                            <Border Background="Transparent" Padding="11,0,0,0" VerticalAlignment="Center">
                                <Path Data="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                                      Stroke="{DynamicResource SecondaryTextColor}" StrokeThickness="1.8"
                                      Fill="Transparent" Stretch="Uniform" Height="15" Width="15"/>
                            </Border>
                            <TextBox x:Name="TxtLicenseID"
                                     VerticalAlignment="Center"
                                     Margin="30,0,0,0"
                                     Style="{StaticResource SearchTextBox}" TextChanged="TxtLicenseID_TextChanged"/>
                        </Grid>

                        <Border Style="{StaticResource HeaderSearchBtn}"
                                Margin="8,0,0,0"
                                MouseLeftButtonUp="BtnSearch_Click">
                            <Border.Effect>
                                <DropShadowEffect Color="#4F46E5" BlurRadius="8" Opacity="0.35" Direction="0"/>
                            </Border.Effect>
                            <Path Data="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                                  Stroke="White" StrokeThickness="2" Fill="Transparent"
                                  Stretch="Uniform" Height="16" Width="16"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════ CONTENT ═══════════════ -->
            <Grid Grid.Row="1" Margin="28,24,28,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <!-- ──── Fields Grid ──── -->
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ═══ Row 1: Class ═══ -->
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Class" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Class, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 1: Name ═══ -->
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Name, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 2: License ID ═══ -->
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="License ID" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding LicenseID, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 2: National No ═══ -->
                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h.01"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="National No" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding NationalNo, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 3: Gender ═══ -->
                    <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Gender" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Gender, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 3: Date Of Birth ═══ -->
                    <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Date Of Birth" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding DateOfBirth, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 4: Driver ID ═══ -->
                    <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm-3.375 6.125h3.375"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Driver ID" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding DriverID, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 4: Issue Date ═══ -->
                    <Border Grid.Row="6" Grid.Column="2" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Issue Date" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding IssueDate, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 5: Expiration Date ═══ -->
                    <Border Grid.Row="8" Grid.Column="0" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Expiration Date" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding ExpirationDate, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 5: Issue Reason ═══ -->
                    <Border Grid.Row="8" Grid.Column="2" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Issue Reason" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding IssueReason, FallbackValue='[???]'}" Style="{StaticResource FieldValue}"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 6: Is Active? ═══ -->
                    <Border Grid.Row="10" Grid.Column="0" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Is Active?" Style="{StaticResource FieldLabel}"/>
                                <Border x:Name="ActiveBadge">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadge}">
                                            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource ActiveGreenBg}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource ActiveGreenText}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource InactiveRedBg}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource InactiveRedText}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock x:Name="ActiveText" FontSize="11.5" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Unknown"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Text" Value="Active"/>
                                                        <Setter Property="Foreground" Value="{StaticResource ActiveGreenText}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Text" Value="Inactive"/>
                                                        <Setter Property="Foreground" Value="{StaticResource InactiveRedText}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 6: Is Detained? ═══ -->
                    <Border Grid.Row="10" Grid.Column="2" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left">
                                <Path Data="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Is Detained?" Style="{StaticResource FieldLabel}"/>
                                <Border x:Name="DetainedBadge">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadge}">
                                            <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDetained}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource DetainedRedBg}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource DetainedRedText}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDetained}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource FreeGreenBg}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource FreeGreenText}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock x:Name="DetainedText" FontSize="11.5" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="Unknown"/>
                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextColor}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDetained}" Value="True">
                                                        <Setter Property="Text" Value="Detained"/>
                                                        <Setter Property="Foreground" Value="{StaticResource DetainedRedText}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDetained}" Value="False">
                                                        <Setter Property="Text" Value="Free"/>
                                                        <Setter Property="Foreground" Value="{StaticResource FreeGreenText}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ═══ Row 7: Notes ═══ -->
                    <Border Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource FieldItemContainer}">
                        <DockPanel>
                            <Border Style="{StaticResource IconCircle}" DockPanel.Dock="Left"
                                    VerticalAlignment="Top" Margin="0,2,0,0">
                                <Path Data="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
                                      Stroke="{DynamicResource PrimaryColor}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform" Height="16" Width="16"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Notes" Style="{StaticResource FieldLabel}"/>
                                <TextBlock Text="{Binding Notes, FallbackValue='[???]'}"
                                           Style="{StaticResource FieldValue}"
                                           TextWrapping="Wrap" MaxHeight="50"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- ──── Right Side Image ──── -->
                <Border Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="140"
                                Height="170"
                                Background="{DynamicResource InputBackground}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="2"
                                CornerRadius="12"
                                ClipToBounds="True">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Ellipse Width="50" Height="50"
                                             Fill="{DynamicResource BorderColor}"
                                             HorizontalAlignment="Center"/>
                                    <Ellipse Width="70" Height="35"
                                             Fill="{DynamicResource BorderColor}"
                                             Margin="0,-18,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="No Photo" FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextColor}"
                                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                </StackPanel>
                                <Image Source="{Binding PersonImagePath}"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <TextBlock Text="Driver Photo" FontSize="11" FontWeight="Medium"
                                   Foreground="{DynamicResource SecondaryTextColor}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
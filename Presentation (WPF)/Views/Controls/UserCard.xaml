<UserControl x:Class="Presentation.Views.Controls.UserCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="400">

    <UserControl.Resources>
        <!-- تعريف الموارد محلياً لضمان ظهور التصميم -->
        <DropShadowEffect x:Key="CardShadow" Color="#000000" Direction="270" ShadowDepth="0" BlurRadius="15" Opacity="0.05"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0078D7"/>
        <SolidColorBrush x:Key="PrimaryBlueLight" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="TextDark" Color="#2C3E50"/>
        <SolidColorBrush x:Key="TextGray" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="StatusGreenBg" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="StatusGreenText" Color="#2E7D32"/>
    </UserControl.Resources>

    <!-- البطاقة الرئيسية -->
    <Border Background="White" 
            CornerRadius="10" 
            Padding="20,15" 
            Margin="5" 
            Effect="{StaticResource CardShadow}"
            BorderBrush="#F0F2F5" 
            BorderThickness="1">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <!-- الأيقونة -->
                <ColumnDefinition Width="*"/>
                <!-- معلومات المستخدم -->
                <ColumnDefinition Width="Auto"/>
                <!-- الحالة -->
            </Grid.ColumnDefinitions>

            <!-- عمود الأيقونة (Avatar) -->
            <Border Grid.Column="0" Width="45" Height="45" CornerRadius="22" Background="{StaticResource PrimaryBlueLight}" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Account" 
                                        Foreground="{StaticResource PrimaryBlue}" 
                                        Width="24" Height="24" 
                                        VerticalAlignment="Center" 
                                        HorizontalAlignment="Center"/>
            </Border>

            <!-- عمود الاسم -->
            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="User" FontSize="10" Foreground="{StaticResource TextGray}" FontWeight="Medium" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding UserName}" 
                           FontSize="16" 
                           FontWeight="SemiBold" 
                           Foreground="{StaticResource TextDark}" 
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- عمود الحالة (Status Badge) -->
            <Border Grid.Column="2" 
                    Background="{StaticResource StatusGreenBg}" 
                    Padding="12,6" 
                    CornerRadius="20" 
                    Margin="15,0,0,0" 
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource StatusGreenText}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding IsActive}" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource StatusGreenText}" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

        </Grid>

    </Border>

</UserControl>
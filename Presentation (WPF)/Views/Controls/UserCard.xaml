<UserControl x:Class="Presentation.Views.Controls.UserCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- تم تطبيق CardStyle هنا: الخلفية البيضاء، الحدود الدائرية، والظل -->
    <Border Style="{StaticResource CardStyle}" 
            Margin="10" 
            Padding="15">

        <StackPanel>
            <!-- تم تطبيق HeaderStyle هنا مع الحفاظ على اللون الأساسي (PrimaryColor) -->
            <TextBlock Text="User Information" 
                       Style="{StaticResource HeaderStyle}"
                       Foreground="{StaticResource PrimaryColor}" 
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">
                <!-- استخدام TextColor بدلاً من اللون الرمادي الثابت ليتناسب مع الثيم -->
                <TextBlock Text="User: " FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                <TextBlock Text="{Binding UserName}" Margin="0,0,20,0" Foreground="{StaticResource TextColor}" VerticalAlignment="Center"/>

                <TextBlock Text="Status: " FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                <!-- تلوين حالة المستخدم باللون الأساسي لإبرازها -->
                <TextBlock Text="{Binding IsActive}" Foreground="{StaticResource PrimaryColor}" FontWeight="Medium" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

    </Border>

</UserControl>
<UserControl x:Class="Presentation.Views.Controls.UserCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#F1F5F9" 
            BorderBrush="#CBD5E1" 
            BorderThickness="1" 
            CornerRadius="8" 
            Margin="10" 
            Padding="15">

        <StackPanel>
            <TextBlock Text="User Information" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource PrimaryColor}" 
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="User: " FontWeight="Bold" Foreground="#475569"/>
                <TextBlock Text="{Binding UserName}" Margin="0,0,20,0" Foreground="#1E293B"/>

                <TextBlock Text="Status: " FontWeight="Bold" Foreground="#475569"/>
                <TextBlock Text="{Binding IsActive}" Foreground="#0F766E"/>
            </StackPanel>
        </StackPanel>

    </Border>

</UserControl>
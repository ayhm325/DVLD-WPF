<UserControl x:Class="Presentation.Views.Controls.InformationPerson"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="Auto">

    <UserControl.Resources>
        <!-- تعريف ستايلات محلية تعتمد على ألوان الستايل العام -->
        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <!-- البطاقة الرئيسية باستخدام الستايل العام -->
    <Border Style="{StaticResource CardStyle}" Padding="25" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <!-- أيقونة بخلفية داكنة -->
                    <Border Width="32" Height="32" CornerRadius="16" 
                            Background="{StaticResource InputBackground}" 
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1"
                            Margin="0,0,10,0" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="CardAccountDetails" 
                                                Foreground="{StaticResource PrimaryColor}" 
                                                Width="18" Height="18" 
                                                VerticalAlignment="Center" 
                                                HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Personal Information" 
                               FontSize="20" FontWeight="SemiBold" 
                               Foreground="{StaticResource TextColor}" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                <!-- خط تزييني بلون الثيم الأساسي -->
                <Border Height="3" Width="40" Margin="44,30,0,0" 
                        Background="{StaticResource PrimaryColor}" 
                        CornerRadius="2" HorizontalAlignment="Left"/>
            </Grid>

            <!-- Content Grid -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <!-- مسافة بين النص والصورة -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- عمود الصورة -->
                </Grid.ColumnDefinitions>

                <!-- عمود البيانات (يسار) -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Person ID & Gender -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Person ID" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Person.PersonId, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Gender" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding Person.Gender, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource InfoValueStyle}"/>

                    <!-- Full Name (Full Width) -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Full Name" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" 
                               Text="{Binding Person.FullName, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               Style="{StaticResource InfoValueStyle}" FontSize="16"/>

                    <!-- Separator Line -->
                    <Border Grid.Row="2" Grid.ColumnSpan="5" Height="1" 
                            Background="{StaticResource BorderColor}" 
                            Margin="0,5,0,15" HorizontalAlignment="Stretch"/>

                    <!-- National No & DOB -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="National No" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Person.NationalNo, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="3" Grid.Column="3" Text="Date Of Birth" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="4" 
                               Text="{Binding Person.DateOfBirth, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='{}{0:dd/MM/yyyy}'}" 
                               Style="{StaticResource InfoValueStyle}"/>

                    <!-- Phone & Email -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Person.Phone, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="4" Grid.Column="3" Text="Email" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="4" Text="{Binding Person.Email, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource InfoValueStyle}"/>

                    <!-- Country & Address -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Country" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Person.CountryName, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource InfoValueStyle}"/>

                    <TextBlock Grid.Row="5" Grid.Column="3" Text="Address" Style="{StaticResource InfoLabelStyle}"/>
                    <TextBlock Grid.Row="5" Grid.Column="4" Text="{Binding Person.Address, RelativeSource={RelativeSource AncestorType=UserControl}}" Style="{StaticResource InfoValueStyle}"/>

                </Grid>

                <!-- عمود الصورة (يمين) -->
                <Border Grid.Column="2" Width="160" Height="160" 
                        CornerRadius="100" 
                        BorderThickness="3" 
                        BorderBrush="{StaticResource BorderColor}" 
                        Effect="{StaticResource CardShadow}" 
                        VerticalAlignment="Top">
                    <Border.Clip>
                        <EllipseGeometry Center="80,80" RadiusX="80" RadiusY="80"/>
                    </Border.Clip>

                    <Grid>
                        <!-- الصورة -->
                        <Image Stretch="UniformToFill" 
                               Source="{Binding Person.ImagePath, RelativeSource={RelativeSource AncestorType=UserControl}, TargetNullValue='pack://application:,,,/Resources/DefaultAvatar.png'}"/>
                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Border>

</UserControl>
<Page x:Class="Presentation.Views.Pages.DriversPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Presentation.Views.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1100"
      Title="DriversPage"
      Background="{StaticResource BackgroundColor}">

    <Page.Resources>

        <!-- ===== DataGrid ===== -->
        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#111114"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ===== Column Header ===== -->
        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0E0E10"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        </Style>

        <!-- ===== Cell ===== -->
        <Style x:Key="CellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#042F2E"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== نصوص الأعمدة ===== -->
        <Style x:Key="ColumnTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style x:Key="ColumnTextBoldStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <Style x:Key="ColumnTextLeftStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>

        <!-- ===== حقل الفلتر (يرث الستايل العام) ===== -->
        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="200"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
        </Style>

    </Page.Resources>

    <Grid Margin="24">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== العنوان ==================== -->
        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Drivers Management" Style="{StaticResource HeaderStyle}"/>
                <TextBlock Text=" (" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                <TextBlock Text="{Binding DriversCount}" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center"/>
                <TextBlock Text=")" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <!-- ==================== شريط الفلتر ==================== -->
        <Border Grid.Row="1" 
                Background="{StaticResource CardBackground}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1"
                Padding="16,10"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Filter by:" 
                           Style="{StaticResource LabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <ComboBox x:Name="cmbFilterBy"
                          SelectedIndex="0"
                          Width="150"
                          FontSize="13">
                    <ComboBoxItem Content="None" IsSelected="True"/>
                    <ComboBoxItem Content="Full Name"/>
                    <ComboBoxItem Content="Driver ID"/>
                    <ComboBoxItem Content="Person ID"/>
                </ComboBox>

                <TextBox x:Name="txtFilterValue">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource FilterTextBoxStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=cmbFilterBy, Path=Text}" Value="None">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

            </StackPanel>
        </Border>

        <!-- ==================== الداتا قريد ==================== -->
        <Border Grid.Row="2" 
                Style="{StaticResource CardStyle}"
                Padding="0"
                ClipToBounds="True">

            <DataGrid x:Name="dgDrivers"
                      Style="{StaticResource DataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                      CellStyle="{StaticResource CellStyle}"
                      ItemsSource="{Binding Drivers}"
                      SelectedItem="{Binding SelectedDriver}"
                      Margin="0">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">

                        <!-- حفظ الـ ViewModel في Tag -->
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"/>

                        <!-- تفعيل التحديد عند الضغط بالزر الأيمن -->
                        <EventSetter Event="MouseRightButtonDown" Handler="DataGridRow_MouseRightButtonDown"/>

                        <!-- Context Menu -->
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">

                                    <MenuItem Header="Show Person Info" 
                                              Command="{Binding PlacementTarget.Tag.ShowPersonInfoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" 
                                                  Fill="{StaticResource PrimaryColor}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Show Person License History" 
                                              Command="{Binding PlacementTarget.Tag.ShowLicenseHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L8.89,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.06,19 9.3,18.21 8.08,16.92L6.64,18.36C8.25,20 10.47,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3M12,8V12L15.28,13.94L16.05,12.66L13,10.8V8H12Z" 
                                                  Fill="{StaticResource PrimaryColor}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                </ContextMenu>
                            </Setter.Value>
                        </Setter>

                        <!-- تفاعلات الصفوف -->
                        <Style.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#1A1A1E"/>
                            </MultiTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#042F2E"/>
                            </Trigger>
                        </Style.Triggers>

                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Driver ID"
                                        Binding="{Binding DriverID}"
                                        Width="90"
                                        ElementStyle="{StaticResource ColumnTextBoldStyle}"/>

                    <DataGridTextColumn Header="Person ID"
                                        Binding="{Binding PersonID}"
                                        Width="90"
                                        ElementStyle="{StaticResource ColumnTextStyle}"/>

                    <DataGridTextColumn Header="National No"
                                        Binding="{Binding NationalNo}"
                                        Width="130"
                                        ElementStyle="{StaticResource ColumnTextStyle}"/>

                    <DataGridTextColumn Header="Full Name"
                                        Binding="{Binding FullName}"
                                        Width="*"
                                        ElementStyle="{StaticResource ColumnTextLeftStyle}"/>

                    <DataGridTextColumn Header="Date"
                                        Binding="{Binding CreatedDate, StringFormat='yyyy/MM/dd'}"
                                        Width="110"
                                        ElementStyle="{StaticResource ColumnTextStyle}"/>

                    <DataGridTextColumn Header="Active Licenses"
                                        Binding="{Binding ActiveLicenses}"
                                        Width="120"
                                        ElementStyle="{StaticResource ColumnTextStyle}"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>
    </Grid>
</Page>
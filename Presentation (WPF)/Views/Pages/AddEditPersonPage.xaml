<Page x:Class="Presentation.Views.AddEditPersonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Presentation.Views.Controls"
      mc:Ignorable="d"
      Title="Add/Edit Person"
      Background="#F5F6FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <TextBlock Text="Add / Edit Person"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

        <!-- PERSON FORM 
             الآن سترث البيانات تلقائياً من الـ DataContext الخاص بالصفحة الرئيسية
        -->
        <controls:PersonInfoCard Grid.Row="1" />

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <Button Content="Cancel"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#E74C3C"
                    Foreground="White"
                    Click="Cancel_Click"/>

            <Button Content="Save"
                    Width="100"
                    Height="35"
                    Background="#2ECC71"
                    Foreground="White"
                    Click="Save_Click"/>

        </StackPanel>

    </Grid>
</Page>
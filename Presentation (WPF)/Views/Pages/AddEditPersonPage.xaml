 <Page x:Class="Presentation.Views.AddEditPersonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Presentation.Views.Controls" xmlns:viewmodels="clr-namespace:Presentation.ViewModels" 
      mc:Ignorable="d"
      Title="Add/Edit Person"
      Background="#F5F6FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding PageTitle}"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>



        <ScrollViewer Grid.Row="1" 
              VerticalScrollBarVisibility="Auto" 
              HorizontalScrollBarVisibility="Disabled"
              Margin="0,0,0,10">
            <controls:PersonInfoCard />
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">


            <Button Content="Cancel" Style="{StaticResource PrimaryButtonStyle}" Background="#94A3B8" Width="100" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
            <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Background="OliveDrab" Width="100" Command="{Binding SavePersonCommand}"/>

        </StackPanel>

    </Grid>
</Page>
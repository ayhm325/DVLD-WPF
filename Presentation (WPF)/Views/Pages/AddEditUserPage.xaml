<Page x:Class="Presentation.Views.Pages.AddEditUserPage" 
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:controls="clr-namespace:Presentation.Views.Controls" 
      xmlns:helpers="clr-namespace:Presentation.Helpers"        
      mc:Ignorable="d" 
      Title="Add/Edit User"
      Background="#F5F6FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,15" Padding="20">
                <StackPanel>
                    <TextBlock Text="User Information Details" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextColor}"/>
                    <TextBlock Text="Review or update the user profile details below" FontSize="14" Foreground="#64748B" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <controls:Filter Grid.Row="1" Margin="0,0,0,15"/>

            <controls:InformationPerson Grid.Row="2" DataContext="{Binding SelectedPerson}"/>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,15" Padding="20">
                <StackPanel>
                    <TextBlock Text="Login Information" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Content="UserID:" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding UserIdDisplay, TargetNullValue='???'}" VerticalAlignment="Center" Margin="10,0"/>

                        <Label Grid.Row="1" Content="User Name:" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Margin="0,5" Width="300" Height="30" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="5,0,0,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                   Text="{Binding UserNameValidationMessage}" 
                                   Foreground="{Binding UserNameValidationColor}" 
                                   FontSize="11" 
                                   Margin="0,0,0,5" 
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   TextWrapping="Wrap" />

                        <Label Grid.Row="3" Content="Password:" VerticalAlignment="Center" Visibility="{Binding PasswordVisibility}" />
                        <PasswordBox Grid.Row="3" Grid.Column="1" Margin="0,5" Width="300" Height="30" HorizontalAlignment="Left" Padding="5,0,30,0"
                                     helpers:PasswordBoxHelper.Attach="True"
                                     helpers:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay}"
                                     Visibility="{Binding PasswordVisibility}" />

                        <Label Grid.Row="4" Content="Confirm Password:" VerticalAlignment="Center" Visibility="{Binding ConfirmPasswordVisibility}" />
                        <PasswordBox Grid.Row="4" Grid.Column="1" Margin="0,5" Width="300" Height="30" HorizontalAlignment="Left" Padding="5,0,30,0"
                                     helpers:PasswordBoxHelper.Attach="True"
                                     helpers:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay}"
                                     Visibility="{Binding ConfirmPasswordVisibility}" />

                        <CheckBox Grid.Row="5" Grid.Column="1" Content="Is Active" IsChecked="{Binding IsActive}" Margin="0,10,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
            
           <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,15" Padding="20">
    <StackPanel>
        <TextBlock Text="Login Information" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- UserID -->
            <Label Content="UserID:" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="{Binding UserIdDisplay, TargetNullValue='???'}" VerticalAlignment="Center" Margin="10,0"/>

            <!-- User Name -->
            <Label Grid.Row="1" Content="User Name:" VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" 
                     Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="0,5" Width="300" Height="30" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="5,0,0,0"/>

            <!-- Validation Message -->
            <TextBlock Grid.Row="2" Grid.Column="1" 
                       Text="{Binding UserNameValidationMessage}" 
                       Foreground="{Binding UserNameValidationColor}" 
                       FontSize="11" 
                       Margin="0,0,0,5" 
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       TextWrapping="Wrap" />

            <!-- Password Section -->
            <Label Grid.Row="3" Content="Password:" VerticalAlignment="Center" Visibility="{Binding PasswordVisibility}" />

            <Grid Grid.Row="3" Grid.Column="1" Margin="0,5" Width="300" Height="30" HorizontalAlignment="Left" 
                  Visibility="{Binding PasswordVisibility}">
                
                <!-- PasswordBox (Hidden when Eye is Active) -->
                <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                             helpers:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay}"
                             Padding="5,0,30,0"  Height="30"
                             VerticalAlignment="Stretch">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>

                <!-- TextBox (Visible when Eye is Active) -->
                <TextBox Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,0,30,0" 
                         VerticalContentAlignment="Center" Height="30"
                         VerticalAlignment="Stretch"> 
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPasswordVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Eye Button (Password) -->
                <Button HorizontalAlignment="Right" Width="30" Height="30" 
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Command="{Binding TogglePasswordVisibilityCommand}">
                    <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Confirm Password Section -->
            <Label Grid.Row="4" Content="Confirm Password:" VerticalAlignment="Center" Visibility="{Binding ConfirmPasswordVisibility}" />
            
            <Grid Grid.Row="4" Grid.Column="1" Margin="0,5" Width="300" Height="30" HorizontalAlignment="Left"
                  Visibility="{Binding ConfirmPasswordVisibility}">

                <!-- PasswordBox -->
                <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                             helpers:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay}"
                             Padding="5,0,30,0" Height="30"
                             VerticalAlignment="Stretch">
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConfirmPasswordVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>

                <!-- TextBox -->
                <TextBox Text="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5,0,30,0" 
                         VerticalContentAlignment="Center" Height="30"
                         VerticalAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConfirmPasswordVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Eye Button (Confirm Password) -->
                <Button HorizontalAlignment="Right" Width="30" Height="30"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Command="{Binding ToggleConfirmPasswordVisibilityCommand}">
                    <TextBlock Text="👁️" FontSize="14" Foreground="Gray" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>
            </Grid>

            <!-- Is Active -->
            <CheckBox Grid.Row="5" Grid.Column="1" Content="Is Active" IsChecked="{Binding IsActive}" Margin="0,10,0,0"/>
        </Grid>
    </StackPanel>
</Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Cancel" Style="{StaticResource PrimaryButtonStyle}" Background="#94A3B8" Width="100" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Background="OliveDrab" Width="100" Command="{Binding SaveUserCommand}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
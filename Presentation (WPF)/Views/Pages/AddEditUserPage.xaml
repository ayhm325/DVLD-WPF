<Page x:Class="Presentation.Views.Pages.AddEditUserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Presentation.Views.Controls"
      xmlns:helpers="clr-namespace:Presentation.Helpers"
      mc:Ignorable="d"
      Title="Add/Edit User"
      Background="#F5F6FA">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,0,15"
                    Padding="20">

                <StackPanel>
                    <TextBlock Text="User Information Details"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextColor}"/>

                    <TextBlock Text="Review or update the user profile details below"
                               FontSize="14"
                               Foreground="#64748B"
                               Margin="0,5,0,0"/>
                </StackPanel>

            </Border>

            <!-- Filter -->
            <controls:Filter Grid.Row="1"
                             Margin="0,0,0,15"/>

            <!-- Person Information -->
            <controls:InformationPerson Grid.Row="2"
                                        Person="{Binding Person}" />

            <!-- Login Information -->
            <Border Grid.Row="3"
                    Style="{StaticResource CardStyle}"
                    Margin="0,15"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="Login Information"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryColor}"
                               Margin="0,0,0,15"/>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- User ID -->
                        <Label Content="User ID:"
                               VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding UserIdDisplay, TargetNullValue='???'}"
                                   VerticalAlignment="Center"
                                   Margin="10,0"/>

                        <!-- User Name -->
                        <Label Grid.Row="1"
                               Content="User Name:"
                               VerticalAlignment="Center"/>

                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Width="300"
                                 Height="30"
                                 Margin="0,5"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 Padding="5,0,0,0"
                                 Text="{Binding UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- Validation -->
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Text="{Binding UserNameValidationMessage}"
                                   Foreground="{Binding UserNameValidationColor}"
                                   FontSize="11"
                                   Margin="0,0,0,5"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Top"
                                   TextWrapping="Wrap"/>

                        <!-- Password -->
                        <Label Grid.Row="3"
                               Content="Password:"
                               VerticalAlignment="Center"
                               Visibility="{Binding PasswordVisibility}" />

                        <Grid Grid.Row="3"
                              Grid.Column="1"
                              Width="300"
                              Height="30"
                              Margin="0,5"
                              HorizontalAlignment="Left"
                              Visibility="{Binding PasswordVisibility}">

                            <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                         helpers:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay}"
                                         Padding="5,0,30,0">

                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPasswordVisible}"
                                                         Value="True">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>

                            </PasswordBox>

                            <TextBox Text="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="5,0,30,0"
                                     VerticalContentAlignment="Center">

                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPasswordVisible}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>

                            </TextBox>

                            <Button Width="30"
                                    Height="30"
                                    HorizontalAlignment="Right"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding TogglePasswordVisibilityCommand}">

                                <TextBlock Text="👁️"
                                           FontSize="14"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                            </Button>

                        </Grid>

                        <!-- Confirm Password -->
                        <Label Grid.Row="4"
                               Content="Confirm Password:"
                               VerticalAlignment="Center"
                               Visibility="{Binding ConfirmPasswordVisibility}" />

                        <Grid Grid.Row="4"
                              Grid.Column="1"
                              Width="300"
                              Height="30"
                              Margin="0,5"
                              HorizontalAlignment="Left"
                              Visibility="{Binding ConfirmPasswordVisibility}">

                            <PasswordBox helpers:PasswordBoxHelper.Attach="True"
                                         helpers:PasswordBoxHelper.Password="{Binding ConfirmPassword, Mode=TwoWay}"
                                         Padding="5,0,30,0">

                                <PasswordBox.Style>
                                    <Style TargetType="PasswordBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConfirmPasswordVisible}"
                                                         Value="True">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </PasswordBox.Style>

                            </PasswordBox>

                            <TextBox Text="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="5,0,30,0"
                                     VerticalContentAlignment="Center">

                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConfirmPasswordVisible}"
                                                         Value="False">
                                                <Setter Property="Visibility"
                                                        Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>

                            </TextBox>

                            <Button Width="30"
                                    Height="30"
                                    HorizontalAlignment="Right"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Command="{Binding ToggleConfirmPasswordVisibilityCommand}">

                                <TextBlock Text="👁️"
                                           FontSize="14"
                                           Foreground="Gray"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>

                            </Button>

                        </Grid>

                        <!-- Active -->
                        <CheckBox Grid.Row="5"
                                  Grid.Column="1"
                                  Content="Is Active"
                                  IsChecked="{Binding IsActive}"
                                  Margin="0,10,0,0"/>

                    </Grid>

                </StackPanel>

            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <Button Content="Cancel"
                        Width="100"
                        Margin="0,0,10,0"
                        Background="#94A3B8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding CancelCommand}" />

                <Button Content="Save"
                        Width="100"
                        Background="OliveDrab"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SaveUserCommand}" />

            </StackPanel>

        </Grid>

    </ScrollViewer>

</Page>
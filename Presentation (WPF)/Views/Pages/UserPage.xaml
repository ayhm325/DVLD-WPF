<Page x:Class="Presentation.Views.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"     
      mc:Ignorable="d"
      Title="UserPage"
      Background="{StaticResource BackgroundColor}">

    <Page.Resources>

        <!-- ===================== CONVERTER ===================== -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ===================== COLORS ===================== -->
        <SolidColorBrush x:Key="AlternatingRowBrush" Color="#253248"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#334155"/>
        <SolidColorBrush x:Key="SelectedBrush" Color="#6366F1"/>

        <SolidColorBrush x:Key="IconSuccess" Color="#10B981"/>
        <SolidColorBrush x:Key="IconOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="IconPurple" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="IconCyan" Color="#06B6D4"/>

        <!-- ===================== DATA GRID STYLE ===================== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource AlternatingRowBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="45"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedBrush}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== HEADER ===================== -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
            <DockPanel LastChildFill="False">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <TextBlock Text="Users Management" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Text=" (" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <TextBlock Text="{Binding UsersCount}" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center"/>
                    <TextBlock Text=")" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="+ Add New User"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddNewUserCommand}"
                        Width="150"
                        DockPanel.Dock="Right"/>

            </DockPanel>
        </Border>

        <!-- ===================== MAIN ===================== -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

               
                <!-- ===================== FILTER ===================== -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                    <TextBlock Text="Filter by:"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0"
                         Style="{StaticResource LabelStyle}"/>

                    <ComboBox ItemsSource="{Binding FilterOptions}"
                        SelectedItem="{Binding SelectedFilterType}"
                        Width="140"
                        Margin="0,0,15,0"/>

                    <!-- FIXED FILTER AREA -->
                    <Grid Width="220">

                        <!-- SEARCH TEXT (تم التعديل هنا: IsSearchVisible بدلاً من IsTextFilter) -->
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsSearchVisible, 
                            Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- STATUS FILTER (تم التعديل هنا: IsStatusVisible بدلاً من IsStatusFilter) -->
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                 SelectedItem="{Binding SelectedStatus}"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsStatusVisible, 
                                 Converter={StaticResource BoolToVisibilityConverter}}"/>

                    </Grid>

                </StackPanel>

                <!-- ===================== DATA GRID ===================== -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="60"/>
                        <DataGridTextColumn Header="User Name" Binding="{Binding UserName}" Width="150"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding IsActive}" Width="100"/>
                    </DataGrid.Columns>

                    <!-- CONTEXT MENU -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>

                            <MenuItem Header="Show Details" Command="{Binding ShowDetailsCommand}"/>

                            <Separator/>

                            <MenuItem Header="Add New User" Command="{Binding AddUserCommand}"/>
                            <MenuItem Header="Edit" Command="{Binding EditUserCommand}"/>
                            <MenuItem Header="Delete" Command="{Binding DeleteUserCommand}"/>

                            <MenuItem Header="Change Password" Command="{Binding ChangePasswordCommand}"/>

                            <Separator/>

                            <MenuItem Header="Send Email" Command="{Binding SendEmailCommand}"/>
                            <MenuItem Header="Phone Call" Command="{Binding PhoneCallCommand}"/>

                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</Page>
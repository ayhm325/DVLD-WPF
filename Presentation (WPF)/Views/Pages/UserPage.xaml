<Page x:Class="Presentation.Views.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="UserPage"
      Background="Cornsilk">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- الجزء العلوي: العنوان وزر الإضافة -->
        <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Users Management" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <TextBlock Text=" (" FontSize="18" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <TextBlock Text="{Binding UsersCount}" FontSize="18" FontWeight="Bold" Foreground="#3498DB" VerticalAlignment="Center"/>
                    <TextBlock Text=")" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="+ Add New User" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Command="{Binding AddNewUserCommand}" 
                        Width="140" Height="35" 
                        HorizontalAlignment="Right" 
                        Background="OliveDrab"/>
            </DockPanel>
        </Border>

        <!-- الجزء السفلي: الفلاتر والـ DataGrid -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- شريط الفلاتر والبحث -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ComboBox ItemsSource="{Binding FilterOptions}" 
                        SelectedItem="{Binding SelectedFilterType}" 
                        Width="120" Height="30" Margin="0,0,10,0"/>

                    <Grid Width="200" Margin="0,0,10,0">
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            Height="30" Padding="5,0"
                            Visibility="{Binding IsSearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <ComboBox ItemsSource="{Binding StatusOptions}" 
                            SelectedItem="{Binding SelectedStatus}" 
                            Height="30"
                            Visibility="{Binding IsStatusVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </StackPanel>

                <!-- الـ DataGrid الكامل مع القائمة المنسدلة المرتبة بالأيقونات -->
                <DataGrid x:Name="dgUsers"
                          Grid.Row="1"
                          ItemsSource="{Binding Users}" 
                          SelectedItem="{Binding SelectedUser}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          CanUserAddRows="False" 
                          GridLinesVisibility="All"
                          RowBackground="White" 
                          AlternatingRowBackground="#F9FAFB" 
                          BorderBrush="#D0D7DE" 
                          BorderThickness="1">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="60"/>
                        <DataGridTextColumn Header="User Name" Binding="{Binding UserName}" Width="150"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding IsActive}" Width="100"/>
                    </DataGrid.Columns>

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Show Details" Command="{Binding ShowDetailsCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 1,1 4,12A8,8 0 0,1 12,4M11,16V10H13V16H11M11,6V8H13V6H11Z" Fill="Black" Stretch="Uniform" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator />

                            <MenuItem Header="Add New User" Command="{Binding AddUserCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="Green" Stretch="Uniform" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Edit" Command="{Binding EditUserCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="Blue" Stretch="Uniform" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Delete" Command="{Binding DeleteUserCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="Red" Stretch="Uniform" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Change Password" Command="{Binding ChangePasswordCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M18,8H17V6A5,5 0 0,0 12,1A5,5 0 0,0 7,6V8H6A2,2 0 0,0 4,10V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V10A2,2 0 0,0 18,8M12,17A2,2 0 0,1 10,15A2,2 0 0,1 12,13A2,2 0 0,1 14,15A2,2 0 0,1 12,17M15,8H9V6A3,3 0 0,1 12,3A3,3 0 0,1 15,6V8Z" Fill="Orange" Stretch="Uniform" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator />

                            <MenuItem Header="Send Email" Command="{Binding SendEmailCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4M20,8L12,13L4,8V6L12,11L20,6V8Z" Fill="Purple" Stretch="Uniform" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Phone Call" Command="{Binding PhoneCallCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" Fill="DarkCyan" Stretch="Uniform" Width="16" Height="16"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
<Page x:Class="Presentation.Views.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"     
      mc:Ignorable="d"
      Title="UserPage"
      Background="{StaticResource BackgroundColor}">

    <Page.Resources>

        <!-- ===================== CONVERTER ===================== -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ===================== COLORS ===================== -->
        <SolidColorBrush x:Key="AlternatingRowBrush" Color="#111114"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#1A1A1E"/>
        <SolidColorBrush x:Key="SelectedRowBg" Color="#042F2E"/>

        <SolidColorBrush x:Key="IconSuccess" Color="#34D399"/>
        <SolidColorBrush x:Key="IconOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="IconAccent" Color="#0D9488"/>
        <SolidColorBrush x:Key="IconLight" Color="#2DD4BF"/>

        <!-- ===================== DATA GRID STYLE ===================== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource AlternatingRowBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="45"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== HEADER ===================== -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,20">
            <DockPanel LastChildFill="False">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                    <TextBlock Text="Users Management" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Text=" (" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center" Margin="5,0,0,0"/>
                    <TextBlock Text="{Binding UsersCount}" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource PrimaryColor}" VerticalAlignment="Center"/>
                    <TextBlock Text=")" Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="+ Add New User"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding AddNewUserCommand}"
                        Width="150"
                        DockPanel.Dock="Right"/>

            </DockPanel>
        </Border>

        <!-- ===================== MAIN ===================== -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ===================== FILTER ===================== -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                    <TextBlock Text="Filter by:"
                              VerticalAlignment="Center"
                              Margin="0,0,10,0"
                              Style="{StaticResource LabelStyle}"/>

                    <ComboBox ItemsSource="{Binding FilterOptions}"
                              SelectedItem="{Binding SelectedFilterType}"
                              Width="140"
                              Margin="0,0,15,0"/>

                    <!-- FIXED FILTER AREA -->
                    <Grid Width="220">

                        <!-- SEARCH TEXT -->
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- STATUS FILTER -->
                        <ComboBox ItemsSource="{Binding StatusOptions}"
                                  SelectedItem="{Binding SelectedStatus}"
                                  VerticalAlignment="Center"
                                  Visibility="{Binding IsStatusVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    </Grid>

                </StackPanel>

                <!-- ===================== DATA GRID ===================== -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Users}"
                          SelectedItem="{Binding SelectedUser}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User ID" Binding="{Binding UserId}" Width="90" />
                        <DataGridTextColumn Header="Person ID" Binding="{Binding PersonId}" Width="90"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="User Name" Binding="{Binding UserName}" Width="150"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding IsActive}" Width="100"/>
                    </DataGrid.Columns>

                    <!-- CONTEXT MENU -->
                    <DataGrid.ContextMenu>
                        <ContextMenu>

                            <MenuItem Header="Show Details" Command="{Binding ShowDetailsCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 1,1 4,12A8,8 0 0,1 12,4M11,16V10H13V16H11M11,6V8H13V6H11Z" 
                                          Fill="{StaticResource PrimaryColor}" Stretch="Uniform" Width="18" Height="18"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator/>

                            <MenuItem Header="Add New User" Command="{Binding AddUserCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" 
                                          Fill="{StaticResource IconSuccess}" Stretch="Uniform" Width="18" Height="18"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Edit" Command="{Binding EditUserCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" 
                                          Fill="{StaticResource IconOrange}" Stretch="Uniform" Width="18" Height="18"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Delete" Command="{Binding DeleteUserCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                          Fill="{StaticResource ErrorColor}" Stretch="Uniform" Width="18" Height="18"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Change Password" Command="{Binding ChangePasswordCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M12,17C10.89,17 10,16.1 10,15C10,13.89 10.89,13 12,13A2,2 0 0,1 14,15A2,2 0 0,1 12,17M18,8H17V6A5,5 0 0,0 7,6V8H6A1,1 0 0,0 5,9V19A1,1 0 0,0 6,20H18A1,1 0 0,0 19,19V9A1,1 0 0,0 18,8M9,8V6A3,3 0 0,1 15,6V8H9Z" 
                                          Fill="{StaticResource IconAccent}" Stretch="Uniform" Width="18" Height="18"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <Separator/>

                            <MenuItem Header="Send Email" Command="{Binding SendEmailCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4M20,8L12,13L4,8V6L12,11L20,6V8Z" 
                                          Fill="{StaticResource IconAccent}" Stretch="Uniform" Width="18" Height="18"/>
                                </MenuItem.Icon>
                            </MenuItem>

                            <MenuItem Header="Phone Call" Command="{Binding PhoneCallCommand}">
                                <MenuItem.Icon>
                                    <Path Data="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" 
                                          Fill="{StaticResource IconLight}" Stretch="Uniform" Width="18" Height="18"/>
                                </MenuItem.Icon>
                            </MenuItem>

                        </ContextMenu>
                    </DataGrid.ContextMenu>

                </DataGrid>

            </Grid>

        </Border>
    </Grid>

</Page>
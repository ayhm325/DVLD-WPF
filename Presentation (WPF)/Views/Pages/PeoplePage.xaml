<Page x:Class="Presentation.Views.PeoplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="PeoplePage"
      Background="#F5F6FA">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 🔵 Header -->
        <Border Background="White"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,10"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <DockPanel>

                <!-- Title + Count -->
                <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center">

                    <TextBlock Text="People Management"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   VerticalAlignment="Center"/>

                    <TextBlock Text="("
                   FontSize="18"
                   Margin="8,0,0,0"
                   VerticalAlignment="Center"/>

                    <TextBlock x:Name="txtPeopleCount"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#3498DB"
                   VerticalAlignment="Center"/>

                    <TextBlock Text=")"
                   FontSize="18"
                   VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="+ Add Person"
            Width="120"
            Height="35"
            HorizontalAlignment="Right"
            Background="#3498DB"
            Foreground="White"
            BorderThickness="0"
            Cursor="Hand"
            Click="AddPerson_Click"/>

            </DockPanel>

        </Border>

        <!-- 🔴 Content -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="10"
                BorderBrush="#E0E0E0"
                BorderThickness="1">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 🔍 Filter Section -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,10">

                    <!-- Filter Type -->
                    <ComboBox x:Name="cbFilterType"
                              Width="150"
                              Height="30"
                              Margin="0,0,10,0"
                              SelectionChanged="cbFilterType_SelectionChanged">

                        <ComboBoxItem Content="None" IsSelected="True"/>
                        <ComboBoxItem Content="National No"/>
                        <ComboBoxItem Content="Name"/>
                        <ComboBoxItem Content="Gender"/>

                    </ComboBox>

                    <!-- Text Search -->
                    <TextBox x:Name="txtSearch"
                             Width="200"
                             Height="30"
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             Visibility="Collapsed"
                             TextChanged="txtSearch_TextChanged">
                        
                    </TextBox>
                             
                    

                    <!-- Gender Combo -->
                    <ComboBox x:Name="cbGender"
                              Width="120"
                              Height="30"
                              Visibility="Collapsed"
                              SelectionChanged="cbGender_SelectionChanged">

                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Male"/>
                        <ComboBoxItem Content="Female"/>

                    </ComboBox>

                </StackPanel>

                <!-- 📊 DataGrid -->
                <DataGrid x:Name="dgPeople"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="All"
                          RowBackground="White"
                          AlternatingRowBackground="#F9FAFB"
                          BorderBrush="#D0D7DE"
                          BorderThickness="1">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID" Binding="{Binding PersonId}" Width="60"/>
                        <DataGridTextColumn Header="National No" Binding="{Binding NationalNo}" Width="100"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Date Of Birth" Binding="{Binding DateOfBirth}" Width="120"/>
                        <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="250"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="120"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</Page>
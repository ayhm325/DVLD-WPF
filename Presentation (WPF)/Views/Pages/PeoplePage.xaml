<Page x:Class="Presentation.Views.PeoplePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="PeoplePage"
      Background="Cornsilk">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- الجزء العلوي: العنوان وزر الإضافة -->
        <Border Background="White" CornerRadius="8" Padding="10" Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="People Management" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    <TextBlock Text=" (" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PeopleCount}" FontSize="18" FontWeight="Bold" Foreground="#3498DB" VerticalAlignment="Center"/>
                    <TextBlock Text=")" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="+ Add Person" Style="{StaticResource PrimaryButtonStyle}" Width="120" Height="35" HorizontalAlignment="Right" Background="OliveDrab" Foreground="White" BorderThickness="0" Cursor="Hand" Click="AddPerson_Click"/>
            </DockPanel>
        </Border>

        <!-- الجزء السفلي: الفلاتر والـ DataGrid -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- شريط الفلاتر والبحث -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ComboBox ItemsSource="{Binding FilterTypes}"
                              SelectedItem="{Binding SelectedFilterType}"
                              Width="150" Height="30" Margin="0,0,10,0"/>

                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding SearchToolTip}"
                             Visibility="{Binding IsSearchTextVisible, Converter={StaticResource BoolToVis}}"
                             Width="200" Height="30" Padding="5,0" />

                    <ComboBox ItemsSource="{Binding GenderOptions}"
                              SelectedItem="{Binding SelectedGender}"
                              Visibility="{Binding IsGenderComboVisible, Converter={StaticResource BoolToVis}}"
                              Width="120" Height="30"/>
                </StackPanel>

                <!-- الـ DataGrid الكامل مع القائمة المنسدلة المرتبة بالأيقونات -->
                <DataGrid x:Name="dgPeople"
                          ItemsSource="{Binding FilteredPeople}"
                          Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" SelectionMode="Single" GridLinesVisibility="All" RowBackground="White" AlternatingRowBackground="#F9FAFB" BorderBrush="#D0D7DE" BorderThickness="1">

                    <!-- إضافة الـ ContextMenu لكل سطر في الجدول بربط صحيح -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu Background="White" BorderBrush="#CBD5E0" BorderThickness="1">

                                        <MenuItem Header="Show Details" 
                              Command="{Binding PlacementTarget.Tag.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <Path Data="M12,2A10,10 0 1,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 1,1 4,12A8,8 0 0,1 12,4M11,16V10H13V16H11M11,6V8H13V6H11Z" 
                                  Fill="Black" Stretch="Uniform" Width="16" Height="16"/>
                                            </MenuItem.Icon>
                                        </MenuItem>

                                        <Separator BorderBrush="#E2E8F0" BorderThickness="0.5"/>

                                        <MenuItem Header="Add New Person" 
                              Command="{Binding PlacementTarget.Tag.AddNewPersonCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" 
                                  Fill="Green" Stretch="Uniform" Width="16" Height="16"/>
                                            </MenuItem.Icon>
                                        </MenuItem>

                                        <MenuItem Header="Edit" 
                              Command="{Binding PlacementTarget.Tag.EditPersonCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" 
                                  Fill="Blue" Stretch="Uniform" Width="16" Height="16"/>
                                            </MenuItem.Icon>
                                        </MenuItem>

                                        <MenuItem Header="Delete" 
                              Command="{Binding PlacementTarget.Tag.DeletePersonCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Foreground="#E53E3E">
                                            <MenuItem.Icon>
                                                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                  Fill="Red" Stretch="Uniform" Width="16" Height="16"/>
                                            </MenuItem.Icon>
                                        </MenuItem>

                                        <Separator BorderBrush="#E2E8F0" BorderThickness="0.5"/>

                                        <MenuItem Header="Send Email" 
                              Command="{Binding PlacementTarget.Tag.SendEmailCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <Path Data="M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.1,4 20,4M20,8L12,13L4,8V6L12,11L20,6V8Z" 
                                  Fill="Purple" Stretch="Uniform" Width="16" Height="16"/>
                                            </MenuItem.Icon>
                                        </MenuItem>

                                        <MenuItem Header="Phone Call" 
                              Command="{Binding PlacementTarget.Tag.PhoneCallCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                            <MenuItem.Icon>
                                                <Path Data="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z" 
                                  Fill="DarkCyan" Stretch="Uniform" Width="16" Height="16"/>
                                            </MenuItem.Icon>
                                        </MenuItem>

                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- أعمدة الجدول -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding PersonId}" Width="60"/>
                        <DataGridTextColumn Header="National No" Binding="{Binding NationalNo}" Width="100"/>
                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Date Of Birth" Binding="{Binding DateOfBirth, StringFormat=\{0:dd/MM/yyyy\}}" Width="120"/>
                        <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                        <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="250"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        <DataGridTextColumn Header="Country" Binding="{Binding CountryName}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
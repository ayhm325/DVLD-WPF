<Page x:Class="Presentation.Views.Pages.LDLAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Presentation.Views.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="Driving License Applications"
      Background="{StaticResource BackgroundColor}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Local Driving License Applications " Style="{StaticResource HeaderStyle}"/>
            <TextBlock Text="{Binding Applications.Count, StringFormat='({0})'}" 
                       Style="{StaticResource HeaderStyle}" Foreground="#64748B" Margin="5,0,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Filter by:" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Width="150" Margin="0,0,10,0" SelectedIndex="0" SelectedItem="{Binding SelectedFilter, Mode=TwoWay}">
                    <ComboBoxItem Content="Full Name"/>
                    <ComboBoxItem Content="National No."/>
                </ComboBox>
                <TextBox Width="220" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="2" Content="+ Add New" Style="{StaticResource PrimaryButtonStyle}" 
                    Command="{Binding AddNewCommand}" Width="140" HorizontalAlignment="Right" />
        </Grid>

        <DataGrid Grid.Row="3" 
          ItemsSource="{Binding Applications}" 
          SelectedItem="{Binding SelectedApplication}"
          AutoGenerateColumns="False" 
          IsReadOnly="True" 
          GridLinesVisibility="Horizontal"
          BorderThickness="0"
          Background="White"
          RowBackground="White"
          AlternatingRowBackground="#F8FAFC"
          HeadersVisibility="Column"
          HorizontalGridLinesBrush="{StaticResource BorderColor}">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="40"/>

                    <!-- 1. حفظ الـ ViewModel في Tag -->
                    <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"/>

                    <!-- 2. تفعيل التحديد عند الضغط بالزر الأيمن -->
                    <EventSetter Event="MouseRightButtonDown" Handler="DataGridRow_MouseRightButtonDown"/>

                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <!-- ContextMenu يحتوي على بيانات الصف (DTO) كـ DataContext -->
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">

                                <!-- التعديل الأساسي: إضافة RelativeSource للبحث عن PlacementTarget داخل الـ ContextMenu وليس داخل الـ DTO -->

                                <MenuItem Header="Show Application Details" 
                                          Command="{Binding PlacementTarget.Tag.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Icon>
                                        <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Fill="#3B82F6" Stretch="Uniform" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>

                                <Separator/>

                                <MenuItem Header="Edit Application" 
                                          Command="{Binding PlacementTarget.Tag.EditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Icon>
                                        <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z" Fill="#F59E0B" Stretch="Uniform" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>

                                <MenuItem Header="Delete Application" 
                                          Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" 
                                          CommandParameter="{Binding ApplicationID}">
                                    <MenuItem.Icon>
                                        <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#EF4444" Stretch="Uniform" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>

                                <MenuItem Header="Cancel Application"
                                            Command="{Binding PlacementTarget.Tag.CancelCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                            CommandParameter="{Binding ApplicationID}" >
                                    <MenuItem.Icon>
                                        <Path Data="M12,2C17.5,2 22,6.5 22,12S17.5,22 12,22 2,17.5 2,12 6.5,2 12,2M12,4C10.1,4 8.4,4.6 7.1,5.7L18.3,16.9C19.3,15.6 20,13.9 20,12C20,7.6 16.4,4 12,4M16.9,18.3L5.7,7.1C4.6,8.4 4,10.1 4,12C4,16.4 7.6,20 12,20C13.9,20 15.6,19.3 16.9,18.3Z" Fill="#64748B" Stretch="Uniform" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>

                                <Separator/>

                                <MenuItem Header="Schedule Tests">
                                    <MenuItem.Icon>
                                        <Path Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,11H12V16H17V11Z" Fill="#8B5CF6" Stretch="Uniform" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                    <MenuItem Header="Schedule Vision Test" 
                                              Command="{Binding PlacementTarget.Tag.ScheduleVisionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Fill="#3B82F6" Width="16" Height="16"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Schedule Written Test" 
                                              Command="{Binding PlacementTarget.Tag.ScheduleWrittenCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2Z" Fill="#F59E0B" Width="16" Height="16"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Schedule Street Test" 
                                              Command="{Binding PlacementTarget.Tag.ScheduleStreetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M18.92,6.01C18.72,5.42 18.16,5 17.5,5H15V3H9V5H6.5C5.84,5 5.28,5.42 5.08,6.01L2,15V21H22V15L18.92,6.01Z" Fill="#EF4444" Width="16" Height="16"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuItem>

                                <Separator/>

                                <MenuItem Header="Issue Driving License" 
                                          Command="{Binding PlacementTarget.Tag.IssueLicenseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Show License" 
                                          Command="{Binding PlacementTarget.Tag.ShowLicenseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                <MenuItem Header="Show Person License History" 
                                          Command="{Binding PlacementTarget.Tag.ShowHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                    <MenuItem.Icon>
                                        <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L8.89,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.06,19 9.3,18.21 8.08,16.92L6.64,18.36C8.25,20 10.47,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3M12,8V12L15.28,13.94L16.05,12.66L13,10.8V8H12Z" Fill="#10B981" Stretch="Uniform" Width="16" Height="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F1F5F9"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ApplicationID}" Width="75"/>
                <DataGridTextColumn Header="Driving Class" Binding="{Binding DrivingClass}" Width="350"/>
                <DataGridTextColumn Header="National No." Binding="{Binding NationalNo}" Width="150"/>
                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Date" Binding="{Binding ApplicationDate, StringFormat=yyyy/MM/dd}" Width="150"/>
                <DataGridTextColumn Header="Passed Test" Binding="{Binding PassedTest}" Width="150"/>
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
<Page x:Class="Presentation.Views.Pages.ListDetainedLicenses"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Presentation.Views.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="List Detained Licenses"
      Background="{StaticResource BackgroundColor}">

    <Page.Resources>
        <!-- ألوان الجدول مطابقة للوحة الألوان العامة -->
        <SolidColorBrush x:Key="AlternatingRowBrush" Color="#111114"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#1A1A1E"/>
        <SolidColorBrush x:Key="SelectedRowBg" Color="#042F2E"/>

        <!-- ألوان دلالية للأيقونات -->
        <SolidColorBrush x:Key="IconOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="IconGreen" Color="#34D399"/>

        <!-- ستايل الجدول -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource AlternatingRowBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <!-- ستايل عناوين الأعمدة -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ستايل الخلايا -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- تسمية الفلتر -->
        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="List Detained Licenses " Style="{StaticResource HeaderStyle}"/>
            <TextBlock Text="{Binding DetainedLicenses.Count, StringFormat='({0})'}" 
                       Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" Margin="5,0,0,0"/>
        </StackPanel>

        <!-- Filter Bar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Filter by:" Style="{StaticResource FilterLabelStyle}" Margin="0,0,10,0"/>

                <ComboBox Width="130" 
                          Margin="0,0,10,0" 
                          ItemsSource="{Binding FilterOptions}" 
                          SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                          VerticalAlignment="Center"/>

                <!-- TextBox يظهر لكل الفلاتر ماعدا Is Released -->
                <TextBox Width="180" 
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="0,0,10,0"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsSearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- ComboBox يظهر فقط عندما يختار Is Released -->
                <ComboBox Width="130" 
                          Margin="0,0,10,0" 
                          ItemsSource="{Binding ReleaseFilterOptions}" 
                          SelectedItem="{Binding SelectedReleaseFilter, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          Visibility="{Binding IsReleaseFilterVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Detain" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Command="{Binding DetainCommand}" 
                        Width="120" 
                        Margin="0,0,10,0"/>
                <Button Content="Release" 
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Command="{Binding ReleaseDetainCommand}" 
                        Width="120"/>
            </StackPanel>
        </Grid>

        <!-- DataGrid Card Container -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding DetainedLicenses}" 
                      SelectedItem="{Binding SelectedDetainedLicense}">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Height" Value="45"/>

                        <!-- حفظ الـ ViewModel في Tag -->
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"/>

                        <!-- تفعيل التحديد عند الضغط بالزر الأيمن -->
                        <EventSetter Event="MouseRightButtonDown" Handler="DataGridRow_MouseRightButtonDown"/>

                        <!-- Context Menu -->
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">

                                    <MenuItem Header="Show Person Details" 
                                              Command="{Binding PlacementTarget.Tag.ShowPersonDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" 
                                                  Fill="{StaticResource PrimaryColor}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Show License Details" 
                                              Command="{Binding PlacementTarget.Tag.ShowLicenseDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6M18,12H16V14H18V12M14,12H12V14H14V12M10,12H8V14H10V12Z" 
                                                  Fill="{StaticResource IconOrange}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Show Person License History" 
                                              Command="{Binding PlacementTarget.Tag.ShowPersonLicenseHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L8.89,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.06,19 9.3,18.21 8.08,16.92L6.64,18.36C8.25,20 10.47,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3M12,8V12L15.28,13.94L16.05,12.66L13,10.8V8H12Z" 
                                                  Fill="{StaticResource IconGreen}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator/>

                                    <MenuItem Header="Release Detained License"
                                                Command="{Binding PlacementTarget.Tag.ReleaseDetainedLicenseCommand,
                                                RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,2C17.5,2 22,6.5 22,12S17.5,22 12,22 2,17.5 2,12 6.5,2 12,2M12,4C10.1,4 8.4,4.6 7.1,5.7L18.3,16.9C19.3,15.6 20,13.9 20,12C20,7.6 16.4,4 12,4M16.9,18.3L5.7,7.1C4.6,8.4 4,10.1 4,12C4,16.4 7.6,20 12,20C13.9,20 15.6,19.3 16.9,18.3Z" 
                                                  Fill="{StaticResource ErrorColor}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                </ContextMenu>
                            </Setter.Value>
                        </Setter>

                        <!-- تفاعلات الصفوف -->
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Detain ID" Binding="{Binding DetainID}" Width="90"/>
                    <DataGridTextColumn Header="License ID" Binding="{Binding LicenseID}" Width="90"/>
                    <DataGridTextColumn Header="Detain Date" Binding="{Binding DetainDate, StringFormat=dd/MM/yyyy hh:mm tt}" Width="160"/>
                    <DataGridTextColumn Header="Is Released" Binding="{Binding IsReleasedText}" Width="100"/>
                    <DataGridTextColumn Header="Fine Fees" Binding="{Binding FineFees}" Width="100"/>
                    <DataGridTextColumn Header="Release Date" Binding="{Binding ReleaseDate, StringFormat=dd/MM/yyyy hh:mm tt}" Width="160"/>
                    <DataGridTextColumn Header="National No" Binding="{Binding NationalNo}" Width="140"/>
                    <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="Release App ID" Binding="{Binding ReleaseApplicationID}" Width="140"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>
</Page>
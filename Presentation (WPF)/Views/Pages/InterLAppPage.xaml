<Page x:Class="Presentation.Views.Pages.InterLAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:Presentation.Views.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="International License Applications"
      Background="{StaticResource BackgroundColor}">

    <Page.Resources>
        <!-- ألوان الجدول مطابقة للوحة الألوان العامة -->
        <SolidColorBrush x:Key="AlternatingRowBrush" Color="#111114"/>
        <SolidColorBrush x:Key="HoverBrush" Color="#1A1A1E"/>
        <SolidColorBrush x:Key="SelectedRowBg" Color="#042F2E"/>

        <!-- ألوان دلالية للأيقونات -->
        <SolidColorBrush x:Key="IconOrange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="IconGreen" Color="#34D399"/>

        <!-- تحويل Boolean إلى نص/رمز -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ستايل الجدول -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource AlternatingRowBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <!-- ستايل عناوين الأعمدة -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ستايل الخلايا -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                    <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- تسمية الفلتر -->
        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="International Driving License Applications " Style="{StaticResource HeaderStyle}"/>
            <TextBlock Text="{Binding Applications.Count, StringFormat='({0})'}" 
                       Style="{StaticResource HeaderStyle}" Foreground="{StaticResource SecondaryTextColor}" Margin="5,0,0,0"/>
        </StackPanel>

        <!-- Filter Bar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Filter by:" Style="{StaticResource FilterLabelStyle}" Margin="0,0,10,0"/>

                <ComboBox Width="170"
                    Margin="0,0,10,0"
                    ItemsSource="{Binding Filters}"
                    SelectedItem="{Binding SelectedFilter, Mode=TwoWay}" />

                <TextBox Width="180" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0" VerticalAlignment="Center"/>
            </StackPanel>

            <Button Grid.Column="1" Content="+ Issue New" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Command="{Binding IssueNewCommand}" 
                    Width="140" 
                    HorizontalAlignment="Right"/>
        </Grid>

        <!-- DataGrid Card Container -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Applications}" 
                      SelectedItem="{Binding SelectedApplication}">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Height" Value="45"/>

                        <!-- حفظ الـ ViewModel في Tag -->
                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Page}}"/>

                        <!-- تفعيل التحديد عند الضغط بالزر الأيمن -->
                        <EventSetter Event="MouseRightButtonDown" Handler="DataGridRow_MouseRightButtonDown"/>

                        <!-- Context Menu -->
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">

                                    <MenuItem Header="Show Person Details" 
                                              Command="{Binding PlacementTarget.Tag.ShowPersonDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" 
                                                  Fill="{StaticResource PrimaryColor}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Show License Details" 
                                              Command="{Binding PlacementTarget.Tag.ShowLicenseDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" 
                                                  Fill="{StaticResource IconGreen}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <MenuItem Header="Show Person License History" 
                                              Command="{Binding PlacementTarget.Tag.ShowPersonLicenseHistoryCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <Path Data="M13,3A9,9 0 0,0 4,12H1L4.89,15.89L8.89,12H6A7,7 0 0,1 13,5A7,7 0 0,1 20,12A7,7 0 0,1 13,19C11.06,19 9.3,18.21 8.08,16.92L6.64,18.36C8.25,20 10.47,21 13,21A9,9 0 0,0 22,12A9,9 0 0,0 13,3M12,8V12L15.28,13.94L16.05,12.66L13,10.8V8H12Z" 
                                                  Fill="{StaticResource IconOrange}" Stretch="Uniform" Width="18" Height="18"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                </ContextMenu>
                            </Setter.Value>
                        </Setter>

                        <!-- تفاعلات الصفوف -->
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource SelectedRowBg}"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!-- Int License ID -->
                    <DataGridTextColumn Header="Int License ID" 
                                        Binding="{Binding InternationalLicenseID}" 
                                        Width="130"/>

                    <!-- Application ID -->
                    <DataGridTextColumn Header="Application ID" 
                                        Binding="{Binding ApplicationID}" 
                                        Width="130"/>

                    <!-- Driver ID -->
                    <DataGridTextColumn Header="Driver ID" 
                                        Binding="{Binding DriverID}" 
                                        Width="100"/>

                    <!-- L.License ID -->
                    <DataGridTextColumn Header="L.License ID" 
                                        Binding="{Binding IssuedUsingLocalLicenseID}" 
                                        Width="120"/>

                    <!-- Issue Date -->
                    <DataGridTextColumn Header="Issue Date" 
                                        Binding="{Binding IssueDate, StringFormat='MM/dd/yyyy hh:mm tt'}" 
                                        Width="180"/>

                    <!-- Expiration Date -->
                    <DataGridTextColumn Header="Expiration Date" 
                                        Binding="{Binding ExpirationDate, StringFormat='MM/dd/yyyy hh:mm tt'}" 
                                        Width="190"/>

                    <!-- Is Active -->
                    <DataGridTemplateColumn Header="Is Active" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="√" 
                                           FontWeight="Bold" 
                                           FontSize="16"
                                           Foreground="{StaticResource IconGreen}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

            </DataGrid>
        </Border>
    </Grid>
</Page>
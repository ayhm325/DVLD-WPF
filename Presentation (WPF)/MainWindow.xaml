<Window x:Class="DVLD_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVLD System" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}"       
        ResizeMode="CanResize">

    <!-- ═══════ موارد على مستوى النافذة ═══════ -->
    <Window.Resources>
        <!-- حركة وميض مؤشر الكاتبة (منقول هنا لحل مشكلة البحث) -->
        <Storyboard x:Key="CursorBlinkStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation 
                Storyboard.TargetName="TypewriterCursor" 
                Storyboard.TargetProperty="Opacity" 
                From="1" To="0" 
                Duration="0:0:0.5" 
                AutoReverse="True"/>
        </Storyboard>
    </Window.Resources>

    <!-- حاوية رئيسية مع حدود النافذة -->
    <Border BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">

        <DockPanel>

            <!-- ═══════════════ شريط العنوان المخصص ═══════════════ -->
            <Border DockPanel.Dock="Top" 
                    Background="{StaticResource CardBackground}" 
                    Height="40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <Border Width="8" Height="8" 
                                CornerRadius="4" 
                                Background="{StaticResource PrimaryColor}" 
                                Margin="0,0,10,0" 
                                VerticalAlignment="Center"/>
                        <TextBlock Text="DVLD System" 
                                   FontSize="13" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════ القائمة العلوية ═══════════════ -->
            <Menu DockPanel.Dock="Top" 
                  Background="{StaticResource CardBackground}" 
                  Padding="10,5">

                <MenuItem Header="Applications">
                    <MenuItem Header="Driving Licenses Services">
                        <MenuItem Header="New Driving License">
                            <MenuItem Header="Local License" Click="NewLocalLicnnse_Click"/>
                            <MenuItem Header="International License" Click="InternationalLicense_Click"/>
                        </MenuItem>
                        <MenuItem Header="Renew Driving License"  Click="RenewDrivingLicense_Click"/>
                        <Separator/>
                        <MenuItem Header="Replacement for Lost or Damaged" Click="ReplacementForLostOrDamaged_Click"/>
                        <Separator/>
                        <MenuItem Header="Release Detained Driving License" Click="ReleaseDetainedDrivingLicense_Click"/>
                        <MenuItem Header="Retake Test" Click="RetakeTest_Click"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Manage Applications">
                        <MenuItem Header="Local Driving License Applications" Click="LocalDrivingLicenseApplications_Click"/>
                        <MenuItem Header="International License Applications" Click="InternationalLicenseApplications_Click"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Detain Licenses">
                        <MenuItem Header="Manage Detained Licenses" Click="ManageDetainedLicenses_Click"/>
                        <MenuItem Header="Detain License" Click="DetainLicense_Click"/>
                        <MenuItem Header="Release Detained License" Click="ReleaseDetainedLicense_Click"/>
                    </MenuItem>
                    <MenuItem Header="Manage Application Types" Click="ApplicationType_Click"/>
                    <MenuItem Header="Manage Test Types" Click="TestType_Click"/>
                </MenuItem>

                <MenuItem Header="People" Click="ManagePeople_Click"/>
                <MenuItem Header="Drivers" Click="Drivers_Click"/>
                <MenuItem Header="Users" Click="Users_Click"/>
                <MenuItem Header="Account Settings">
                    <MenuItem Header="Current User Info" Click="CurrentUser_Click"/>
                    <MenuItem Header="Change Password" Click="ChangePassword_Click"/>
                    <Separator/>
                    <MenuItem Header="Sign Out" Click="SignOut_Click"/>
                </MenuItem>
            </Menu>

            <!-- فاصل أسفل القائمة -->
            <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BorderColor}"/>

            <!-- ═══════════════ منطقة عرض الصفحات والشاشة الفارغة ═══════════════ -->
            <Grid x:Name="ContentArea">

                <!-- إطار عرض الصفحات -->
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

                <!-- ═══════ لوحة المعلومات الاحترافية ═══════ -->
                <Grid x:Name="EmptyStatePlaceholder">

                    <Grid.Resources>

                        <!-- نمط بطاقة الإحصائية -->
                        <Style x:Key="StatCardStyle" TargetType="Border">
                            <Setter Property="Background" Value="#141419"/>
                            <Setter Property="BorderBrush" Value="#2A2A35"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="CornerRadius" Value="14"/>
                            <Setter Property="Padding" Value="22,18"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="#4F46E5"/>
                                    <Setter Property="Background" Value="#1A1A2E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- نمط نص التذييل -->
                        <Style x:Key="FooterLinkStyle" TargetType="TextBlock">
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Foreground" Value="#4F46E5"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#818CF8"/>
                                    <Setter Property="TextDecorations" Value="Underline"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!-- حركة النبض للتوهج -->
                        <Storyboard x:Key="PulseGlowStoryboard" RepeatBehavior="Forever">
                            <DoubleAnimation 
                                Storyboard.TargetName="GlowEffect" 
                                Storyboard.TargetProperty="Opacity" 
                                From="0.25" To="0.55" 
                                Duration="0:0:4" 
                                AutoReverse="True">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>

                    </Grid.Resources>

                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource PulseGlowStoryboard}"/>
                        </EventTrigger>
                    </Grid.Triggers>

                    <!-- ═══════ طبقة الجسيمات المتحركة ═══════ -->
                    <Canvas x:Name="ParticleCanvas" 
                            ClipToBounds="True" 
                            IsHitTestVisible="False"/>

                    <!-- ═══════ خلفية هندسية دائرية ═══════ -->
                    <Ellipse Width="400" Height="400" 
                             Stroke="#2A2A35" StrokeThickness="0.5" 
                             StrokeDashArray="4 4" 
                             HorizontalAlignment="Center" VerticalAlignment="Center" 
                             Opacity="0.25"/>
                    <Ellipse Width="620" Height="620" 
                             Stroke="#2A2A35" StrokeThickness="0.3" 
                             StrokeDashArray="2 6" 
                             HorizontalAlignment="Center" VerticalAlignment="Center" 
                             Opacity="0.12"/>
                    <Ellipse Width="850" Height="850" 
                             Stroke="#2A2A35" StrokeThickness="0.2" 
                             StrokeDashArray="1 8" 
                             HorizontalAlignment="Center" VerticalAlignment="Center" 
                             Opacity="0.06"/>

                    <!-- ═══════ التوهج المركزي ═══════ -->
                    <Ellipse x:Name="GlowEffect" 
                             Width="600" Height="600" 
                             HorizontalAlignment="Center" VerticalAlignment="Center" 
                             IsHitTestVisible="False">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#1A4F46E5" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- ═══════ المحتوى الرئيسي ═══════ -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="MainContent" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center" 
                                    MaxWidth="960" 
                                    Margin="30,25"
                                    Opacity="0">

                            <!-- ──── قسم الهيدر ──── -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,35">

                                <!-- أيقونة البرنامج -->
                                <Border Width="100" Height="100" 
                                        CornerRadius="24" 
                                        Background="#0F0F14" 
                                        BorderBrush="#4F46E5" 
                                        BorderThickness="1.5" 
                                        Margin="0,0,0,28" 
                                        HorizontalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#4F46E5" 
                                                          BlurRadius="40" 
                                                          ShadowDepth="0" 
                                                          Opacity="0.5"/>
                                    </Border.Effect>
                                    <TextBlock Text="🪪" FontSize="48" 
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               Margin="0,0,0,4"/>
                                </Border>

                                <!-- العنوان الرئيسي -->
                                <TextBlock Text="DVLD System" 
                                           FontSize="32" FontWeight="Bold" 
                                           Foreground="White" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,8">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#4F46E5" 
                                                          BlurRadius="20" 
                                                          ShadowDepth="0" 
                                                          Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>

                                <!-- العنوان الفرعي -->
                                <TextBlock Text="Driving License Management" 
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#4F46E5" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,18" Opacity="0.9"/>

                                <!-- فاصل -->
                                <Rectangle Width="40" Height="2" 
                                           Fill="#4F46E5" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,18" 
                                           Opacity="0.35" 
                                           RadiusX="1" RadiusY="1"/>

                                <!-- نص تأثير الكاتبة -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TypewriterText" 
                                               Text="" FontSize="13" 
                                               Foreground="#777" 
                                               TextAlignment="Center"/>
                                    <TextBlock x:Name="TypewriterCursor" 
                                               Text="|" FontSize="13" 
                                               Foreground="#4F46E5" 
                                               Opacity="0" 
                                               Margin="-1,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- ──── قسم الإحصائيات العامة ──── -->
                            <TextBlock Text="📊  General Statistics" 
                                       FontSize="13" FontWeight="SemiBold" 
                                       Foreground="#999" Margin="0,0,0,14"/>

                            <UniformGrid Columns="4" Margin="0,0,0,28">

                                <!-- إجمالي الأشخاص -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="👥" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatTotalPeople" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Total People" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="عدد الأشخاص المسجلين" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- إجمالي السائقين -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="🚗" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatTotalDrivers" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Total Drivers" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="عدد السائقين" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- الرخص الفعالة -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="🪪" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatActiveLicenses" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Active Licenses" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="عدد الرخص الفعالة" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- الطلبات المعلقة -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="📝" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatPendingApps" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Pending Applications" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="الطلبات قيد المعالجة" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- ──── قسم إحصائيات العمليات ──── -->
                            <TextBlock Text="⚡  Operations Statistics" 
                                       FontSize="13" FontWeight="SemiBold" 
                                       Foreground="#999" Margin="0,0,0,14"/>

                            <UniformGrid Columns="4" Margin="0,0,0,38">

                                <!-- طلبات الرخص المحلية -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="📋" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatLocalDLApps" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Local DL Applications" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="عدد طلبات الرخص المحلية" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- الرخص الدولية -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="🌍" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatInternationalLicenses" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="International Licenses" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="عدد الرخص الدولية" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- الرخص المحجوزة -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="⚠️" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatDetainedLicenses" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Detained Licenses" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="عدد الرخص المحجوزة" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- الاختبارات القادمة -->
                                <Border Style="{StaticResource StatCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="🧪" FontSize="26" Margin="0,0,0,12"/>
                                        <TextBlock x:Name="StatUpcomingTests" 
                                                   Text="0" FontSize="30" 
                                                   FontWeight="Bold" Foreground="White" 
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Upcoming Tests" 
                                                   FontSize="12" Foreground="#888"/>
                                        <TextBlock Text="الاختبارات القادمة" 
                                                   FontSize="10" Foreground="#555" 
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- ──── زر البدء ──── -->
                            <Button x:Name="GetStartedBtn" 
                                    Click="GetStarted_Click" 
                                    Height="50" Width="240" 
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,38"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" 
                                                CornerRadius="12" 
                                                Background="#4F46E5" 
                                                BorderThickness="0" 
                                                Padding="24,0"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#4F46E5" 
                                                                  BlurRadius="25" 
                                                                  ShadowDepth="0" 
                                                                  Opacity="0.45"/>
                                            </Border.Effect>
                                            <StackPanel Orientation="Horizontal" 
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="🚀 " FontSize="17" 
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Get Started" 
                                                           FontSize="15" FontWeight="SemiBold" 
                                                           Foreground="White" 
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation 
                                                                Storyboard.TargetName="BtnBorder" 
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                                To="#6366F1" Duration="0:0:0.25"/>
                                                            <DoubleAnimation 
                                                                Storyboard.TargetName="BtnBorder" 
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                                To="1.05" Duration="0:0:0.2">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation 
                                                                Storyboard.TargetName="BtnBorder" 
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                                To="1.05" Duration="0:0:0.2">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ColorAnimation 
                                                                Storyboard.TargetName="BtnBorder" 
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                                To="#4F46E5" Duration="0:0:0.25"/>
                                                            <DoubleAnimation 
                                                                Storyboard.TargetName="BtnBorder" 
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                                To="1.0" Duration="0:0:0.2"/>
                                                            <DoubleAnimation 
                                                                Storyboard.TargetName="BtnBorder" 
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                                To="1.0" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- ──── التذييل ──── -->
                            <Border Height="1" Background="#2A2A35" Margin="0,0,0,14"/>
                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Center" 
                                        Margin="0,0,0,8">
                                <TextBlock Text="DVLD System v1.0" 
                                           FontSize="11" Foreground="#555" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="  •  " FontSize="11" 
                                           Foreground="#333" VerticalAlignment="Center"/>
                                <TextBlock Text="Terms &amp; Conditions" 
                                           Style="{StaticResource FooterLinkStyle}" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="  •  " FontSize="11" 
                                           Foreground="#333" VerticalAlignment="Center"/>
                                <TextBlock Text="About" 
                                           Style="{StaticResource FooterLinkStyle}" 
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="  •  " FontSize="11" 
                                           Foreground="#333" VerticalAlignment="Center"/>
                                <TextBlock Text="© 2025 DVLD" FontSize="11" 
                                           Foreground="#555" VerticalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>

                </Grid>

            </Grid>

        </DockPanel>
    </Border>
</Window>
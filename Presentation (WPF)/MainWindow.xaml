<Window x:Class="DVLD_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVLD System" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <Menu DockPanel.Dock="Top" FontSize="16" Padding="10" Background="#F0F0F0">
            <MenuItem Header="_Applications">
                <MenuItem Header="Driving Licenses Services">
                    <MenuItem Header="New Driving License">
                        <MenuItem Header="Local License" Click="NewLocalLicnnse_Click"/>
                        <MenuItem Header="International License"/>
                    </MenuItem>
                    <MenuItem Header="Renew Driving License"/>
                    <Separator/>
                    <MenuItem Header="Replacement for Lost or Damaged"/>
                    <Separator/>
                    <MenuItem Header="Release Detained Driving License"/>
                    <MenuItem Header="Retake Test"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Manage Applications"/>
                <Separator/>
                <MenuItem Header="Detin  Licenses"/>
                <MenuItem Header="Manage Application Types" Click="ApplicationType_Click"/>
                <MenuItem Header="Manage Test Types"  Click="TestType_Click"/>
            </MenuItem>

            <MenuItem Header="_People" Click="ManagePeople_Click"/>
            <MenuItem Header="_Drivers"/>
            <MenuItem Header="_Users" Click="Users_Click"/>
            <MenuItem Header="Account Settings"/>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Background="BurlyWood" Grid.Column="0">
                <TextBlock Text="MENU" Foreground="White" FontSize="30" 
                           FontFamily="Algerian" Margin="10" HorizontalAlignment="Center"/>

                <Button Content="Home" Margin="10" Click="Home_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Manage People" Margin="10" Click="ManagePeople_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Manage Users" Margin="10" Click="Users_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Application Type" Margin="10" Click="ApplicationType_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Test Type" Margin="10" Click="TestType_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="New Local License" Margin="10" Click="NewLocalLicnnse_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="L.D.L.App" Margin="10" Click="LDLApp_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>

            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
        </Grid>
    </DockPanel>
</Window>
<Window x:Class="DVLD_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVLD System" Height="500" Width="900">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 🔵 Sidebar -->
        <StackPanel Background="BurlyWood">

            <TextBlock Text="MENU"
                       Foreground="White"
                       FontSize="30"
                       FontFamily="Algerian"
                       Margin="10"/>

            <Button Content="Home" Margin="10" Click="Home_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Manage People" Margin="10" Click="ManagePeople_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Manage Users" Margin="10" Click="Users_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Application Type" Margin="10" Click="ApplicationType_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            <Button Content="Settings" Margin="10" Click="Settings_Click" Style="{StaticResource PrimaryButtonStyle}"/>

        </StackPanel>

        <!-- 🔴 Main Content -->
        <Frame x:Name="MainFrame" Grid.Column="1"/>

    </Grid>
</Window>
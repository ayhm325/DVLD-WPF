<Window x:Class="DVLD_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVLD System" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}">

    <DockPanel>
        <!-- القائمة العلوية: تطبيق CardBackground واستخدام الستايل العام للقوائم -->
        <Menu DockPanel.Dock="Top" 
              Background="{StaticResource CardBackground}" 
              Foreground="{StaticResource TextColor}"
              FontSize="14" 
              Padding="10">

            <MenuItem Header="Applications">
                <MenuItem Header="Driving Licenses Services">
                    <MenuItem Header="New Driving License">
                        <MenuItem Header="Local License" Click="NewLocalLicnnse_Click"/>
                        <MenuItem Header="International License"/>
                    </MenuItem>
                    <MenuItem Header="Renew Driving License"/>
                    <Separator/>
                    <MenuItem Header="Replacement for Lost or Damaged"/>
                    <Separator/>
                    <MenuItem Header="Release Detained Driving License"/>
                    <MenuItem Header="Retake Test"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Manage Applications"/>
                <Separator/>
                <MenuItem Header="Detin  Licenses"/>
                <MenuItem Header="Manage Application Types" Click="ApplicationType_Click"/>
                <MenuItem Header="Manage Test Types"  Click="TestType_Click"/>
            </MenuItem>

            <MenuItem Header="People" Click="ManagePeople_Click"/>
            <MenuItem Header="Drivers" Click="Drivers_Click"/>
            <MenuItem Header="Users" Click="Users_Click"/>
            <MenuItem Header="Account Settings"/>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="215*"/>
                <ColumnDefinition Width="18*"/>
                <ColumnDefinition Width="547*"/>
            </Grid.ColumnDefinitions>

            <!-- الشريط الجانبي (Sidebar) -->
            <StackPanel Grid.Column="0" Background="{StaticResource CardBackground}">
                <!-- عنوان الشريط الجانبي بتصميم عصري -->
                <TextBlock Text="MENU" 
                           Foreground="{StaticResource PrimaryColor}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           FontFamily="Segoe UI" 
                           Margin="20" 
                           HorizontalAlignment="Center"/>

                <!-- أزرار التنقل -->
                <Button Content="Home" Margin="15,5,15,5" Click="Home_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Manage People" Margin="15,5,15,5" Click="ManagePeople_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Manage Users" Margin="15,5,15,5" Click="Users_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Application Type" Margin="15,5,15,5" Click="ApplicationType_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="Test Type" Margin="15,5,15,5" Click="TestType_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="L.D.L.App" Margin="15,5,15,5" Click="LDLApp_Click" Style="{StaticResource PrimaryButtonStyle}"/>

            </StackPanel>

            <!-- فاصل بسيط بين الشريط والمحتوى -->
            <Border Grid.Column="1" Width="1" HorizontalAlignment="Left" Background="{StaticResource BorderColor}"/>

            <!-- المحتوى الرئيسي -->
            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="Transparent" Grid.ColumnSpan="3"/>
        </Grid>
    </DockPanel>
</Window>
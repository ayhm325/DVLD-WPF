<Window x:Class="DVLD_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVLD System"
        MinWidth="1100" MinHeight="700"
        Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- ═══  RESOURCES — Colors · Styles · Storyboards                ═══ -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <Window.Resources>

        <!-- ── Color System ── -->
        <SolidColorBrush x:Key="BgDark"       Color="#0B0B12"/>
        <SolidColorBrush x:Key="BgSidebar"    Color="#0E0E15"/>
        <SolidColorBrush x:Key="BgCard"       Color="#141419"/>
        <SolidColorBrush x:Key="BgCardHover"  Color="#1A1A2E"/>
        <SolidColorBrush x:Key="BgActive"     Color="#1E1B4B"/>
        <SolidColorBrush x:Key="BgInput"      Color="#1A1A24"/>
        <SolidColorBrush x:Key="BorderDark"   Color="#1E1E2A"/>
        <SolidColorBrush x:Key="BorderLight"  Color="#2A2A35"/>
        <SolidColorBrush x:Key="Primary"      Color="#6366F1"/>
        <SolidColorBrush x:Key="PrimaryDark"  Color="#4338CA"/>
        <SolidColorBrush x:Key="PrimaryLight" Color="#818CF8"/>
        <SolidColorBrush x:Key="Success"      Color="#22C55E"/>
        <SolidColorBrush x:Key="Warning"      Color="#F59E0B"/>
        <SolidColorBrush x:Key="Danger"       Color="#EF4444"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E2E2E8"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8888A0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#555568"/>

        <!-- ── Sidebar Item Style ── -->
        <Style x:Key="NavItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="6,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgCardHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Sidebar Item Active ── -->
        <Style x:Key="NavItemActiveStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgActive}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="6,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ── Stat Card Style ── -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
                    <Setter Property="Background" Value="{StaticResource BgCardHover}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Quick Action Style ── -->
        <Style x:Key="QuickActionStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
                    <Setter Property="Background" Value="{StaticResource BgCardHover}"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Activity Item Style ── -->
        <Style x:Key="ActivityItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BgCard}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Staggered Enter Animations ── -->
        <Storyboard x:Key="StaggerEnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="StatsRow1"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.05">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="StatsRow1RT"
                             Storyboard.TargetProperty="Y"
                             From="24" To="0" Duration="0:0:0.4" BeginTime="0:0:0.05">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="StatsRow2"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="StatsRow2RT"
                             Storyboard.TargetProperty="Y"
                             From="24" To="0" Duration="0:0:0.4" BeginTime="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="QuickActionsSection"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="QuickActionsRT"
                             Storyboard.TargetProperty="Y"
                             From="24" To="0" Duration="0:0:0.4" BeginTime="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>

            <DoubleAnimation Storyboard.TargetName="RecentActivitiesSection"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.4" BeginTime="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RecentActivitiesRT"
                             Storyboard.TargetProperty="Y"
                             From="24" To="0" Duration="0:0:0.4" BeginTime="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- ── Cursor Blink ── -->
        <Storyboard x:Key="CursorBlinkStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="TypewriterCursor"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.5" AutoReverse="True"/>
        </Storyboard>

        <!-- ── Glow Pulse ── -->
        <Storyboard x:Key="PulseGlowStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                             Storyboard.TargetProperty="Opacity"
                             From="0.12" To="0.28" Duration="0:0:5" AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </Window.Resources>


    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- ═══  MAIN CONTAINER                                           ═══ -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <Border Background="{StaticResource BgDark}"
            BorderBrush="{StaticResource BorderDark}"
            BorderThickness="1"
            CornerRadius="10"
            ClipToBounds="True">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>


            <!-- ════════════════════════════════════════════════════════ -->
            <!-- ═══  ROW 0 — CUSTOM TITLE BAR                          ═══ -->
            <!-- ════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Background="{StaticResource BgSidebar}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Border Width="7" Height="7" CornerRadius="4"
                            Background="{StaticResource Primary}" Margin="0,0,9,0"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="DVLD System" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border x:Name="MinBtn" Width="36" Height="36" Cursor="Hand"
                            MouseLeftButtonDown="MinBtn_Click"
                            Background="Transparent">
                        <TextBlock Text="─" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="MaxBtn" Width="36" Height="36" Cursor="Hand"
                            MouseLeftButtonDown="MaxBtn_Click"
                            Background="Transparent">
                        <TextBlock Text="☐" FontSize="11" Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                    </Border>
                    <Border x:Name="CloseBtn" Width="36" Height="36" Cursor="Hand"
                            MouseLeftButtonDown="CloseBtn_Click"
                            Background="Transparent">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DC2626"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="✕" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>


            <!-- ════════════════════════════════════════════════════════ -->
            <!-- ═══  ROW 1 — MAIN CONTENT AREA                          ═══ -->
            <!-- ════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <!-- ══════════════════════════════════════════════════ -->
                <!-- ═══  SIDEBAR                                     ═══ -->
                <!-- ══════════════════════════════════════════════════ -->
                <Border Grid.Column="0" Background="{StaticResource BgSidebar}"
                        BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,1,0">

                    <DockPanel>

                        <!-- ── User Profile ── -->
                        <Border DockPanel.Dock="Top" Padding="16,18"
                                BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <!-- ✅ FIX #1: LinearGradient صحيح -->
                                <Border Width="44" Height="44" CornerRadius="12"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#6366F1" Offset="0"/>
                                            <GradientStop Color="#4338CA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="AM" FontSize="15" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Ayhm Mohammed" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Administrator" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Navigation ── -->
                        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Padding="0,6">
                            <StackPanel>

                                <TextBlock Text="OVERVIEW" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}" Margin="16,8,0,4"/>

                                <Border x:Name="NavDashboard" Style="{StaticResource NavItemActiveStyle}"
                                        MouseLeftButtonUp="NavDashboard_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⬡" FontSize="15" Width="24" TextAlignment="Center"
                                                   Foreground="{StaticResource Primary}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Dashboard" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="PEOPLE" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}" Margin="16,14,0,4"/>

                                <Border x:Name="NavPeople" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavPeople_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👤" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Manage People" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavDrivers" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavDrivers_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🚗" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Manage Drivers" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="SERVICES" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}" Margin="16,14,0,4"/>

                                <Border x:Name="NavNewLocal" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavNewLocal_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📝" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="New Local License" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavNewInternational" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavNewInternational_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌍" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="New Intl. License" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavRenew" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavRenew_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔄" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Renew License" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavReplace" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavReplace_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔁" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Replace License" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavReleaseDetained" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavReleaseDetained_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✅" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Release Detained" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="MANAGEMENT" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}" Margin="16,14,0,4"/>

                                <Border x:Name="NavLocalApps" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavLocalApps_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Local Applications" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavIntlApps" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavIntlApps_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📄" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Intl. Applications" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavDetained" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavDetained_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚠" FontSize="14" Width="24" TextAlignment="Center"
                                                   Foreground="{StaticResource Warning}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Detained Licenses" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavDetainLicense" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavDetainLicense_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔒" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Detain License" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavRetakeTest" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavRetakeTest_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧪" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Retake Test" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavUsers" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavUsers_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👥" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Users" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="CONFIG" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}" Margin="16,14,0,4"/>

                                <Border x:Name="NavAppTypes" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavAppTypes_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Application Types" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavTestTypes" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavTestTypes_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔧" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Test Types" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="ACCOUNT" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMuted}" Margin="16,14,0,4"/>

                                <Border x:Name="NavMyProfile" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavMyProfile_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ℹ" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="My Profile" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="NavChangePassword" Style="{StaticResource NavItemStyle}"
                                        MouseLeftButtonUp="NavChangePassword_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔑" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Change Password" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- ✅ FIX #2: Style مرة واحدة فقط -->
                                <Border x:Name="NavSignOut"
                                        MouseLeftButtonUp="NavSignOut_Click" Margin="6,6,6,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="CornerRadius" Value="8"/>
                                            <Setter Property="Padding" Value="12,9"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2D1515"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🚪" FontSize="14" Width="24" TextAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Sign Out" FontSize="13"
                                                   Foreground="{StaticResource Danger}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                    </DockPanel>
                </Border>


                <Border Grid.Column="1" Width="1" Background="{StaticResource BorderDark}"/>


                <!-- ══════════════════════════════════════════════════ -->
                <!-- ═══  CONTENT AREA                                ═══ -->
                <!-- ══════════════════════════════════════════════════ -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <!-- ══════════════════════════════════════════ -->
                    <!-- ═══  HEADER BAR                          ═══ -->
                    <!-- ══════════════════════════════════════════ -->
                    <Border Grid.Row="0" Background="{StaticResource BgSidebar}"
                            BorderBrush="{StaticResource BorderDark}" BorderThickness="0,0,0,1"
                            Padding="24,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="HeaderTitle" Text="Dashboard"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="HeaderSubtitle" Text="Overview of your driving license system"
                                           FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

                                <Border Background="{StaticResource BgInput}" CornerRadius="8"
                                        BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                        Padding="10,7" Margin="0,0,16,0" Width="200">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔍" FontSize="12" Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Search..." FontSize="12"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock x:Name="DateText" Text="" FontSize="11"
                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>

                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{StaticResource BgInput}" Cursor="Hand"
                                        BorderBrush="{StaticResource BorderDark}" BorderThickness="1"
                                        Margin="0,0,14,0">
                                    <Grid>
                                        <TextBlock Text="🔔" FontSize="14" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Background="{StaticResource Danger}"

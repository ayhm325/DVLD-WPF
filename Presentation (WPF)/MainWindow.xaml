<Window x:Class="DVLD_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVLD System" Height="500" Width="900">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 🔵 Sidebar -->
        <StackPanel Background="#2C3E50">

            <TextBlock Text="MENU"
                       Foreground="White"
                       FontSize="20"
                       Margin="10"/>

            <Button Content="Home" Margin="10" Click="Home_Click"/>
            <Button Content="Users" Margin="10" Click="Users_Click"/>
            <Button Content="Settings" Margin="10" Click="Settings_Click"/>
            <Button Content="Manage People" Margin="10" Click="ManagePeople_Click"/>

        </StackPanel>

        <!-- 🔴 Main Content -->
        <Frame x:Name="MainFrame" Grid.Column="1"/>

    </Grid>
</Window>
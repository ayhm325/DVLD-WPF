<Window x:Class="DVLD_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DVLD System" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundColor}"       
        ResizeMode="CanResize">

    <!-- حاوية رئيسية مع حدود النافذة -->
    <Border BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">

        <DockPanel>

            <!-- ═══════════════ شريط العنوان المخصص ═══════════════ -->
            <Border DockPanel.Dock="Top" 
                    Background="{StaticResource CardBackground}" 
                    Height="40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                        <Border Width="8" Height="8" 
                                CornerRadius="4" 
                                Background="{StaticResource PrimaryColor}" 
                                Margin="0,0,10,0" 
                                VerticalAlignment="Center"/>
                        <TextBlock Text="DVLD System" 
                                   FontSize="13" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextColor}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════ القائمة العلوية ═══════════════ -->
            <Menu DockPanel.Dock="Top" 
                  Background="{StaticResource CardBackground}" 
                  Padding="10,5">

                <MenuItem Header="Applications">
                    <MenuItem Header="Driving Licenses Services">
                        <MenuItem Header="New Driving License">
                            <MenuItem Header="Local License" Click="NewLocalLicnnse_Click"/>
                            <MenuItem Header="International License" Click="InternationalLicense_Click"/>
                        </MenuItem>
                        <MenuItem Header="Renew Driving License"  Click="RenewDrivingLicense_Click"/>
                        <Separator/>
                        <MenuItem Header="Replacement for Lost or Damaged" Click="ReplacementForLostOrDamaged_Click"/>
                        <Separator/>
                        <MenuItem Header="Release Detained Driving License" Click="ReleaseDetainedDrivingLicense_Click"/>
                        <MenuItem Header="Retake Test" Click="RetakeTest_Click"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Manage Applications">
                        <MenuItem Header="Local Driving License Applications" Click="LocalDrivingLicenseApplications_Click"/>
                        <MenuItem Header="International License Applications" Click="InternationalLicenseApplications_Click"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Detain Licenses">
                        <MenuItem Header="Manage Detained Licenses" Click="ManageDetainedLicenses_Click"/>
                        <MenuItem Header="Detain License" Click="DetainLicense_Click"/>
                        <MenuItem Header="Release Detained License" Click="ReleaseDetainedLicense_Click"/>
                    </MenuItem>
                    <MenuItem Header="Manage Application Types" Click="ApplicationType_Click"/>
                    <MenuItem Header="Manage Test Types" Click="TestType_Click"/>
                </MenuItem>

                <MenuItem Header="People" Click="ManagePeople_Click"/>
                <MenuItem Header="Drivers" Click="Drivers_Click"/>
                <MenuItem Header="Users" Click="Users_Click"/>
                <MenuItem Header="Account Settings">
                    <MenuItem Header="Current User Info" Click="CurrentUser_Click"/>
                    <MenuItem Header="Change Password" Click="ChangePassword_Click"/>
                    <Separator/>
                    <MenuItem Header="Sign Out" Click="SignOut_Click"/>
                </MenuItem>
            </Menu>

            <!-- فاصل أسفل القائمة -->
            <Border DockPanel.Dock="Top" Height="1" Background="{StaticResource BorderColor}"/>

            <!-- ═══════════════ منطقة عرض الصفحات والشاشة الفارغة ═══════════════ -->
            <Grid x:Name="ContentArea">

                <!-- إطار عرض الصفحات -->
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

                <!-- ═══════ شاشة الترحيب الاحترافية مع المؤثرات ═══════ -->
                <Grid x:Name="EmptyStatePlaceholder">

                    <Grid.Resources>
                        <!-- حركة النبض للخلفية المتوهجة -->
                        <Storyboard x:Key="PulseGlowStoryboard" RepeatBehavior="Forever">
                            <DoubleAnimation 
                                Storyboard.TargetName="GlowEffect" 
                                Storyboard.TargetProperty="Opacity" 
                                From="0.4" To="0.8" 
                                Duration="0:0:3" 
                                AutoReverse="True">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseInOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>

                        <!-- حركة الظهور التدريجي (Fade In & Slide Up) -->
                        <Storyboard x:Key="FadeInStoryboard">
                            <DoubleAnimation 
                                Storyboard.TargetName="MainContent" 
                                Storyboard.TargetProperty="Opacity" 
                                From="0" To="1" Duration="0:0:1.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuinticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation 
                                Storyboard.TargetName="MainContent" 
                                Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" 
                                From="40" To="0" Duration="0:0:1.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuinticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </Grid.Resources>

                    <!-- تشغيل المؤثرات عند تحميل النافذة -->
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard Storyboard="{StaticResource PulseGlowStoryboard}"/>
                            <BeginStoryboard Storyboard="{StaticResource FadeInStoryboard}"/>
                        </EventTrigger>
                    </Grid.Triggers>

                    <!-- خلفية هندسية خفيفة (تأثير تكنولوجي) -->
                    <Ellipse Width="350" Height="350" Stroke="{StaticResource BorderColor}" StrokeThickness="0.5" StrokeDashArray="4 4" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4"/>
                    <Ellipse Width="520" Height="520" Stroke="{StaticResource BorderColor}" StrokeThickness="0.3" StrokeDashArray="2 6" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.2"/>
                    <Ellipse Width="700" Height="700" Stroke="{StaticResource BorderColor}" StrokeThickness="0.2" StrokeDashArray="1 8" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.1"/>

                    <!-- التوهج الخلفي (Background Glow) - تم تصحيح اللون ليحمل الشفافية بداخل #334F46E5 -->
                    <Ellipse x:Name="GlowEffect" Width="500" Height="500" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#334F46E5" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- المحتوى الرئيسي -->
                    <StackPanel x:Name="MainContent" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TranslateTransform/>
                        </StackPanel.RenderTransform>

                        <!-- حاوية الأيقونة مع الظل المتوهج -->
                        <Border Width="120" Height="120" CornerRadius="28" 
                                Background="#0F0F12" 
                                BorderBrush="#4F46E5" 
                                BorderThickness="1.5" 
                                Margin="0,0,0,40"
                                HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="#4F46E5" BlurRadius="50" ShadowDepth="0" Opacity="0.6"/>
                            </Border.Effect>

                            <TextBlock Text="🪪" FontSize="55" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,5">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="Black"/>
                                        <GradientStop Color="White" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Border>

                        <!-- العنوان الرئيسي مع تأثير التوهج النصي (تم إزالة LetterSpacing) -->
                        <TextBlock Text="DVLD System" 
                                   FontSize="34" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#4F46E5" BlurRadius="25" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <!-- العنوان الفرعي -->
                        <TextBlock Text="Driving License Management" 
                                   FontSize="15" 
                                   FontWeight="SemiBold"
                                   Foreground="#4F46E5" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,8,0,25"
                                   Opacity="0.9"/>

                        <!-- خط فاصل بسيط -->
                        <Rectangle Width="50" Height="2" Fill="#4F46E5" HorizontalAlignment="Center" Margin="0,0,0,25" Opacity="0.4" RadiusX="1" RadiusY="1"/>

                        <!-- وصف الترحيب -->
                        <TextBlock Text="Navigate through the menu above to manage licenses," 
                                   FontSize="13" 
                                   Foreground="{StaticResource SecondaryTextColor}" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center" 
                                   Opacity="0.7"/>
                        <TextBlock Text="applications, drivers, and system users." 
                                   FontSize="13" 
                                   Foreground="{StaticResource SecondaryTextColor}" 
                                   HorizontalAlignment="Center" 
                                   TextAlignment="Center" 
                                   Opacity="0.7"
                                   Margin="0,0,0,0"/>

                    </StackPanel>
                </Grid>

            </Grid>

        </DockPanel>
    </Border>
</Window>